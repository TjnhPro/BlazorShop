# BlazorShop V2 local manual QA environment.
# This file is development-only. Values here are intentionally simple local defaults.
# The database names are dedicated to this runner so dirty dev databases do not block migrations.

RUN__CONTROL_PLANE_API_URL=http://localhost:5280
RUN__CONTROL_PLANE_WEB_URL=http://localhost:5281
RUN__COMMERCE_NODE_API_URL=http://localhost:5180
RUN__STOREFRONT_URL=http://localhost:18598
RUN__OPEN_BROWSER=true
RUN__BOOTSTRAP_CONTROLPLANE=true
RUN__CONTROL_PLANE_NODE_NAME=Local Commerce Node
RUN__CONTROL_PLANE_STORE_NAME=Default QA Store

COMMON__ASPNETCORE_ENVIRONMENT=Development
COMMON__DOTNET_ENVIRONMENT=Development

CONTROLPLANE_API__ConnectionStrings__ControlPlaneConnection=Host=localhost;Port=5433;Database=blazorshop_controlplane_v2_local;Username=blazorshop_controlplane;Password=blazorshop_controlplane_dev
CONTROLPLANE_API__Jwt__Key=development-only-control-plane-jwt-key-change-before-production
CONTROLPLANE_API__Jwt__Issuer=http://localhost:5280
CONTROLPLANE_API__Jwt__Audience=http://localhost:5280
CONTROLPLANE_API__ClientApp__BaseUrl=http://localhost:5281
CONTROLPLANE_API__ControlPlane__Database__MigrateOnStartup=true
CONTROLPLANE_API__ControlPlane__Database__FailStartupOnMigrationError=true
CONTROLPLANE_API__ControlPlane__Database__LogMigrationState=true
CONTROLPLANE_API__ControlPlane__Probes__ScheduledEnabled=true
CONTROLPLANE_API__ControlPlane__Probes__IntervalSeconds=30
CONTROLPLANE_API__ControlPlane__Probes__TimeoutSeconds=10
CONTROLPLANE_API__ControlPlane__SeedAdmin__Enabled=true
CONTROLPLANE_API__ControlPlane__SeedAdmin__Email=admin@example.local
CONTROLPLANE_API__ControlPlane__SeedAdmin__Password=Admin123!
CONTROLPLANE_API__ControlPlane__SeedAdmin__DisplayName=Control Plane Admin
CONTROLPLANE_API__ControlPlane__SeedAdmin__IdentityRole=Admin
CONTROLPLANE_API__ControlPlane__SeedAdmin__ControlPlaneRoleKey=platform_owner
CONTROLPLANE_API__ControlPlane__SeedUser__Enabled=true
CONTROLPLANE_API__ControlPlane__SeedUser__Email=user@example.local
CONTROLPLANE_API__ControlPlane__SeedUser__Password=User123!
CONTROLPLANE_API__ControlPlane__SeedUser__DisplayName=Control Plane User
CONTROLPLANE_API__ControlPlane__SeedUser__IdentityRole=User
CONTROLPLANE_API__ControlPlane__SeedUser__ControlPlaneRoleKey=auditor

CONTROLPLANE_WEB__ASPNETCORE_ENVIRONMENT=Development

COMMERCENODE_API__ConnectionStrings__CommerceNodeConnection=Host=localhost;Port=5434;Database=blazorshop_commerce_node_v2_local;Username=blazorshop_commerce_node;Password=blazorshop_commerce_node_dev
COMMERCENODE_API__JWT__Key=development-commerce-node-jwt-key-change-before-production
COMMERCENODE_API__JWT__Issuer=http://localhost:5180
COMMERCENODE_API__JWT__Audience=http://localhost:5180
COMMERCENODE_API__ClientApp__BaseUrl=http://localhost:18598
COMMERCENODE_API__CommerceNode__NodeKey=dev-node
COMMERCENODE_API__CommerceNode__NodeSecret=dev-node-secret
COMMERCENODE_API__CommerceNode__AllowedControlPlaneIps__0=127.0.0.1
COMMERCENODE_API__CommerceNode__AllowedControlPlaneIps__1=::1
COMMERCENODE_API__CommerceNode__Database__MigrateOnStartup=true
COMMERCENODE_API__CommerceNode__Database__FailStartupOnMigrationError=true
COMMERCENODE_API__CommerceNode__Database__LogMigrationState=true
COMMERCENODE_API__StorefrontDeployment__NetworkName=blazorshop-commercenode
COMMERCENODE_API__StorefrontDeployment__EnvDirectory=runtime/storefront-env
COMMERCENODE_API__StorefrontDeployment__StorefrontApiBaseUrl=http://host.docker.internal:5180/api/
COMMERCENODE_API__StorefrontDeployment__AllowedImages__0=blazorshop-storefront-v2:latest
COMMERCENODE_API__NginxDeployment__MediaUpstreamUrl=http://host.docker.internal:5180

STOREFRONT_V2__ASPNETCORE_ENVIRONMENT=Development
STOREFRONT_V2__Api__BaseUrl=http://localhost:5180/api/
STOREFRONT_V2__Api__StoreKey=default
STOREFRONT_V2__StoreKey=default
STOREFRONT_V2__StoreResolution__RequireCurrentStore=true
STOREFRONT_V2__ClientApp__BaseUrl=http://localhost:18598/
STOREFRONT_V2__PublicUrl__BaseUrl=http://localhost:18598/

@if (Errors.Count > 0)
{
    <section class="starter-state starter-state-error" role="alert">
        <h2>@Title</h2>
        <ul>
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </section>
}

@code {
    [Parameter]
    public string Title { get; set; } = "Validation failed";

    [Parameter]
    public IReadOnlyList<string> Errors { get; set; } = [];
}

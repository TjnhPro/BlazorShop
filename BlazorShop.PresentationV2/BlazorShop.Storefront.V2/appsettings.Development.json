{
  "Api": {
    "BaseUrl": "http://localhost:5180/api/",
    "RefreshTokenRoute": "auth/refresh-token",
    "EnableLegacyFallback": false,
    "StoreKey": "default"
  },
  "ClientApp": {
    "BaseUrl": "https://localhost:7258/"
  },
  "StoreResolution": {
    "RequireCurrentStore": true
  },
  "Storefront": {
    "RateLimiting": {
      "Enabled": true,
      "Cart": {
        "PermitLimit": 240,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "ForwardedHeaders": {
      "KnownProxies": [],
      "KnownNetworks": []
    }
  }
}

@page "/account/orders"
@using System.Globalization
@inject IStorefrontSessionResolver SessionResolver
@inject StorefrontApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Account orders</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<section class="mx-auto max-w-7xl px-4 pb-12 pt-10 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[220px_minmax(0,1fr)] lg:items-start">
        <nav class="rounded border border-neutral-200 bg-white p-4 text-sm">
            <a class="block rounded px-3 py-2 font-semibold text-neutral-700 hover:bg-neutral-100" href="@StorefrontRoutes.AccountProfile">Profile</a>
            <a class="mt-2 block rounded bg-neutral-900 px-3 py-2 font-semibold text-white" href="@StorefrontRoutes.AccountOrders">Orders</a>
            <a class="mt-2 block rounded px-3 py-2 font-semibold text-neutral-700 hover:bg-neutral-100" href="@StorefrontRoutes.AccountAddresses">Addresses</a>
            <a class="mt-2 block rounded px-3 py-2 font-semibold text-neutral-700 hover:bg-neutral-100" href="@StorefrontRoutes.AccountChangePassword">Password</a>
        </nav>

        <article class="rounded border border-neutral-200 bg-white">
            <header class="border-b border-neutral-200 px-6 py-6">
                <p class="text-sm font-semibold uppercase text-neutral-500">Customer account</p>
                <h1 class="mt-2 text-3xl font-extrabold text-neutral-900">Orders</h1>
            </header>

            <div class="px-6 py-6">
                @if (_loading)
                {
                    <p class="text-sm text-neutral-600">Loading orders...</p>
                }
                else if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="rounded border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800" role="alert">@_error</div>
                }
                else if (_orders.Count == 0)
                {
                    <p class="text-sm text-neutral-700">No orders yet.</p>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-neutral-200 text-sm">
                            <thead class="text-left text-xs font-semibold uppercase text-neutral-500">
                                <tr>
                                    <th class="py-3 pr-4">Reference</th>
                                    <th class="py-3 pr-4">Date</th>
                                    <th class="py-3 pr-4">Status</th>
                                    <th class="py-3 pr-4">Payment</th>
                                    <th class="py-3 pr-4">Total</th>
                                    <th class="py-3 pr-4">Items</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-neutral-100">
                                @foreach (var order in _orders)
                                {
                                    <tr>
                                        <td class="py-4 pr-4 font-semibold text-neutral-900">
                                            <a class="underline decoration-neutral-300 underline-offset-4 hover:decoration-neutral-900" href="@BuildOrderUrl(order.Reference)">@order.Reference</a>
                                        </td>
                                        <td class="py-4 pr-4 text-neutral-700">@order.CreatedOn.ToString("yyyy-MM-dd")</td>
                                        <td class="py-4 pr-4 text-neutral-700">@order.OrderStatus</td>
                                        <td class="py-4 pr-4 text-neutral-700">@order.PaymentStatus</td>
                                        <td class="py-4 pr-4 text-neutral-900">@FormatMoney(order.TotalAmount, order.CurrencyCode)</td>
                                        <td class="py-4 pr-4 text-neutral-700">@order.ItemCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </article>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "page")]
    public int Page { get; set; } = 1;

    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<StorefrontCustomerOrderListItemResponse> _orders = [];

    protected override async Task OnInitializedAsync()
    {
        var session = await SessionResolver.GetCurrentUserAsync();
        if (!session.IsAuthenticated || string.IsNullOrWhiteSpace(session.AccessToken))
        {
            NavigationManager.NavigateTo(StorefrontReturnUrl.BuildSignInUrl(StorefrontRoutes.AccountOrders), replace: true);
            return;
        }

        var result = await ApiClient.GetCustomerOrdersAsync(session.AccessToken, Math.Max(1, Page), 10);
        if (result.Success)
        {
            _orders = result.Data?.Items ?? [];
        }
        else
        {
            _error = result.Message;
        }

        _loading = false;
    }

    private static string BuildOrderUrl(string reference)
    {
        return $"/account/orders/{Uri.EscapeDataString(reference)}";
    }

    private static string FormatMoney(decimal amount, string? currencyCode)
    {
        return string.Create(CultureInfo.InvariantCulture, $"{amount:0.00} {currencyCode ?? string.Empty}").Trim();
    }
}

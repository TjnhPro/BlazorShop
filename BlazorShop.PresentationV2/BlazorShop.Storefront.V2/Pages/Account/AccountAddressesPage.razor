@page "/account/addresses"
@using Microsoft.AspNetCore.Antiforgery
@inject IStorefrontSessionResolver SessionResolver
@inject IStorefrontCustomerClient ApiClient
@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery

<PageTitle>Account addresses</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<AccountPageShell Title="Addresses" ActiveRoute="@StorefrontRoutes.AccountAddresses">
    @if (_loading)
    {
        <p class="text-sm text-neutral-600">Loading addresses...</p>
    }
    else
    {
        <AccountAddressBook
            InitialAddresses="_addresses"
            InitialError="@(_error ?? Error)"
            InitialSuccess="@(Saved == "1" ? "Address book updated." : null)"
            FormAction="@StorefrontRoutes.AccountAddresses"
            AntiforgeryFieldName="_antiforgeryFieldName"
            AntiforgeryRequestToken="_antiforgeryRequestToken"
            @rendermode="InteractiveWebAssembly" />
    }
</AccountPageShell>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<StorefrontBrowserCustomerAddress> _addresses = [];
    private string? _antiforgeryFieldName;
    private string? _antiforgeryRequestToken;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "saved")]
    public string? Saved { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var tokens = HttpContext is null ? null : Antiforgery.GetAndStoreTokens(HttpContext);
        _antiforgeryFieldName = tokens?.FormFieldName;
        _antiforgeryRequestToken = tokens?.RequestToken;

        var session = await SessionResolver.GetCurrentUserAsync();
        if (!session.IsAuthenticated || string.IsNullOrWhiteSpace(session.AccessToken))
        {
            NavigationManager.NavigateTo(StorefrontReturnUrl.BuildSignInUrl(StorefrontRoutes.AccountAddresses), replace: true);
            return;
        }

        var result = await ApiClient.GetCustomerAddressesAsync(session.AccessToken);
        if (result.Success)
        {
            _addresses = (result.Data ?? []).Select(ToBrowserAddress).ToArray();
        }
        else
        {
            _error = result.Message;
        }

        _loading = false;
    }

    private static StorefrontBrowserCustomerAddress ToBrowserAddress(StorefrontCustomerAddressResponse address)
    {
        return new StorefrontBrowserCustomerAddress(
            address.PublicId,
            address.FullName,
            address.Company,
            address.Email,
            address.Phone,
            address.Address1,
            address.Address2,
            address.City,
            address.PostalCode,
            address.CountryCode,
            address.StateProvinceCode,
            address.StateProvinceName,
            address.IsDefaultShipping,
            address.IsDefaultBilling);
    }
}

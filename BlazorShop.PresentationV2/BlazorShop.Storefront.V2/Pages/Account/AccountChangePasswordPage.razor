@page "/account/change-password"
@using Microsoft.AspNetCore.Antiforgery
@inject IStorefrontSessionResolver SessionResolver
@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery

<PageTitle>Change password</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<AccountPageShell Title="Change password" ActiveRoute="@StorefrontRoutes.AccountChangePassword">
    <AccountChangePasswordForm
        InitialError="@ErrorMessage"
        InitialSuccess="@SuccessMessage"
        FormAction="@StorefrontRoutes.AccountChangePassword"
        AntiforgeryFieldName="_antiforgeryFieldName"
        AntiforgeryRequestToken="_antiforgeryRequestToken"
        @rendermode="InteractiveWebAssembly" />
</AccountPageShell>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "saved")]
    public string? Saved { get; set; }

    private string? ErrorMessage => this.Error;

    private string? SuccessMessage => this.Saved == "1" ? "Password changed." : null;

    private string? _antiforgeryFieldName;
    private string? _antiforgeryRequestToken;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var tokens = HttpContext is null ? null : Antiforgery.GetAndStoreTokens(HttpContext);
        _antiforgeryFieldName = tokens?.FormFieldName;
        _antiforgeryRequestToken = tokens?.RequestToken;

        var session = await SessionResolver.GetCurrentUserAsync();
        if (!session.IsAuthenticated || string.IsNullOrWhiteSpace(session.AccessToken))
        {
            NavigationManager.NavigateTo(StorefrontReturnUrl.BuildSignInUrl(StorefrontRoutes.AccountChangePassword), replace: true);
        }
    }
}

@page "/account/orders"
@using System.Globalization
@inject IStorefrontSessionResolver SessionResolver
@inject IStorefrontCustomerClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Account orders</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<AccountPageShell Title="Orders" ActiveRoute="@StorefrontRoutes.AccountOrders">
    @if (_loading)
    {
        <p class="text-sm text-neutral-600">Loading orders...</p>
    }
    else
    {
        <AccountOrderList InitialOrders="_orders" InitialError="@_error" PageNumber="Page" @rendermode="InteractiveWebAssembly" />
    }
</AccountPageShell>

@code {
    [SupplyParameterFromQuery(Name = "page")]
    public int Page { get; set; } = 1;

    private bool _loading = true;
    private string? _error;
    private StorefrontBrowserAccountOrderList _orders = new([], 1, 10, 0, 0);

    protected override async Task OnInitializedAsync()
    {
        var session = await SessionResolver.GetCurrentUserAsync();
        if (!session.IsAuthenticated || string.IsNullOrWhiteSpace(session.AccessToken))
        {
            NavigationManager.NavigateTo(StorefrontReturnUrl.BuildSignInUrl(StorefrontRoutes.AccountOrders), replace: true);
            return;
        }

        var result = await ApiClient.GetCustomerOrdersAsync(session.AccessToken, Math.Max(1, Page), 10);
        if (result.Success)
        {
            _orders = result.Data is null ? new([], Math.Max(1, Page), 10, 0, 0) : ToBrowserOrderList(result.Data);
        }
        else
        {
            _error = result.Message;
        }

        _loading = false;
    }

    private static StorefrontBrowserAccountOrderList ToBrowserOrderList(PagedResult<StorefrontCustomerOrderListItemResponse> orders)
    {
        return new StorefrontBrowserAccountOrderList(
            orders.Items.Select(ToBrowserOrderListItem).ToArray(),
            orders.PageNumber,
            orders.PageSize,
            orders.TotalCount,
            orders.TotalPages);
    }

    private static StorefrontBrowserAccountOrderListItem ToBrowserOrderListItem(StorefrontCustomerOrderListItemResponse order)
    {
        return new StorefrontBrowserAccountOrderListItem(
            order.Reference,
            order.CreatedOn.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture),
            order.OrderStatus,
            order.PaymentStatus,
            order.ShippingStatus,
            FormatMoney(order.TotalAmount, order.CurrencyCode),
            order.ItemCount);
    }

    private static string FormatMoney(decimal amount, string? currencyCode)
    {
        return string.Create(CultureInfo.InvariantCulture, $"{amount:0.00} {currencyCode ?? string.Empty}").Trim();
    }
}

@page "/checkout"
@inject StorefrontApiClient ApiClient
@inject StorefrontCartTokenService CartTokenService

<PageTitle>Checkout</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<section class="mx-auto max-w-7xl px-4 pb-12 pt-10 sm:px-6 lg:px-8">
    @if (!string.IsNullOrWhiteSpace(OrderReference))
    {
        <div class="rounded-3xl border border-emerald-200 bg-emerald-50 px-6 py-10 text-center shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Order placed</p>
            <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-emerald-950">Thank you</h1>
            <p class="mt-3 text-base text-emerald-900">Your order reference is <span class="font-mono font-bold">@OrderReference</span>.</p>
            <a href="@StorefrontRoutes.Home" class="mt-6 inline-flex items-center rounded bg-neutral-900 px-4 py-3 font-semibold text-white hover:bg-neutral-800">Continue shopping</a>
        </div>
    }
    else if (Lines.Count == 0)
    {
        <StorefrontCheckoutShell InitialState="CheckoutState" ShowPanel="false" @rendermode="InteractiveWebAssembly" />
        <div class="rounded-3xl border border-dashed border-neutral-300 bg-white/80 px-6 py-10 text-center shadow-sm">
            <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Your cart is empty</h1>
            <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-neutral-700">Add products before continuing to checkout.</p>
            <a href="@StorefrontRoutes.NewReleases" class="mt-6 inline-flex items-center rounded bg-neutral-900 px-4 py-3 font-semibold text-white hover:bg-neutral-800">Shop New Releases</a>
        </div>
    }
    else
    {
        <StorefrontCheckoutShell InitialState="CheckoutState" ShowPanel="false" @rendermode="InteractiveWebAssembly" />
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_380px] lg:items-start">
            <article class="rounded-3xl border border-neutral-200/70 bg-white/95 shadow-lg">
                <header class="border-b border-neutral-200 px-6 py-7 sm:px-8">
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Storefront checkout</p>
                    <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-neutral-900">Checkout</h1>
                    <p class="mt-3 max-w-2xl text-base leading-7 text-neutral-700">Enter contact and shipping details to place this order.</p>
                </header>

                <div class="px-6 py-7 sm:px-8">
                    @if (!string.IsNullOrWhiteSpace(Error))
                    {
                        <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800" role="alert">
                            @Error
                        </div>
                    }

                    @if (PaymentMethods.Count == 0)
                    {
                        <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">No payment method is currently available.</div>
                    }
                    else
                    {
                        <form method="post" action="@StorefrontRoutes.Checkout" class="space-y-6">
                            <AntiforgeryToken />
                            <input type="hidden" name="CartVersion" value="@CartVersion" />
                            <input type="hidden" name="IdempotencyKey" value="@IdempotencyKey" />
                            <input type="hidden" name="UseShippingAddressAsBillingAddress" value="true" />

                            <section class="grid gap-4 md:grid-cols-2">
                                <label class="block text-sm">
                                    <span class="font-semibold text-neutral-800">Customer email</span>
                                    <input name="CustomerEmail" type="email" autocomplete="email" required class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                </label>
                                <label class="block text-sm">
                                    <span class="font-semibold text-neutral-800">Customer name</span>
                                    <input name="CustomerName" autocomplete="name" required class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                </label>
                            </section>

                            <section class="space-y-4">
                                <h2 class="text-lg font-bold text-neutral-950">Shipping address</h2>
                                @if (CustomerAddresses.Count > 0)
                                {
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">Saved address</span>
                                        <select name="ShippingAddressId" data-storefront-address-select class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100">
                                            <option value="">Enter a new address</option>
                                            @foreach (var address in CustomerAddresses)
                                            {
                                                <option value="@address.PublicId" selected="@(SelectedShippingAddress?.PublicId == address.PublicId)">
                                                    @FormatAddressOption(address)
                                                </option>
                                            }
                                        </select>
                                    </label>
                                }

                                <div class="grid gap-4 md:grid-cols-2" data-storefront-manual-address>
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">Full name</span>
                                        <input name="ShippingFullName" value="@SelectedShippingAddress?.FullName" autocomplete="shipping name" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                    </label>
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">Email</span>
                                        <input name="ShippingEmail" value="@SelectedShippingAddress?.Email" type="email" autocomplete="shipping email" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                    </label>
                                    @if (PhoneEnabled)
                                    {
                                        <label class="block text-sm">
                                            <span class="font-semibold text-neutral-800">Phone</span>
                                            <input name="ShippingPhone" value="@SelectedShippingAddress?.Phone" autocomplete="shipping tel" required="@PhoneRequired" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                        </label>
                                    }
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">Country</span>
                                        @if (HasAddressCountries)
                                        {
                                            <select name="ShippingCountryCode" autocomplete="shipping country" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100">
                                                @foreach (var country in AddressCountries)
                                                {
                                                    <option value="@country.Code" selected="@(string.Equals(country.Code, DefaultShippingCountryCode, StringComparison.OrdinalIgnoreCase))">@country.Name</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input name="ShippingCountryCode" maxlength="2" value="@DefaultShippingCountryCode" autocomplete="shipping country" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm uppercase text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                        }
                                    </label>
                                    <label class="block text-sm md:col-span-2">
                                        <span class="font-semibold text-neutral-800">Address line 1</span>
                                        <input name="ShippingAddress1" value="@SelectedShippingAddress?.Address1" autocomplete="shipping address-line1" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                    </label>
                                    <label class="block text-sm md:col-span-2">
                                        <span class="font-semibold text-neutral-800">Address line 2</span>
                                        <input name="ShippingAddress2" value="@SelectedShippingAddress?.Address2" autocomplete="shipping address-line2" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                    </label>
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">City</span>
                                        <input name="ShippingCity" value="@SelectedShippingAddress?.City" autocomplete="shipping address-level2" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                    </label>
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">State / province</span>
                                        @if (HasAddressStates)
                                        {
                                            <select name="ShippingState" autocomplete="shipping address-level1" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100">
                                                <option value="">Select state / province</option>
                                                @foreach (var state in AddressStates)
                                                {
                                                    <option value="@state.Code" selected="@(string.Equals(state.Code, DefaultShippingStateCode, StringComparison.OrdinalIgnoreCase))">@state.Name</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input name="ShippingState" value="@DefaultShippingStateCode" autocomplete="shipping address-level1" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                        }
                                    </label>
                                    <label class="block text-sm">
                                        <span class="font-semibold text-neutral-800">Postal code</span>
                                        <input name="ShippingPostalCode" value="@SelectedShippingAddress?.PostalCode" autocomplete="shipping postal-code" required="@PostalCodeRequired" data-storefront-manual-address-field class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                                    </label>
                                </div>
                            </section>

                            <section class="space-y-3">
                                <h2 class="text-lg font-bold text-neutral-950">Payment</h2>
                                @foreach (var method in PaymentMethods)
                                {
                                    <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-neutral-200 bg-neutral-50 p-4 text-sm hover:bg-neutral-100">
                                        <input class="mt-1" type="radio" name="PaymentMethodKey" value="@method.Key" checked="@(method == PaymentMethods[0])" />
                                        <span>
                                            <span class="block font-bold text-neutral-950">@method.DisplayName</span>
                                            <span class="mt-1 block text-neutral-600">@method.Description</span>
                                        </span>
                                    </label>
                                }
                            </section>

                            <button type="submit" class="inline-flex w-full items-center justify-center rounded bg-amber-500 px-4 py-3 font-semibold text-white hover:bg-amber-600">
                                Place order
                            </button>
                        </form>
                    }
                </div>
            </article>

            <aside class="rounded-3xl border border-neutral-200/70 bg-white/95 p-6 shadow-lg">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Order Summary</p>
                <div class="mt-5 divide-y divide-neutral-100">
                    @foreach (var line in Lines)
                    {
                        <div class="flex gap-3 py-3 text-sm">
                            <div class="flex-1">
                                <div class="font-semibold text-neutral-950">@line.DisplayName</div>
                                <div class="mt-1 text-neutral-500">Qty @line.Quantity</div>
                            </div>
                            <div class="font-semibold text-neutral-900">@FormatPrice(line.LineTotal, line.CurrencyCode)</div>
                        </div>
                    }
                </div>
                @if (ServerSubtotal.HasValue)
                {
                    <div class="mt-5 space-y-2 border-t border-neutral-200 pt-4 text-sm text-neutral-700">
                        <div class="flex items-center justify-between">
                            <span>Subtotal</span>
                            <span>@FormatPrice(ServerSubtotal.Value, GrandTotalCurrencyCode)</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span>Shipping</span>
                            <span>@FormatPrice(ServerShippingTotal.GetValueOrDefault(), GrandTotalCurrencyCode)</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span>Tax</span>
                            <span>@FormatPrice(ServerTaxTotal.GetValueOrDefault(), GrandTotalCurrencyCode)</span>
                        </div>
                        @if (ServerDiscountTotal.GetValueOrDefault() != 0m)
                        {
                            <div class="flex items-center justify-between">
                                <span>Discount</span>
                                <span>@FormatPrice(ServerDiscountTotal.GetValueOrDefault(), GrandTotalCurrencyCode)</span>
                            </div>
                        }
                    </div>
                }
                <div class="mt-5 flex items-center justify-between border-t border-neutral-200 pt-4 text-base font-black text-neutral-950">
                    <span>Total</span>
                    <span>@GrandTotalDisplay</span>
                </div>
            </aside>
        </div>
    }
</section>

@page "/reset-password"

<PageTitle>Reset password</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<section class="mx-auto max-w-7xl px-4 pb-12 pt-10 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <article class="rounded-3xl border border-neutral-200/70 bg-white/95 shadow-lg">
            <header class="border-b border-neutral-200 px-6 py-7 sm:px-8">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Account recovery</p>
                <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-neutral-900">Reset password</h1>
                <p class="mt-3 max-w-2xl text-base leading-7 text-neutral-700">Choose a new password for your storefront customer account.</p>
            </header>

            <div class="px-6 py-7 sm:px-8">
                @if (!string.IsNullOrWhiteSpace(Error))
                {
                    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800" role="alert">
                        @Error
                    </div>
                }

                @if (MissingRecoveryData)
                {
                    <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-900" role="alert">
                        This reset link is incomplete or expired. Request a new password reset email.
                    </div>
                    <a href="@StorefrontRoutes.ForgotPassword" class="mt-5 inline-flex items-center rounded bg-neutral-900 px-4 py-3 font-semibold text-white hover:bg-neutral-800">
                        Request a new reset link
                    </a>
                }
                else
                {
                    <form method="post" action="@StorefrontRoutes.ResetPassword" class="max-w-xl space-y-5">
                        <AntiforgeryToken />
                        <input type="hidden" name="Email" value="@Email" />
                        <input type="hidden" name="Token" value="@Token" />

                        <label class="block text-sm">
                            <span class="font-semibold text-neutral-800">Email address</span>
                            <input type="email"
                                   value="@Email"
                                   disabled
                                   class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-neutral-100 px-3 text-sm text-neutral-700" />
                        </label>

                        <label class="block text-sm">
                            <span class="font-semibold text-neutral-800">New password</span>
                            <input name="Password"
                                   type="password"
                                   autocomplete="new-password"
                                   required
                                   minlength="8"
                                   class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                        </label>

                        <label class="block text-sm">
                            <span class="font-semibold text-neutral-800">Confirm new password</span>
                            <input name="ConfirmPassword"
                                   type="password"
                                   autocomplete="new-password"
                                   required
                                   minlength="8"
                                   class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                        </label>

                        <button type="submit" class="inline-flex w-full items-center justify-center rounded bg-neutral-900 px-4 py-3 font-semibold text-white hover:bg-neutral-800">
                            Reset password
                        </button>
                    </form>
                }
            </div>

            <footer class="border-t border-neutral-200 px-6 py-5 text-sm text-neutral-700 sm:px-8">
                <div class="flex flex-wrap items-center justify-between gap-3">
                    <span>Already updated your password?</span>
                    <a href="@StorefrontRoutes.SignIn" class="font-semibold text-neutral-950 hover:text-neutral-700">Sign in</a>
                </div>
            </footer>
        </article>

        <aside class="rounded-3xl border border-neutral-200/70 bg-white/90 p-6 shadow-lg">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Security</p>
            <div class="mt-5 space-y-3 text-sm leading-6 text-neutral-700">
                <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
                    <div class="font-semibold text-neutral-950">Single purpose link</div>
                    <p class="mt-1">Reset links expire and should only be used from the recovery email.</p>
                </div>
                <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
                    <div class="font-semibold text-neutral-950">Private failure</div>
                    <p class="mt-1">Invalid or expired links show a generic error.</p>
                </div>
            </div>
        </aside>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private bool MissingRecoveryData => string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token);
}

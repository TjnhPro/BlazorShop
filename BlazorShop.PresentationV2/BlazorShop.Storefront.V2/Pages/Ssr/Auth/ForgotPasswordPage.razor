@page "/forgot-password"

<PageTitle>Forgot password</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<section class="mx-auto max-w-7xl px-4 pb-12 pt-10 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <article class="rounded-3xl border border-neutral-200/70 bg-white/95 shadow-lg">
            <header class="border-b border-neutral-200 px-6 py-7 sm:px-8">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Account recovery</p>
                <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-neutral-900">Forgot password</h1>
                <p class="mt-3 max-w-2xl text-base leading-7 text-neutral-700">Enter your email address and we will send reset instructions if a matching customer account exists.</p>
            </header>

            <div class="px-6 py-7 sm:px-8">
                @if (Sent == "1")
                {
                    <div class="mb-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800" role="status">
                        If that email is registered, password reset instructions will arrive shortly.
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Error))
                {
                    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800" role="alert">
                        @Error
                    </div>
                }

                <form method="post" action="@StorefrontRoutes.ForgotPassword" class="max-w-xl space-y-5">
                    <AntiforgeryToken />
                    <input type="hidden" name="CaptchaToken" data-storefront-captcha-token="password-recovery" />

                    <label class="block text-sm">
                        <span class="font-semibold text-neutral-800">Email address</span>
                        <input name="Email"
                               type="email"
                               autocomplete="email"
                               required
                               value="@Email"
                               class="mt-2 min-h-11 w-full rounded-xl border border-neutral-300 bg-white px-3 text-sm text-neutral-900 outline-none focus:border-neutral-600 focus:ring-2 focus:ring-neutral-100" />
                    </label>

                    <button type="submit" class="inline-flex w-full items-center justify-center rounded bg-neutral-900 px-4 py-3 font-semibold text-white hover:bg-neutral-800">
                        Send reset instructions
                    </button>
                </form>
            </div>

            <footer class="border-t border-neutral-200 px-6 py-5 text-sm text-neutral-700 sm:px-8">
                <div class="flex flex-wrap items-center justify-between gap-3">
                    <span>Remembered your password?</span>
                    <a href="@StorefrontRoutes.SignIn" class="font-semibold text-neutral-950 hover:text-neutral-700">Back to sign in</a>
                </div>
            </footer>
        </article>

        <aside class="rounded-3xl border border-neutral-200/70 bg-white/90 p-6 shadow-lg">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Recovery policy</p>
            <div class="mt-5 space-y-3 text-sm leading-6 text-neutral-700">
                <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
                    <div class="font-semibold text-neutral-950">Private by default</div>
                    <p class="mt-1">The same confirmation appears whether or not the email is registered.</p>
                </div>
                <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
                    <div class="font-semibold text-neutral-950">Reset link</div>
                    <p class="mt-1">Use the link from the email to choose a new password.</p>
                </div>
            </div>
        </aside>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "sent")]
    public string? Sent { get; set; }
}

@page "/product/{Slug}"
@inject IStorefrontCatalogClient ApiClient
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontStructuredDataComposer StructuredDataComposer
@inject IStorefrontDisplayContextProvider DisplayContextProvider
@inject IStorefrontPriceFormatter PriceFormatter
@inject ILogger<ProductPage> Logger

<SeoHead Metadata="_metadata" StructuredData="_structuredData" />

@if (_isServiceUnavailable)
{
    <ServiceUnavailableState Title="Product temporarily unavailable"
                             Message="The storefront is running, but the catalog API is not reachable right now. Start the API project or AppHost and refresh this page." />
}
else if (_isNotFound)
{
    <NotFoundState Title="Product not found"
                   Message="We couldn't find a published product for this address." />
}
else if (_product is not null)
{
    <StorefrontPageShell Class="mx-auto max-w-7xl px-4 pb-8 pt-10 sm:px-6 lg:px-8">
        <Breadcrumb>
            <BreadcrumbNav Items="_breadcrumbs" />
        </Breadcrumb>

        <ChildContent>
            <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
                <div class="rounded-3xl border border-neutral-200/70 bg-white/90 p-6 shadow-lg">
                    <ProductGallery Items="_galleryItems" ProductName="@_product.Name" />
                </div>

                <div class="rounded-3xl border border-neutral-200/70 bg-white/90 p-8 shadow-lg">
                    @if (!string.IsNullOrWhiteSpace(_product.Category?.Slug))
                    {
                        <a href="@StorefrontRoutes.Category(_product.Category.Slug)" class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500 hover:text-neutral-900">@_product.Category.Name</a>
                    }
                    else if (!string.IsNullOrWhiteSpace(_product.Category?.Name))
                    {
                        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">@_product.Category.Name</p>
                    }

                    @if (IsFreshArrival)
                    {
                        <div class="mt-4 flex flex-wrap items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.18em]">
                            <span class="inline-block rounded bg-green-600/90 px-2 py-0.5 text-white">New</span>
                        </div>
                    }

                    <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-neutral-900">@_product.Name</h1>
                    <div class="mt-5">
                        <div class="text-sm text-neutral-500">@PrimaryPriceLabel</div>
                        <div class="mt-1 flex flex-wrap items-end gap-3">
                            <span class="text-4xl font-black text-neutral-900" data-storefront-selection-price>@DisplayPrice</span>
                            <span class="pb-1 text-lg font-semibold text-neutral-400 line-through @(HasComparePrice ? null : "hidden")" data-storefront-selection-compare>
                                @(HasComparePrice ? FormatPrice(DisplayComparePriceAmount!.Value, DisplayCurrencyCode) : string.Empty)
                            </span>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-neutral-600">
                        <span class="inline-flex items-center rounded-full bg-neutral-100 px-3 py-1 font-semibold text-neutral-700">@VariantSummary</span>
                        <span class="inline-flex items-center rounded-full bg-neutral-100 px-3 py-1 font-semibold text-neutral-700 @(string.IsNullOrWhiteSpace(DefaultSkuLabel) ? "hidden" : null)" data-storefront-selection-sku>@DefaultSkuLabel</span>
                        <span class="@StockBadgeClass" data-storefront-selection-stock>@StockSummary</span>
                    </div>

                    <p class="mt-6 text-base leading-7 text-neutral-700">@ProductDescription</p>

                <ProductPurchasePanel Model="_purchasePanel" />

                @if (_product.Variants.Any())
                {
                    <div class="mt-8">
                        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Available Variants</h2>
                        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                            @foreach (var variant in _product.Variants)
                            {
                                <li class="rounded-2xl border border-neutral-200 bg-neutral-50/80 px-4 py-3 text-sm text-neutral-700">
                                    <div class="font-semibold text-neutral-900">@VariantDisplayName(variant)</div>
                                    <div class="mt-1">@VariantAttributeText(variant)</div>
                                    <div class="mt-2 flex items-center justify-between gap-2">
                                        <span class="font-semibold text-neutral-900">@FormatPrice(GetVariantDisplayPrice(variant), VariantCurrencyCode(variant))</span>
                                        <span class="@(variant.Stock > 0 ? "text-emerald-700" : "text-rose-700")">@(variant.Stock > 0 ? $"{variant.Stock} in stock" : "Out of stock")</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div class="mt-8 flex flex-wrap gap-3">
                    @if (!string.IsNullOrWhiteSpace(_product.Category?.Slug) && !string.IsNullOrWhiteSpace(_product.Category?.Name))
                    {
                        <a href="@StorefrontRoutes.Category(_product.Category.Slug)" class="inline-flex items-center rounded bg-neutral-900 px-4 py-2 font-semibold text-white hover:bg-neutral-800">
                            Back to @_product.Category.Name
                        </a>
                    }

                    <a href="@StorefrontRoutes.NewReleases" class="inline-flex items-center rounded bg-amber-500 px-4 py-2 font-semibold text-white hover:bg-amber-600">
                        Browse New Releases
                    </a>

                    <a href="@StorefrontRoutes.TodaysDeals" class="inline-flex items-center rounded bg-white px-4 py-2 font-semibold text-neutral-900 ring-1 ring-black/5 hover:bg-neutral-100">
                        See Today's Deals
                    </a>
                </div>

                <div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm leading-6 text-amber-900">
                    Questions about sizing, delivery, or returns? Visit <a href="@StorefrontRoutes.CustomerService" class="font-semibold underline">Customer Service</a> before you place your order.
                </div>
                </div>
            </div>
        </ChildContent>
    </StorefrontPageShell>

    <SeoContentSection Title="@ProductSeoContentTitle"
                       Eyebrow="Product Details"
                       Content="@_product.SeoContent" />

    <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
        <div class="rounded-3xl border border-neutral-200/70 bg-white/90 p-8 shadow-lg">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Keep Exploring</p>

            @if (_relatedProducts.Count > 0)
            {
                <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-neutral-900">More from @_product.Category?.Name</h2>
                <div class="mt-8">
                    <ProductGrid Products="_relatedProducts" EmptyMessage="No additional related products are available right now." />
                </div>
            }
            else
            {
                <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-neutral-900">Keep browsing the public catalog</h2>
                <div class="mt-6 flex flex-wrap gap-3">
                    @if (!string.IsNullOrWhiteSpace(_product.Category?.Slug) && !string.IsNullOrWhiteSpace(_product.Category?.Name))
                    {
                        <a href="@StorefrontRoutes.Category(_product.Category.Slug)" class="inline-flex items-center rounded bg-neutral-900 px-4 py-2 font-semibold text-white hover:bg-neutral-800">
                            Explore @_product.Category.Name
                        </a>
                    }

                    <a href="@StorefrontRoutes.NewReleases" class="inline-flex items-center rounded bg-amber-500 px-4 py-2 font-semibold text-white hover:bg-amber-600">
                        Browse New Releases
                    </a>

                    <a href="@StorefrontRoutes.TodaysDeals" class="inline-flex items-center rounded bg-white px-4 py-2 font-semibold text-neutral-900 ring-1 ring-black/5 hover:bg-neutral-100">
                        See Today's Deals
                    </a>
                </div>
            }
        </div>
    </section>
}

@code {
    private SeoMetadataDto _metadata = new();
    private bool _isNotFound;
    private bool _isServiceUnavailable;
    private GetProduct? _product;
    private IReadOnlyList<StorefrontBreadcrumbItem> _breadcrumbs = [];
    private IReadOnlyList<ProductGalleryItem> _galleryItems = [];
    private ProductPurchasePanelModel _purchasePanel = ProductPurchasePanelModel.Empty;
    private IReadOnlyList<GetCatalogProduct> _relatedProducts = [];
    private StorefrontStructuredDataDocument _structuredData = StorefrontStructuredDataDocument.Empty;
    private StorefrontDisplayContext _displayContext = StorefrontDisplayContext.Fallback;

    private bool IsFreshArrival => _product is not null && DateTime.UtcNow.Subtract(_product.CreatedOn).TotalDays <= 7;

    private string PrimaryPriceLabel => _product?.Variants.Any() == true ? "From" : "Price";

    private bool HasComparePrice => DisplayComparePriceAmount is not null && DisplayComparePriceAmount > DisplayPriceAmount;

    private bool HasVariationTemplate => ActiveVariationOptions.Count > 0;

    private bool UsesVariantSelect => _product?.Variants.Any() == true && !HasVariationTemplate;

    private IReadOnlyList<StorefrontVariationOptionDto> ActiveVariationOptions =>
        _product?.VariationTemplate?.Options
            .Where(option => !string.IsNullOrWhiteSpace(option.Name))
            .Where(option => ActiveVariationValues(option).Count > 0)
            .ToArray()
        ?? [];

    private string VariantSummary => _product?.Variants.Any() == true
        ? string.Concat(_product.Variants.Count(), " options")
        : "Single option";

    private string CartUrl => StorefrontRoutes.Cart;

    private string PurchaseMessage => _product?.Variants.Any() == true
        ? "Choose a size, add it to your cart, and review it in the storefront cart before checkout."
        : _product?.Purchasable == true
            ? "Add this item now and review it in the storefront cart before checkout."
            : "This product cannot be added to cart right now.";

    private decimal DisplayPriceAmount => _product?.DisplayPrice ?? _product?.Price ?? 0m;

    private decimal? DisplayComparePriceAmount => _product?.DisplayComparePrice ?? _product?.ComparePrice;

    private string DisplayCurrencyCode => NormalizeCurrencyCode(_product?.DisplayCurrencyCode) ?? _displayContext.DefaultCurrencyCode;

    private string BaseUnitPriceValue => DisplayPriceAmount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);

    private string DisplayPrice => FormatPrice(DisplayPriceAmount, DisplayCurrencyCode);

    private string DefaultSkuLabel => !string.IsNullOrWhiteSpace(DefaultSelectionSku)
        ? $"SKU {DefaultSelectionSku}"
        : string.Empty;

    private string? DefaultSelectionSku => _product?.Variants.FirstOrDefault(variant => variant.IsDefault)?.Sku ?? _product?.Sku;

    private string ProductDescription => !string.IsNullOrWhiteSpace(_product?.FullDescription)
        ? _product.FullDescription!
        : _product?.Description ?? string.Empty;

    private string StockSummary => _product?.Variants.Any() == true
        ? $"{_product.Variants.Count(variant => variant.Stock > 0)} options in stock"
        : _product?.ManageStock == false
            ? "Available"
            : (_product?.Quantity ?? 0) > 0
            ? $"{_product!.Quantity} in stock"
            : "Out of stock";

    private string StockBadgeClass => StockSummary.StartsWith("Out", StringComparison.Ordinal)
        ? "inline-flex items-center rounded-full bg-rose-50 px-3 py-1 font-semibold text-rose-700"
        : "inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 font-semibold text-emerald-700";

    private bool CanSubmitInitialPurchase =>
        _product is not null
        && !_product.PurchaseBlockReasons.Any(IsInitialPurchaseHardBlock);

    private string AddToCartButtonClass => CanSubmitInitialPurchase
        ? "inline-flex items-center rounded bg-amber-500 px-4 py-2 font-semibold text-white hover:bg-amber-600"
        : "inline-flex cursor-not-allowed items-center rounded bg-neutral-300 px-4 py-2 font-semibold text-neutral-600 hover:bg-neutral-300";

    private static bool IsInitialPurchaseHardBlock(string reason) =>
        reason is "not_visible"
            or "not_published"
            or "not_started"
            or "expired"
            or "purchase_disabled"
            or "variant_inactive"
            or "out_of_stock"
            or "not_enough_stock"
            or "above_max_quantity";

    private int InitialStockValue => _product?.ManageStock == false ? 999999 : Math.Max(0, _product?.AvailableQuantity ?? _product?.Quantity ?? 0);

    private string PurchaseBlockMessage => _product?.PurchaseBlockReasons.FirstOrDefault() switch
    {
        "purchase_disabled" => "Purchasing is paused.",
        "out_of_stock" => "Currently out of stock.",
        "below_min_quantity" => $"Minimum order quantity is {_product?.MinOrderQuantity ?? 1}.",
        "above_max_quantity" => $"Maximum order quantity is {_product?.MaxOrderQuantity}.",
        _ => "Currently unavailable.",
    };

    private string ProductSeoContentTitle => _product?.Name is { Length: > 0 } productName
        ? $"More about {productName}"
        : string.Empty;

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        _displayContext = await DisplayContextProvider.GetAsync();

        var routePath = StorefrontRoutes.Product(Slug);
        var productResult = await ApiClient.GetPublishedProductBySlugAsync(Slug, _displayContext.CurrencyCode);

        if (productResult.IsServiceUnavailable)
        {
            _product = null;
            _isNotFound = false;
            _isServiceUnavailable = true;
            _breadcrumbs = [];
            _galleryItems = [];
            _purchasePanel = ProductPurchasePanelModel.Empty;
            _relatedProducts = [];
            _structuredData = StorefrontStructuredDataDocument.Empty;
            StorefrontResponseHeaders.ApplyServiceUnavailable(HttpContext);
            SeoRuntimeLogger.PublicProductServiceUnavailable(Logger, routePath, Slug);

            _metadata = await SeoComposer.ComposeServiceUnavailablePageAsync(
                "Product temporarily unavailable",
                routePath,
                "The storefront is running, but the catalog API is not reachable right now.");
            return;
        }

        _product = productResult.Value;

        if (_product is null)
        {
            _isNotFound = true;
            _isServiceUnavailable = false;
            _breadcrumbs = [];
            _galleryItems = [];
            _purchasePanel = ProductPurchasePanelModel.Empty;
            _relatedProducts = [];
            _structuredData = StorefrontStructuredDataDocument.Empty;
            StorefrontResponseHeaders.ApplyNotFound(HttpContext);
            SeoRuntimeLogger.PublicProductNotFound(Logger, routePath, Slug);

            _metadata = await SeoComposer.ComposeNotFoundPageAsync(
                "Product not found",
                routePath,
                "We couldn't find a published product for this address.");
            return;
        }

        _isNotFound = false;
        _isServiceUnavailable = false;
        SeoRuntimeLogger.PublicProductResolved(Logger, routePath, Slug, _product.Id);
        _breadcrumbs = BuildBreadcrumbs(_product);
        _galleryItems = BuildGalleryItems(_product);
        _purchasePanel = BuildPurchasePanel(_product);

        var metadataTask = SeoComposer.ComposeProductPageAsync(_product);
        var structuredDataTask = StructuredDataComposer.ComposeProductPageAsync(_product);
        var relatedProductsTask = GetRelatedProductsAsync(_product);

        await Task.WhenAll(metadataTask, structuredDataTask, relatedProductsTask);

        _metadata = await metadataTask;
        _structuredData = await structuredDataTask;
        _relatedProducts = await relatedProductsTask;
    }

    private static IReadOnlyList<StorefrontBreadcrumbItem> BuildBreadcrumbs(GetProduct product)
    {
        var breadcrumbs = new List<StorefrontBreadcrumbItem>
        {
            new("Home", StorefrontRoutes.Home),
        };

        if (!string.IsNullOrWhiteSpace(product.Category?.Slug) && !string.IsNullOrWhiteSpace(product.Category?.Name))
        {
            breadcrumbs.Add(new StorefrontBreadcrumbItem(product.Category.Name, StorefrontRoutes.Category(product.Category.Slug)));
        }

        breadcrumbs.Add(new StorefrontBreadcrumbItem(product.Name ?? "Product"));

        return breadcrumbs;
    }

    private static IReadOnlyList<ProductGalleryItem> BuildGalleryItems(GetProduct product)
    {
        var gallery = product.MediaGallery
            .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
            .Select(item => new ProductGalleryItem(
                item.ImageUrl!,
                string.IsNullOrWhiteSpace(item.ThumbnailUrl) ? item.ImageUrl! : item.ThumbnailUrl!,
                ResolveGalleryAltText(item.AltText, product.Name)))
            .ToArray();

        if (gallery.Length > 0)
        {
            return gallery;
        }

        return string.IsNullOrWhiteSpace(product.Image)
            ? []
            :
            [
                new ProductGalleryItem(
                    product.Image!,
                    product.Image!,
                    ResolveGalleryAltText(null, product.Name)),
            ];
    }

    private static string ResolveGalleryAltText(string? altText, string? productName)
    {
        if (!string.IsNullOrWhiteSpace(altText))
        {
            return altText.Trim();
        }

        return string.IsNullOrWhiteSpace(productName) ? "Product image" : productName.Trim();
    }

    private ProductPurchasePanelModel BuildPurchasePanel(GetProduct product)
    {
        return new ProductPurchasePanelModel(
            product.Id,
            string.IsNullOrWhiteSpace(product.Name) ? "Product" : product.Name,
            DisplayCurrencyCode,
            BaseUnitPriceValue,
            InitialStockValue,
            product.MinOrderQuantity,
            product.MaxOrderQuantity,
            product.QuantityStep,
            product.FreeShipping,
            product.DeliveryEstimateText,
            CanSubmitInitialPurchase,
            PurchaseMessage,
            PurchaseBlockMessage,
            ActiveVariationOptions
                .Select(option => new ProductPurchaseOptionItem(
                    option.Name!,
                    option.IsRequired,
                    option.ControlType,
                    ActiveVariationValues(option)
                        .Select(value => new ProductPurchaseOptionValueItem(value.Value!, value.ColorHex))
                        .ToArray()))
                .ToArray(),
            product.Variants
                .Select(variant => new ProductPurchaseVariantItem(
                    variant.Id,
                    VariantDisplayName(variant),
                    VariantAttributeText(variant),
                    VariantOptionLabel(variant),
                    variant.SizeValue,
                    variant.Sku,
                    variant.Stock,
                    variant.IsDefault,
                    VariantPriceValue(variant),
                    VariantCurrencyCode(variant),
                    FormatPrice(GetVariantDisplayPrice(variant), VariantCurrencyCode(variant))))
                .ToArray(),
            CartUrl);
    }

    private async Task<IReadOnlyList<GetCatalogProduct>> GetRelatedProductsAsync(GetProduct product)
    {
        if (string.IsNullOrWhiteSpace(product.Category?.Slug))
        {
            return [];
        }

        var categoryPageResult = await ApiClient.GetPublishedCategoryBySlugAsync(product.Category.Slug, _displayContext.CurrencyCode);
        if (!categoryPageResult.IsSuccess || categoryPageResult.Value is null)
        {
            return [];
        }

        return categoryPageResult.Value.Products
            .Where(relatedProduct => relatedProduct.Id != product.Id)
            .Where(relatedProduct => !string.IsNullOrWhiteSpace(relatedProduct.Slug))
            .Take(3)
            .ToArray();
    }

    private static string ScaleLabel(int scale)
    {
        return scale switch
        {
            1 => "Clothing",
            2 => "Clothing EU",
            10 => "Shoes EU",
            11 => "Shoes US",
            12 => "Shoes UK",
            _ => "Variant",
        };
    }

    private string VariantPriceValue(GetProductVariant variant)
    {
        return GetVariantDisplayPrice(variant).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    }

    private string VariantOptionLabel(GetProductVariant variant)
    {
        var defaultLabel = variant.IsDefault ? " • Default" : string.Empty;
        var stockLabel = variant.Stock > 0 ? $"{variant.Stock} left" : "Out of stock";
        return $"{VariantDisplayName(variant)} • {FormatPrice(GetVariantDisplayPrice(variant), VariantCurrencyCode(variant))} • {stockLabel}{defaultLabel}";
    }

    private decimal GetVariantPrice(GetProductVariant variant)
    {
        return variant.EffectivePrice > 0 ? variant.EffectivePrice : variant.Price ?? _product?.Price ?? 0m;
    }

    private decimal GetVariantDisplayPrice(GetProductVariant variant)
    {
        return variant.DisplayPrice ?? GetVariantPrice(variant);
    }

    private string VariantCurrencyCode(GetProductVariant variant)
    {
        return NormalizeCurrencyCode(variant.DisplayCurrencyCode) ?? DisplayCurrencyCode;
    }

    private string FormatPrice(decimal amount, string currencyCode) => PriceFormatter.Format(amount, _displayContext with { CurrencyCode = currencyCode });

    private static string? NormalizeCurrencyCode(string? currencyCode)
    {
        var normalized = currencyCode?.Trim().ToUpperInvariant();
        return normalized is { Length: 3 } && normalized.All(char.IsLetter)
            ? normalized
            : null;
    }

    private static IReadOnlyList<StorefrontVariationValueDto> ActiveVariationValues(StorefrontVariationOptionDto option)
    {
        return option.Values
            .Where(value => !string.IsNullOrWhiteSpace(value.Value))
            .ToArray();
    }

    private static bool IsRadioControl(StorefrontVariationOptionDto option)
    {
        return string.Equals(option.ControlType, "radio", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsColorControl(StorefrontVariationOptionDto option)
    {
        return string.Equals(option.ControlType, "color", StringComparison.OrdinalIgnoreCase);
    }

    private static bool ShouldSelectOptionValue(StorefrontVariationOptionDto option, StorefrontVariationValueDto value)
    {
        var values = ActiveVariationValues(option);
        return option.IsRequired
            && values.Count > 0
            && string.Equals(values[0].Value, value.Value, StringComparison.Ordinal);
    }

    private static string OptionInputId(StorefrontVariationOptionDto option)
    {
        return $"product-option-{SanitizeDomToken(option.Name)}";
    }

    private static string OptionInputName(StorefrontVariationOptionDto option)
    {
        return $"product_option_{SanitizeDomToken(option.Name)}";
    }

    private static string OptionValueInputId(StorefrontVariationOptionDto option, StorefrontVariationValueDto value)
    {
        return $"{OptionInputId(option)}-{SanitizeDomToken(value.Value)}";
    }

    private static string ColorSwatchStyle(StorefrontVariationValueDto value)
    {
        return !string.IsNullOrWhiteSpace(value.ColorHex)
            ? $"background-color: {value.ColorHex};"
            : "background-color: #f5f5f5;";
    }

    private static string SanitizeDomToken(string? value)
    {
        var raw = string.IsNullOrWhiteSpace(value) ? "option" : value.Trim().ToLowerInvariant();
        var chars = raw.Select(character => char.IsLetterOrDigit(character) ? character : '-').ToArray();
        var token = new string(chars).Trim('-');
        return string.IsNullOrWhiteSpace(token) ? "option" : token;
    }

    private static string VariantDisplayName(GetProductVariant variant)
    {
        if (!string.IsNullOrWhiteSpace(variant.DisplayName))
        {
            return variant.DisplayName;
        }

        var attributeText = VariantAttributeText(variant);
        return string.IsNullOrWhiteSpace(attributeText) ? variant.SizeValue : attributeText;
    }

    private static string VariantAttributeText(GetProductVariant variant)
    {
        var attributeText = string.Join(" / ", variant.Attributes.Select(attribute => $"{attribute.Name}: {attribute.Value}"));
        return string.IsNullOrWhiteSpace(attributeText)
            ? ScaleLabel(variant.SizeScale)
            : attributeText;
    }
}

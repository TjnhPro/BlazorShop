@page "/new-releases"
@inject IStorefrontCatalogClient ApiClient
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontStructuredDataComposer StructuredDataComposer
@inject IStorefrontDisplayContextProvider DisplayContextProvider
@inject IStorefrontPriceFormatter PriceFormatter

<SeoHead Metadata="_metadata" StructuredData="_structuredData" />

<section class="mx-auto max-w-7xl px-4 pb-6 pt-10 sm:px-6 lg:px-8">
    <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">New Releases</p>
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-neutral-900">Fresh Arrivals This Week</h1>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-neutral-700">Hand-picked products and newly published items across the BlazorShop catalog.</p>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a href="@StorefrontRoutes.TodaysDeals" class="inline-flex items-center rounded bg-amber-500 px-4 py-2 font-semibold text-white hover:bg-amber-600">Today's Deals</a>
            <a href="@StorefrontRoutes.Home" class="inline-flex items-center rounded bg-neutral-900 px-4 py-2 font-semibold text-white hover:bg-neutral-800">Back to Home</a>
        </div>
    </div>
</section>

<section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    @if (_isServiceUnavailable)
    {
        <ServiceUnavailableState Title="New releases are temporarily unavailable"
                                 Message="The storefront is running, but the catalog API is not reachable right now. Start the API project or AppHost and refresh this page." />
    }
    else
    {
        <div class="mb-6">
            <h2 class="text-2xl font-extrabold tracking-tight text-neutral-900">Latest Products</h2>
        </div>

        <ProductSummaryGrid Items="_productSummaries" EmptyMessage="No new releases have been published yet." />
    }
</section>

@code {
    private bool _isServiceUnavailable;
    private IReadOnlyList<GetCatalogProduct> _products = [];
    private IReadOnlyList<ProductSummaryItem> _productSummaries = [];
    private SeoMetadataDto _metadata = new();
    private StorefrontStructuredDataDocument _structuredData = StorefrontStructuredDataDocument.Empty;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var displayContext = await DisplayContextProvider.GetAsync();
        var metadataTask = SeoComposer.ComposeStaticPageAsync(
            "New Releases",
            StorefrontRoutes.NewReleases,
            "Browse newly published BlazorShop products on stable route-based pages.");
        var structuredDataTask = StructuredDataComposer.ComposeCollectionPageAsync(
            "New Releases",
            StorefrontRoutes.NewReleases,
            "Browse newly published BlazorShop products on stable route-based pages.");
        var result = await ApiClient.GetPublishedCatalogPageAsync(new ProductCatalogQuery
        {
            PageNumber = 1,
            PageSize = 24,
            SortBy = ProductCatalogSortBy.Newest,
            CreatedAfterUtc = DateTime.UtcNow.AddDays(-7),
        }, displayContext.CurrencyCode);

        _metadata = await metadataTask;

        if (result.IsServiceUnavailable)
        {
            _isServiceUnavailable = true;
            _products = [];
            _productSummaries = [];
            _structuredData = StorefrontStructuredDataDocument.Empty;
            StorefrontResponseHeaders.ApplyServiceUnavailable(HttpContext);
            _metadata = await SeoComposer.ComposeServiceUnavailablePageAsync(
                "New releases are temporarily unavailable",
                StorefrontRoutes.NewReleases,
                "The storefront is running, but the catalog API is not reachable right now.");

            return;
        }

        _isServiceUnavailable = false;
        _products = result.Value?.Items ?? [];
        _productSummaries = _products.Select(product => StorefrontProductSummaryMapper.ToProductSummary(product, displayContext, PriceFormatter)).ToArray();
        _structuredData = await structuredDataTask;
    }

}

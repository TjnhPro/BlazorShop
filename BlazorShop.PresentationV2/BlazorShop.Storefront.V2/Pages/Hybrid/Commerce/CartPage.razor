@page "/my-cart"

<PageTitle>My Cart</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<StorefrontCartView InitialCart="_cart"
                    InitialAlerts="_alerts"
                    DataMode="StorefrontFeatureDataMode.InitialSnapshot"
                    CheckoutUrl="@StorefrontRoutes.Checkout"
                    NewReleasesUrl="@StorefrontRoutes.NewReleases"
                    TodaysDealsUrl="@StorefrontRoutes.TodaysDeals"
                    @rendermode="InteractiveWebAssembly" />

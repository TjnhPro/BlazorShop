@page "/account"
@page "/account/profile"
@using Microsoft.AspNetCore.Antiforgery
@inject IStorefrontSessionResolver SessionResolver
@inject IStorefrontCustomerClient ApiClient
@inject NavigationManager NavigationManager
@inject IAntiforgery Antiforgery

<PageTitle>Account profile</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<AccountPageShell Title="Profile" ActiveRoute="@StorefrontRoutes.AccountProfile">
    @if (_loading)
    {
        <p class="text-sm text-neutral-600">Loading profile...</p>
    }
    else
    {
        <AccountProfileEditor
            InitialProfile="_profile"
            InitialError="@ErrorMessage"
            InitialSuccess="@SuccessMessage"
            FormAction="@StorefrontRoutes.AccountProfile"
            AntiforgeryFieldName="_antiforgeryFieldName"
            AntiforgeryRequestToken="_antiforgeryRequestToken"
            @rendermode="InteractiveWebAssembly" />
    }
</AccountPageShell>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "saved")]
    public string? Saved { get; set; }

    private bool _loading = true;
    private StorefrontBrowserCustomerProfile? _profile;
    private string? _antiforgeryFieldName;
    private string? _antiforgeryRequestToken;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? ErrorMessage => this.Error;

    private string? SuccessMessage => this.Saved == "1" ? "Profile updated." : null;

    protected override async Task OnInitializedAsync()
    {
        var tokens = HttpContext is null ? null : Antiforgery.GetAndStoreTokens(HttpContext);
        _antiforgeryFieldName = tokens?.FormFieldName;
        _antiforgeryRequestToken = tokens?.RequestToken;

        var session = await SessionResolver.GetCurrentUserAsync();
        if (!session.IsAuthenticated || string.IsNullOrWhiteSpace(session.AccessToken))
        {
            NavigationManager.NavigateTo(StorefrontReturnUrl.BuildSignInUrl(StorefrontRoutes.AccountProfile), replace: true);
            return;
        }

        var result = await ApiClient.GetCustomerProfileAsync(session.AccessToken);
        _profile = result.Success && result.Data is not null ? ToBrowserProfile(result.Data) : null;
        _loading = false;
    }

    private static StorefrontBrowserCustomerProfile ToBrowserProfile(StorefrontCustomerProfileResponse profile)
    {
        return new StorefrontBrowserCustomerProfile(
            profile.CustomerPublicId,
            profile.Email,
            profile.FullName,
            profile.FirstName,
            profile.LastName,
            profile.Company,
            profile.PhoneNumber,
            profile.PreferredLanguage,
            profile.PreferredCurrencyCode,
            profile.CreatedAtUtc.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture),
            profile.LastActivityAtUtc?.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture));
    }
}

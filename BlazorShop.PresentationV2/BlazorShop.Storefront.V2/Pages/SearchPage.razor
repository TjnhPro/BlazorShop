@page "/search"
@using BlazorShop.Application.DTOs.Category
@inject StorefrontApiClient ApiClient
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontDisplayContextProvider DisplayContextProvider

<SeoHead Metadata="_metadata" />

<section class="mx-auto max-w-7xl px-4 pb-6 pt-10 sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-neutral-200/70 bg-white/90 p-6 shadow-lg">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Search</p>
                <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-neutral-900">@TitleText</h1>
                <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-700">@ScopeText</p>
            </div>

            <form method="get" action="@StorefrontRoutes.Search" class="grid gap-3 md:grid-cols-[minmax(10rem,14rem)_minmax(16rem,1fr)_auto]">
                <select name="category" class="rounded border border-neutral-300 bg-white px-3 py-3 text-sm font-semibold text-neutral-900">
                    <option value="">All</option>
                    @foreach (var category in _searchCategories)
                    {
                        <option value="@category.Slug" selected="@IsSelectedCategory(category.Slug)">@category.Label</option>
                    }
                </select>
                <input name="q" value="@Q" type="search" placeholder="Search products" class="rounded border border-neutral-300 bg-white px-4 py-3 text-sm text-neutral-900" />
                <button type="submit" class="inline-flex items-center justify-center gap-2 rounded bg-amber-500 px-4 py-3 text-sm font-semibold text-white hover:bg-amber-600">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    Search
                </button>
            </form>
        </div>
    </div>
</section>

<section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
    @if (_isServiceUnavailable)
    {
        <ServiceUnavailableState Title="Search temporarily unavailable"
                                 Message="The storefront is running, but the catalog API is not reachable right now. Start the API project or AppHost and refresh this page." />
    }
    else
    {
        <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h2 class="text-2xl font-extrabold tracking-tight text-neutral-900">Results</h2>
            <span class="inline-flex items-center rounded-full bg-white/80 px-4 py-2 text-sm font-semibold text-neutral-700 shadow">@ResultCountText</span>
        </div>

        <ProductGrid Products="_products" EmptyMessage="No products found" />

        @if (_totalPages > 1)
        {
            <nav class="mt-8 flex flex-wrap items-center justify-center gap-2" aria-label="Search result pages">
                @for (var pageNumber = 1; pageNumber <= _totalPages; pageNumber++)
                {
                    <a href="@StorefrontRoutes.SearchUrl(Q, Category, pageNumber)"
                       class="@GetPageLinkClass(pageNumber)"
                       aria-current="@(pageNumber == _pageNumber ? "page" : null)">
                        @pageNumber
                    </a>
                }
            </nav>
        }
    }
</section>

@code {
    private bool _isServiceUnavailable;
    private int _pageNumber = 1;
    private int _totalPages;
    private IReadOnlyList<GetCatalogProduct> _products = [];
    private IReadOnlyList<SearchCategoryOption> _searchCategories = [];
    private SeoMetadataDto _metadata = new();

    [SupplyParameterFromQuery(Name = "q")]
    public string? Q { get; set; }

    [SupplyParameterFromQuery(Name = "category")]
    public string? Category { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int Page { get; set; } = 1;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string TitleText => string.IsNullOrWhiteSpace(Q)
        ? "Browse products"
        : $"Search results for \"{Q.Trim()}\"";

    private string ScopeText => string.IsNullOrWhiteSpace(Category)
        ? "Showing published products across the store."
        : $"Showing published products in {Category.Trim()}.";

    private string ResultCountText => _products.Count == 1 ? "1 item" : $"{_products.Count} items";

    protected override async Task OnParametersSetAsync()
    {
        var displayContext = await DisplayContextProvider.GetAsync();
        var metadataTask = SeoComposer.ComposeStaticPageAsync(
            "Search",
            StorefrontRoutes.Search,
            "Search published products in the BlazorShop catalog.");
        var categoriesTask = ApiClient.GetPublishedCategoryTreeAsync();
        var productsTask = ApiClient.GetPublishedCatalogPageAsync(new ProductCatalogQuery
        {
            PageNumber = Math.Max(1, Page),
            PageSize = 24,
            CategorySlug = Category,
            SearchTerm = Q,
            SortBy = ProductCatalogSortBy.DisplayOrder,
        }, displayContext.CurrencyCode);

        _metadata = await metadataTask;
        _metadata.RobotsIndex = false;
        _metadata.RobotsFollow = true;
        _metadata.CanonicalUrl = null;

        var categories = await categoriesTask;
        _searchCategories = categories.IsSuccess && categories.Value is not null
            ? FlattenCategories(categories.Value)
            : [];

        var products = await productsTask;
        if (products.IsServiceUnavailable)
        {
            _isServiceUnavailable = true;
            _products = [];
            _pageNumber = 1;
            _totalPages = 0;
            StorefrontResponseHeaders.ApplyServiceUnavailable(HttpContext);
            _metadata = await SeoComposer.ComposeServiceUnavailablePageAsync(
                "Search temporarily unavailable",
                StorefrontRoutes.Search,
                "The storefront is running, but the catalog API is not reachable right now.");
            return;
        }

        _isServiceUnavailable = false;
        _products = products.Value?.Items ?? [];
        _pageNumber = products.Value?.PageNumber ?? Math.Max(1, Page);
        _totalPages = Math.Min(10, products.Value?.TotalPages ?? 0);
    }

    private bool IsSelectedCategory(string slug)
    {
        return string.Equals(slug, Category?.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private string GetPageLinkClass(int page)
    {
        var baseClass = "inline-flex min-h-10 min-w-10 items-center justify-center rounded border px-3 text-sm font-semibold";
        return page == _pageNumber
            ? $"{baseClass} border-neutral-900 bg-neutral-900 text-white"
            : $"{baseClass} border-neutral-200 bg-white text-neutral-900 hover:bg-neutral-100";
    }

    private static IReadOnlyList<SearchCategoryOption> FlattenCategories(IReadOnlyList<GetCategoryTreeNode> categories)
    {
        var options = new List<SearchCategoryOption>();

        foreach (var category in categories)
        {
            AppendCategory(options, category, 0);
        }

        return options;
    }

    private static void AppendCategory(List<SearchCategoryOption> options, GetCategoryTreeNode category, int depth)
    {
        if (!string.IsNullOrWhiteSpace(category.Slug))
        {
            var prefix = depth <= 0 ? string.Empty : $"{new string('-', depth * 2)} ";
            options.Add(new SearchCategoryOption(category.Slug, $"{prefix}{category.Name}"));
        }

        foreach (var child in category.Children)
        {
            AppendCategory(options, child, depth + 1);
        }
    }

    private sealed record SearchCategoryOption(string Slug, string Label);
}

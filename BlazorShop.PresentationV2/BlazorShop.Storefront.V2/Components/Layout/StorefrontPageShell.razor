@namespace BlazorShop.Storefront.Components.Layout

<div class="@ShellClass">
    @if (Breadcrumb is not null)
    {
        <div class="bs-storefront-page-shell__breadcrumb">
            @Breadcrumb
        </div>
    }

    @if (Header is not null || Actions is not null)
    {
        <header class="bs-storefront-page-shell__header">
            @if (Header is not null)
            {
                <div class="bs-storefront-page-shell__heading">
                    @Header
                </div>
            }

            @if (Actions is not null)
            {
                <div class="bs-storefront-page-shell__actions">
                    @Actions
                </div>
            }
        </header>
    }

    @if (Sidebar is not null)
    {
        <div class="bs-storefront-page-shell__layout">
            <aside class="bs-storefront-page-shell__sidebar">
                @Sidebar
            </aside>

            <div class="bs-storefront-page-shell__content">
                @ChildContent
            </div>
        </div>
    }
    else
    {
        <div class="bs-storefront-page-shell__content">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter]
    public RenderFragment? Breadcrumb { get; set; }

    [Parameter]
    public RenderFragment? Header { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? Sidebar { get; set; }

    [Parameter]
    [EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter]
    public string? Class { get; set; }

    private string ShellClass => string.IsNullOrWhiteSpace(Class)
        ? "bs-storefront-page-shell"
        : $"bs-storefront-page-shell {Class}";
}

@inject StorefrontApiClient ApiClient
@inject IStorefrontDisplayContextProvider DisplayContextProvider
@inject IStorefrontPageNavigationProvider PageNavigationProvider
@using BlazorShop.Application.DTOs.Category

<header class="bs-storefront-header relative text-neutral-100">
    <div class="bs-storefront-header__shell">
        <div class="bs-storefront-header__desktop relative mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
            <a href="@StorefrontRoutes.Home" class="bs-storefront-header__brand" aria-label="@BrandHomeLabel">
                @if (!string.IsNullOrWhiteSpace(BrandLogoUrl))
                {
                    <img class="bs-storefront-header__brand-logo" src="@BrandLogoUrl" alt="" loading="eager" decoding="async" />
                }
                <span class="bs-storefront-header__brand-mark">@BrandName</span>
                <span class="bs-storefront-header__brand-label">@BrandLabel</span>
            </a>

            <form method="get" action="@StorefrontRoutes.Search" class="bs-storefront-search" role="search">
                <select name="category" class="bs-storefront-search__select" aria-label="Search category">
                    <option value="">All</option>
                    @foreach (var category in _searchCategories)
                    {
                        <option value="@category.Slug">@category.Label</option>
                    }
                </select>
                <input name="q" class="bs-storefront-search__input" type="search" placeholder="Search products" aria-label="Search products" autocomplete="off" />
                <button type="submit" class="bs-storefront-search__button" aria-label="Search">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    <span class="bs-storefront-search__button-text">Search</span>
                </button>
            </form>

            <nav class="bs-storefront-header__desktop-nav flex flex-wrap items-center gap-2 text-sm font-medium lg:justify-center" aria-label="Primary shop navigation">
                <NavLink href="@StorefrontRoutes.Home" Match="NavLinkMatch.All" class="bs-storefront-nav-link" ActiveClass="is-active">Home</NavLink>
                <NavLink href="@StorefrontRoutes.NewReleases" class="bs-storefront-nav-link" ActiveClass="is-active">New Releases</NavLink>
                <NavLink href="@StorefrontRoutes.TodaysDeals" class="bs-storefront-nav-link" ActiveClass="is-active">Today's Deals</NavLink>
                @foreach (var link in headerLinks)
                {
                    <NavLink href="@PageHref(link)" class="bs-storefront-nav-link" ActiveClass="is-active">@link.Title</NavLink>
                }
            </nav>

            <div class="bs-storefront-header__desktop-actions flex shrink-0 flex-wrap items-center gap-3 text-sm" aria-label="Shop actions">
                @if (ShowCurrencySelector)
                {
                    <form method="post" action="@StorefrontRoutes.CurrencyPreference" class="bs-storefront-currency-form">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
                        <select name="CurrencyCode" class="bs-storefront-currency-select" aria-label="Currency">
                            @foreach (var currencyCode in _displayContext.SupportedCurrencyCodes)
                            {
                                <option value="@currencyCode" selected="@IsSelectedCurrency(currencyCode)">@currencyCode</option>
                            }
                        </select>
                        <button type="submit" class="bs-storefront-currency-submit" aria-label="Apply currency" title="Apply currency">
                            <i class="fa-solid fa-check" aria-hidden="true"></i>
                        </button>
                    </form>
                }
                <a href="@StorefrontRoutes.Cart"
                   class="bs-storefront-icon-button"
                   aria-label="Open cart"
                   title="Open cart">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 6h15l-1.5 9h-12z" />
                        <path d="M6 6 5 3H3" />
                        <circle cx="9" cy="20" r="1" />
                        <circle cx="18" cy="20" r="1" />
                    </svg>
                    <span data-storefront-cart-badge hidden class="bs-storefront-cart-badge">0</span>
                </a>
                <StorefrontAccountMenu />
                <a href="@StorefrontRoutes.NewReleases" class="bs-storefront-pill-button">New Releases</a>
                <a href="@StorefrontRoutes.TodaysDeals" class="bs-storefront-deal-button">Today's Deals</a>
            </div>
        </div>

        <div class="bs-storefront-header__mobile relative mx-auto max-w-7xl px-4 py-3 sm:px-6">
            <a href="@StorefrontRoutes.Home" class="bs-storefront-header__brand" aria-label="@BrandHomeLabel">
                @if (!string.IsNullOrWhiteSpace(BrandLogoUrl))
                {
                    <img class="bs-storefront-header__brand-logo" src="@BrandLogoUrl" alt="" loading="eager" decoding="async" />
                }
                <span class="bs-storefront-header__brand-mark">@BrandName</span>
                <span class="bs-storefront-header__brand-label">@BrandLabel</span>
            </a>

            <div class="bs-storefront-header__mobile-actions" aria-label="Shop shortcuts">
                <a href="@StorefrontRoutes.Cart"
                   class="bs-storefront-icon-button"
                   aria-label="Open cart"
                   title="Open cart">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 6h15l-1.5 9h-12z" />
                        <path d="M6 6 5 3H3" />
                        <circle cx="9" cy="20" r="1" />
                        <circle cx="18" cy="20" r="1" />
                    </svg>
                    <span data-storefront-cart-badge hidden class="bs-storefront-cart-badge">0</span>
                </a>
                <StorefrontAccountMenu />
            </div>

            <form method="get" action="@StorefrontRoutes.Search" class="bs-storefront-search bs-storefront-search--mobile" role="search">
                <select name="category" class="bs-storefront-search__select" aria-label="Search category">
                    <option value="">All</option>
                    @foreach (var category in _searchCategories)
                    {
                        <option value="@category.Slug">@category.Label</option>
                    }
                </select>
                <input name="q" class="bs-storefront-search__input" type="search" placeholder="Search products" aria-label="Search products" autocomplete="off" />
                <button type="submit" class="bs-storefront-search__button" aria-label="Search">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    <span class="bs-storefront-search__button-text">Search</span>
                </button>
            </form>

            <details class="bs-storefront-header__menu">
                <summary class="bs-storefront-menu-button" aria-label="Open shop navigation">
                    <span class="bs-storefront-menu-button__text">Menu</span>
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 7h16M4 12h16M4 17h16" />
                    </svg>
                </summary>

                <div class="bs-storefront-header__mobile-panel">
                    <nav class="bs-storefront-header__mobile-nav" aria-label="Mobile shop navigation">
                        <NavLink href="@StorefrontRoutes.Home" Match="NavLinkMatch.All" class="bs-storefront-nav-link" ActiveClass="is-active">Home</NavLink>
                        <NavLink href="@StorefrontRoutes.NewReleases" class="bs-storefront-nav-link" ActiveClass="is-active">New Releases</NavLink>
                        <NavLink href="@StorefrontRoutes.TodaysDeals" class="bs-storefront-nav-link" ActiveClass="is-active">Today's Deals</NavLink>
                        @foreach (var link in headerLinks)
                        {
                            <NavLink href="@PageHref(link)" class="bs-storefront-nav-link" ActiveClass="is-active">@link.Title</NavLink>
                        }
                    </nav>

                    <div class="bs-storefront-header__mobile-panel-actions">
                        @if (ShowCurrencySelector)
                        {
                            <form method="post" action="@StorefrontRoutes.CurrencyPreference" class="bs-storefront-currency-form bs-storefront-currency-form--mobile">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
                                <select name="CurrencyCode" class="bs-storefront-currency-select" aria-label="Currency">
                                    @foreach (var currencyCode in _displayContext.SupportedCurrencyCodes)
                                    {
                                        <option value="@currencyCode" selected="@IsSelectedCurrency(currencyCode)">@currencyCode</option>
                                    }
                                </select>
                                <button type="submit" class="bs-storefront-currency-submit" aria-label="Apply currency" title="Apply currency">
                                    <i class="fa-solid fa-check" aria-hidden="true"></i>
                                </button>
                            </form>
                        }
                        <a href="@StorefrontRoutes.NewReleases" class="bs-storefront-pill-button">New Releases</a>
                        <a href="@StorefrontRoutes.TodaysDeals" class="bs-storefront-deal-button">Today's Deals</a>
                    </div>
                </div>
            </details>
        </div>
    </div>
</header>

@code {
    private const string DefaultBrandName = "BLAZORSHOP";
    private const string DefaultBrandLabel = "PUBLIC SHOP";

    private string BrandName { get; set; } = DefaultBrandName;

    private string BrandLabel { get; set; } = DefaultBrandLabel;

    private string? BrandLogoUrl { get; set; }

    private StorefrontDisplayContext _displayContext = StorefrontDisplayContext.Fallback;

    private string BrandHomeLabel => $"{BrandName} shop home";

    private bool ShowCurrencySelector => _displayContext.SupportedCurrencyCodes.Count > 1;

    private string ReturnUrl => HttpContext is null
        ? StorefrontRoutes.Home
        : $"{HttpContext.Request.PathBase}{HttpContext.Request.Path}{HttpContext.Request.QueryString}";

    private IReadOnlyList<SearchCategoryOption> _searchCategories = [];
    private IReadOnlyList<StorefrontPageNavigationLinkDto> headerLinks = [];

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _displayContext = await DisplayContextProvider.GetAsync();
        BrandName = _displayContext.StoreName;
        BrandLabel = string.IsNullOrWhiteSpace(_displayContext.CompanyName)
            ? _displayContext.StoreKey.ToUpperInvariant()
            : _displayContext.CompanyName;
        BrandLogoUrl = _displayContext.LogoUrl;

        var categories = await ApiClient.GetPublishedCategoryTreeAsync();
        if (categories.IsSuccess && categories.Value is not null)
        {
            _searchCategories = FlattenCategories(categories.Value);
        }

        headerLinks = await PageNavigationProvider.GetLinksByLocationAsync(StorefrontPageContentRules.Header);
    }

    private static string PageHref(StorefrontPageNavigationLinkDto link)
    {
        return StorefrontRoutes.Page(link.Slug);
    }

    private static IReadOnlyList<SearchCategoryOption> FlattenCategories(IReadOnlyList<GetCategoryTreeNode> categories)
    {
        var options = new List<SearchCategoryOption>();

        foreach (var category in categories)
        {
            AppendCategory(options, category, 0);
        }

        return options;
    }

    private static void AppendCategory(List<SearchCategoryOption> options, GetCategoryTreeNode category, int depth)
    {
        if (!string.IsNullOrWhiteSpace(category.Slug))
        {
            var prefix = depth <= 0 ? string.Empty : $"{new string('-', depth * 2)} ";
            options.Add(new SearchCategoryOption(category.Slug, $"{prefix}{category.Name}"));
        }

        foreach (var child in category.Children)
        {
            AppendCategory(options, child, depth + 1);
        }
    }

    private bool IsSelectedCurrency(string currencyCode)
    {
        return string.Equals(currencyCode, _displayContext.CurrencyCode, StringComparison.Ordinal);
    }

    private sealed record SearchCategoryOption(string Slug, string Label);
}

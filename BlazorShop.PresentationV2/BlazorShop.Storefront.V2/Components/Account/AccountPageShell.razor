<section class="mx-auto max-w-7xl px-4 pb-12 pt-10 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[220px_minmax(0,1fr)] lg:items-start">
        <nav class="rounded border border-neutral-200 bg-white p-4 text-sm" aria-label="Account navigation">
            <a class="@LinkClass(StorefrontRoutes.AccountProfile)" href="@StorefrontRoutes.AccountProfile">Profile</a>
            <a class="@LinkClass(StorefrontRoutes.AccountOrders)" href="@StorefrontRoutes.AccountOrders">Orders</a>
            <a class="@LinkClass(StorefrontRoutes.AccountAddresses)" href="@StorefrontRoutes.AccountAddresses">Addresses</a>
            <a class="@LinkClass(StorefrontRoutes.AccountChangePassword)" href="@StorefrontRoutes.AccountChangePassword">Password</a>
        </nav>

        <article class="rounded border border-neutral-200 bg-white">
            <header class="border-b border-neutral-200 px-6 py-6">
                <p class="text-sm font-semibold uppercase text-neutral-500">@Eyebrow</p>
                <h1 class="mt-2 text-3xl font-extrabold text-neutral-900">@Title</h1>
            </header>

            <div class="px-6 py-6">
                @ChildContent
            </div>
        </article>
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Eyebrow { get; set; } = "Customer account";

    [Parameter]
    public string ActiveRoute { get; set; } = StorefrontRoutes.AccountProfile;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string LinkClass(string route)
    {
        var active = string.Equals(route, ActiveRoute, StringComparison.OrdinalIgnoreCase);
        return active
            ? "mt-2 block rounded bg-neutral-900 px-3 py-2 font-semibold text-white first:mt-0"
            : "mt-2 block rounded px-3 py-2 font-semibold text-neutral-700 hover:bg-neutral-100 first:mt-0";
    }
}

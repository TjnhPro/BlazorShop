@inject IStorefrontDisplayContextProvider DisplayContextProvider
@inject IStorefrontPriceFormatter PriceFormatter

<article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-neutral-200/70 bg-white/95 shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
    <div class="p-6">
        <div class="flex items-start justify-between gap-3">
            <div>
                @if (!string.IsNullOrWhiteSpace(Product.CategoryName))
                {
                    if (!string.IsNullOrWhiteSpace(Product.CategorySlug))
                    {
                        <a href="@StorefrontRoutes.Category(Product.CategorySlug)" class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 hover:text-neutral-900">@Product.CategoryName</a>
                    }
                    else
                    {
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">@Product.CategoryName</span>
                    }
                }

                @if (!string.IsNullOrWhiteSpace(Product.Slug))
                {
                    <a href="@StorefrontRoutes.Product(Product.Slug)" class="block">
                        <h2 class="mt-2 text-lg font-extrabold text-neutral-900 transition-colors group-hover:text-neutral-950">@Product.Name</h2>
                    </a>
                }
                else
                {
                    <h2 class="mt-2 text-lg font-extrabold text-neutral-900">@Product.Name</h2>
                }
            </div>

            <div class="flex flex-wrap justify-end gap-2 text-[10px] font-semibold uppercase tracking-[0.18em]">
                @if (IsNewArrival)
                {
                    <span class="inline-block rounded bg-green-600/90 px-2 py-0.5 text-white">New</span>
                }
                @if (Product.HasVariants)
                {
                    <span class="inline-block rounded bg-amber-100 px-2 py-0.5 text-amber-800">Variants</span>
                }
                @if (!Product.InStock)
                {
                    <span class="inline-block rounded bg-rose-100 px-2 py-0.5 text-rose-800">Out</span>
                }
                @if (IsPurchasePaused && !Product.HasVariants && Product.InStock)
                {
                    <span class="inline-block rounded bg-neutral-100 px-2 py-0.5 text-neutral-700">Paused</span>
                }
            </div>
        </div>

        <p class="mt-2 text-[15px]">
            <span class="font-semibold text-rose-600">@PriceLabel</span>
            <span class="font-semibold">@FormatPrice(DisplayPrice, DisplayCurrencyCode)</span>
            @if (DisplayComparePrice is not null && DisplayComparePrice > DisplayPrice)
            {
                <span class="ml-2 text-sm font-semibold text-neutral-400 line-through">@FormatPrice(DisplayComparePrice.Value, DisplayCurrencyCode)</span>
            }
        </p>

        @if (!string.IsNullOrWhiteSpace(Product.Slug))
        {
            <a href="@StorefrontRoutes.Product(Product.Slug)" aria-label="View @Product.Name" class="mt-4 block">
                <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-neutral-50">
                    <img src="@Product.Image" alt="@Product.Name" class="absolute inset-0 h-full w-full object-contain transition-transform duration-300 ease-out group-hover:scale-105" />
                </div>
            </a>
        }
        else
        {
            <div class="mt-4 relative aspect-[4/3] overflow-hidden rounded-xl bg-neutral-50">
                <img src="@Product.Image" alt="@Product.Name" class="absolute inset-0 h-full w-full object-contain transition-transform duration-300 ease-out group-hover:scale-105" />
            </div>
        }

        <p class="mt-4 text-sm leading-6 text-neutral-700">@Truncate(CardDescription)</p>
    </div>

    <div class="mt-auto border-t border-neutral-100 px-6 py-4 text-sm">
        <div class="flex flex-wrap gap-2">
            @if (CanAddDirectly)
            {
                <button type="button"
                        class="inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2 font-semibold text-white transition hover:bg-amber-600"
                        data-storefront-add-to-cart
                        data-default-label="Add to Cart"
                        data-success-label="Added"
                        data-product-id="@Product.Id"
                        data-product-name="@Product.Name"
                        data-unit-price="@UnitPriceValue"
                        data-currency-code="@DisplayCurrencyCode"
                        data-stock="@DirectAddStockValue">
                    Add to Cart
                </button>
            }
            else if (Product.HasVariants && !string.IsNullOrWhiteSpace(ProductPurchaseUrl))
            {
                <a href="@ProductPurchaseUrl" class="inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2 font-semibold text-white transition hover:bg-amber-600">
                    Add to Cart
                </a>
            }

            @if (!string.IsNullOrWhiteSpace(ProductUrl))
            {
                <a href="@ProductUrl" class="inline-flex items-center justify-center rounded-md bg-neutral-900 px-4 py-2 font-medium text-white hover:bg-neutral-800">
                    View Product
                </a>
            }
        </div>

        @if (Product.HasVariants)
        {
            <p class="mt-3 text-xs font-medium uppercase tracking-[0.16em] text-neutral-500">Select variant on the product page before adding.</p>
        }
        else if (!Product.InStock)
        {
            <p class="mt-3 text-xs font-medium uppercase tracking-[0.16em] text-rose-600">Currently out of stock.</p>
        }
        else if (!Product.Purchasable)
        {
            <p class="mt-3 text-xs font-medium uppercase tracking-[0.16em] text-neutral-600">@PurchaseBlockMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(Product.CategorySlug) && !string.IsNullOrWhiteSpace(Product.CategoryName))
        {
            <a href="@StorefrontRoutes.Category(Product.CategorySlug)" class="mt-3 inline-flex items-center gap-2 text-sm text-neutral-700 hover:text-neutral-900">
                Browse @Product.CategoryName
            </a>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public GetCatalogProduct Product { get; set; } = new();

    private StorefrontDisplayContext _displayContext = StorefrontDisplayContext.Fallback;

    private bool IsNewArrival => DateTime.UtcNow.Subtract(Product.CreatedOn).TotalDays <= 7;

    private bool CanAddDirectly => !Product.HasVariants && Product.Purchasable && QuantityOneAllowed;

    private bool IsPurchasePaused => Product.PurchaseBlockReasons.Contains("purchase_disabled", StringComparer.Ordinal);

    private bool QuantityOneAllowed =>
        Product.MinOrderQuantity <= 1
        && (!Product.MaxOrderQuantity.HasValue || Product.MaxOrderQuantity.Value >= 1)
        && Product.QuantityStep <= 1;

    private int DirectAddStockValue => Product.ManageStock ? Math.Max(0, Product.AvailableQuantity ?? Product.Quantity) : 999999;

    private string PurchaseBlockMessage => Product.PurchaseBlockReasons.FirstOrDefault() switch
    {
        "purchase_disabled" => "Purchasing is paused.",
        "below_min_quantity" => $"Minimum order quantity is {Product.MinOrderQuantity}.",
        "out_of_stock" => "Currently out of stock.",
        _ => "Currently unavailable.",
    };

    private string PriceLabel => Product.HasVariants ? "From" : "Price";

    private string? ProductUrl => string.IsNullOrWhiteSpace(Product.Slug)
        ? null
        : StorefrontRoutes.Product(Product.Slug);

    private string? ProductPurchaseUrl => ProductUrl is null
        ? null
        : $"{ProductUrl}#purchase";

    private decimal DisplayPrice => Product.DisplayPrice ?? Product.Price;

    private decimal? DisplayComparePrice => Product.DisplayComparePrice ?? Product.ComparePrice;

    private string DisplayCurrencyCode => NormalizeCurrencyCode(Product.DisplayCurrencyCode) ?? _displayContext.DefaultCurrencyCode;

    private string UnitPriceValue => DisplayPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);

    private string? CardDescription => string.IsNullOrWhiteSpace(Product.ShortDescription)
        ? Product.Description
        : Product.ShortDescription;

    protected override async Task OnInitializedAsync()
    {
        _displayContext = await DisplayContextProvider.GetAsync();
    }

    private string FormatPrice(decimal amount, string currencyCode) => PriceFormatter.Format(amount, _displayContext with { CurrencyCode = currencyCode });

    private static string? NormalizeCurrencyCode(string? currencyCode)
    {
        var normalized = currencyCode?.Trim().ToUpperInvariant();
        return normalized is { Length: 3 } && normalized.All(char.IsLetter)
            ? normalized
            : null;
    }

    private static string Truncate(string? value, int maxLength = 110)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value ?? string.Empty;
        }

        return $"{value[..maxLength].TrimEnd()}...";
    }
}

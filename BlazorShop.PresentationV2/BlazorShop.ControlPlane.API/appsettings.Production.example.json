{
  "ConnectionStrings": {
    "ControlPlaneConnection": "Host=<control-plane-db-host>;Port=5432;Database=blazorshop_controlplane;Username=<user>;Password=<secret>"
  },
  "Jwt": {
    "Key": "<replace-with-strong-secret>",
    "Issuer": "https://controlplane-api.example.com",
    "Audience": "https://controlplane-api.example.com"
  },
  "ClientApp": {
    "BaseUrl": "https://controlplane.example.com"
  },
  "Identity": {
    "RequireConfirmedAccount": true,
    "RequireConfirmedEmail": true
  },
  "ControlPlane": {
    "Database": {
      "MigrateOnStartup": false
    },
    "Cors": {
      "AllowedOrigins": [
        "https://controlplane.example.com"
      ]
    },
    "ForwardedHeaders": {
      "KnownProxies": [
        "10.0.0.10"
      ]
    },
    "RateLimiting": {
      "PermitLimit": 120,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Probes": {
      "ScheduledEnabled": false,
      "IntervalSeconds": 300,
      "TimeoutSeconds": 10
    }
  },
  "AllowedHosts": "controlplane-api.example.com"
}

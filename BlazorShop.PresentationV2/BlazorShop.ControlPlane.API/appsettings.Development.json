{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ControlPlaneConnection": "Host=localhost;Port=5433;Database=blazorshop_controlplane;Username=blazorshop_controlplane;Password=blazorshop_controlplane_dev"
  },
  "Jwt": {
    "Key": "development-only-control-plane-jwt-key-change-before-production",
    "Issuer": "https://localhost:7280",
    "Audience": "https://localhost:7280"
  },
  "ClientApp": {
    "BaseUrl": "https://localhost:7281"
  },
  "Identity": {
    "RequireConfirmedAccount": false,
    "RequireConfirmedEmail": false
  },
  "ControlPlane": {
    "Database": {
      "MigrateOnStartup": true
    },
    "SeedAdmin": {
      "Enabled": false,
      "Email": "admin@example.local",
      "DisplayName": "Control Plane Admin",
      "IdentityRole": "Admin",
      "ControlPlaneRoleKey": "platform_owner"
    },
    "SeedUser": {
      "Enabled": false,
      "Email": "user@example.local",
      "DisplayName": "Control Plane User",
      "IdentityRole": "User",
      "ControlPlaneRoleKey": "auditor"
    },
    "Cors": {
      "AllowedOrigins": [
        "https://localhost:7281",
        "http://localhost:5281"
      ]
    },
    "ForwardedHeaders": {
      "KnownProxies": []
    },
    "RateLimiting": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 20
    },
    "Probes": {
      "ScheduledEnabled": false,
      "IntervalSeconds": 300,
      "TimeoutSeconds": 10
    }
  }
}

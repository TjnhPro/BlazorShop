{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ControlPlaneConnection": "Host=localhost;Port=5433;Database=blazorshop_controlplane;Username=<set-in-user-secrets>;Password=<set-in-user-secrets>"
  },
  "Jwt": {
    "Key": "<set-in-user-secrets>",
    "Issuer": "https://localhost:7280",
    "Audience": "https://localhost:7280"
  },
  "ClientApp": {
    "BaseUrl": "https://localhost:7281"
  },
  "Identity": {
    "RequireConfirmedAccount": true,
    "RequireConfirmedEmail": true
  },
  "ControlPlane": {
    "Database": {
      "Provider": "PostgreSQL",
      "ConnectionName": "ControlPlaneConnection"
    },
    "SeedAdmin": {
      "Enabled": false,
      "Email": "",
      "DisplayName": "",
      "IdentityRole": "Admin",
      "ControlPlaneRoleKey": "platform_owner"
    },
    "SeedUser": {
      "Enabled": false,
      "Email": "",
      "DisplayName": "",
      "IdentityRole": "User",
      "ControlPlaneRoleKey": "auditor"
    },
    "Cors": {
      "AllowedOrigins": []
    },
    "ForwardedHeaders": {
      "KnownProxies": []
    },
    "RateLimiting": {
      "PermitLimit": 120,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Probes": {
      "ScheduledEnabled": false,
      "IntervalSeconds": 300,
      "TimeoutSeconds": 10
    }
  },
  "AllowedHosts": "*"
}

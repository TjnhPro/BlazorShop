<article class="starter-product-card sfb-product-card">
    <a class="starter-product-media sfb-product-card-media" href="@Href" aria-label="@($"Open {Name}")">
        @if (!string.IsNullOrWhiteSpace(ImageUrl))
        {
            <img src="@ImageUrl" alt="" loading="lazy" />
        }
        else
        {
            <ProductGalleryPlaceholder Label="@Name" />
        }
    </a>
    <p class="sfb-product-kicker">Catalog pick</p>
    <h3><a href="@Href">@Name</a></h3>
    @if (!string.IsNullOrWhiteSpace(Price))
    {
        <p class="sfb-product-price">@Price</p>
    }
    <a class="sfb-secondary-link" href="@Href">View product</a>
</article>

@code {
    [Parameter]
    public string Name { get; set; } = "Product";

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public string? Price { get; set; }

    [Parameter]
    public string Href { get; set; } = "#";
}


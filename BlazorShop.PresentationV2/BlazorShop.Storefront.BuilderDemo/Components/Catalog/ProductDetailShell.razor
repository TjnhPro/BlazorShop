<section class="starter-detail-shell sfb-product-detail">
    <ProductGalleryPlaceholder Label="@ProductName" />
    <div class="sfb-product-info">
        <p class="sfb-eyebrow">In stock</p>
        <h2>@ProductName</h2>
        <p>Generated product information region using safe product media and Starter-backed purchase actions.</p>
        <ul>
            <li>Square media presentation</li>
            <li>Responsive detail stacking</li>
            <li>Fallback content section</li>
        </ul>
    </div>
    <PurchasePanelPlaceholder ProductName="@ProductName" />
</section>

@code {
    [Parameter]
    public string ProductName { get; set; } = "Product";
}


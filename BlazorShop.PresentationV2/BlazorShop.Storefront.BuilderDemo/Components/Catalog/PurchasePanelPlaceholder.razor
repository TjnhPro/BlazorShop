<aside class="starter-purchase-panel sfb-product-purchase">
    <h2>@ProductName</h2>
    <p>Purchase controls stay backed by Commerce Node validation.</p>
    <label class="sfb-quantity-control">
        Quantity
        <input type="number" min="1" step="1" value="1" />
    </label>
    <button class="starter-button" type="button" data-action="cart.add-line" disabled>Add to cart</button>
    <button class="sfb-secondary-button" type="button" disabled>Buy now</button>
</aside>

@code {
    [Parameter]
    public string ProductName { get; set; } = "Product";
}


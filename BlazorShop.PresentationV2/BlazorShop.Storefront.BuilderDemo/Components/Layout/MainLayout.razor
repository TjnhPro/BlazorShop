@inherits LayoutComponentBase

<header class="starter-header sfb-shell-header">
    <a class="starter-brand" href="/">Builder Demo</a>
    <nav class="sfb-main-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/search">Search</a>
        <a href="/deals">Deals</a>
        <a class="sfb-cart-badge" href="/cart" aria-label="Cart">Cart <span>0</span></a>
        <a href="/account" aria-label="Account">Account</a>
    </nav>
    <nav class="sfb-mobile-nav" aria-label="Mobile navigation">
        <a href="/search">Search</a>
        <a href="/cart">Cart</a>
        <a href="/account">Account</a>
    </nav>
</header>

<main class="starter-main">
    <nav class="starter-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
    </nav>
    @Body
</main>

<div class="starter-toast-region" aria-live="polite" aria-atomic="true"></div>

<footer class="starter-footer sfb-shell-footer">
    <span>Builder Demo storefront</span>
    <nav aria-label="Footer navigation">
        <a href="/content/about">About</a>
        <a href="/content/shipping">Shipping</a>
        <a href="/content/contact">Contact</a>
    </nav>
</footer>


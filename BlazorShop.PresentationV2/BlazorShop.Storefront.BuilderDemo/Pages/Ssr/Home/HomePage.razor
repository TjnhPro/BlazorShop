@page "/"
@using BlazorShop.Storefront.Runtime
@inject IOptions<StarterStorefrontOptions> StorefrontOptions
@inject StorefrontBootstrapService BootstrapService
@inject StarterFeatureActivationService FeatureActivationService

<PageTitle>@(_snapshot?.StoreName ?? "Storefront Starter")</PageTitle>

<section class="sfb-hero" aria-labelledby="home-title">
    <p class="sfb-eyebrow">Generated storefront</p>
    <h1 id="home-title">@(_snapshot?.StoreName ?? "Builder Demo")</h1>
    <p>Target-inspired storefront composition backed by the Starter client and runtime packages.</p>
    <div class="sfb-hero-actions">
        <a class="starter-button" href="/search">Shop catalog</a>
        <a class="sfb-secondary-link" href="/deals">View deals</a>
    </div>
</section>

<dl class="starter-config sfb-store-config">
    <dt>Store key</dt>
    <dd>@(_snapshot?.StoreKey ?? StorefrontOptions.Value.StoreKey)</dd>
    <dt>Commerce API</dt>
    <dd>Configured server-side</dd>
    <dt>Render owner</dt>
    <dd>SSR</dd>
</dl>

@if (_snapshot?.Error is not null)
{
    <section class="starter-alert" data-error-code="@_snapshot.Error.Code">
        <h2>Storefront unavailable</h2>
        <p>@_snapshot.Error.Message</p>
    </section>
    <section class="starter-section sfb-featured-grid" aria-labelledby="fallback-products-title" data-hydration-mode="@StarterHydrationMode.InitialSnapshot">
        <h2 id="fallback-products-title">Featured products</h2>
        <div class="starter-product-grid">
            <ProductSummaryCard Name="Sample product" Price="29.00 USD" Href="/product/sample-product" />
        </div>
    </section>
}
else if (_snapshot is not null)
{
    <section class="starter-section sfb-featured-grid" aria-labelledby="featured-products-title" data-hydration-mode="@StarterHydrationMode.InitialSnapshot">
        <h2 id="featured-products-title">Featured products</h2>
        <ProductGrid Products="@_snapshot.Products" CurrencyCode="@_snapshot.CurrencyCode" />
    </section>

    @if (FeatureActivationService.Evaluate("recommendations", "home", _snapshot.Features).Visible)
    {
        <section class="starter-section sfb-content-band" aria-labelledby="recommendations-title">
            <h2 id="recommendations-title">Recommended</h2>
            <p>Recommendation placement is active for this store.</p>
        </section>
    }
}

@code {
    private StarterBootstrapSnapshot? _snapshot;

    protected override async Task OnInitializedAsync()
    {
        using var timeout = new CancellationTokenSource(TimeSpan.FromSeconds(3));
        try
        {
            _snapshot = await BootstrapService.LoadAsync(timeout.Token);
        }
        catch (Exception exception) when (exception is OperationCanceledException or HttpRequestException)
        {
            _snapshot = StarterBootstrapSnapshot.Failed(new StorefrontRuntimeError(
                503,
                "storefront.bootstrap_unavailable",
                "Storefront data is unavailable; generated fallback content is still renderable.",
                null,
                new Dictionary<string, IReadOnlyList<string>>(StringComparer.Ordinal)));
        }
    }
}


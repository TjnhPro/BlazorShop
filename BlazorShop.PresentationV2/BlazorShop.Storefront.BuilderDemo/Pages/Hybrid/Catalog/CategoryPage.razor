@page "/category/{Slug}"

<PageTitle>@CategoryTitle</PageTitle>
<HeadContent>
    <meta name="description" content="@CategoryDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
</HeadContent>
<section class="sfb-catalog-header" aria-labelledby="category-title">
    <p class="sfb-eyebrow">Category</p>
    <h1 id="category-title">@CategoryTitle</h1>
    <p>@CategoryDescription</p>
</section>
<div class="sfb-catalog-toolbar" data-hydration-mode="@StarterHydrationMode.BrowserFetch">
    <label>
        Search
        <input type="search" placeholder="Search this category" />
    </label>
    <label>
        Sort
        <select>
            <option>Featured</option>
            <option>Newest</option>
            <option>Price low to high</option>
        </select>
    </label>
    <button class="starter-button" type="button">Filters</button>
</div>
<PlaceholderState
    Title="Category shell"
    Message="SSR snapshot supplies category and product listing data."
    RenderOwner="Hybrid"
    HydrationMode="StarterHydrationMode.InitialSnapshot" />
<section class="starter-section sfb-featured-grid" aria-label="Category products">
    <div class="starter-product-grid">
        <ProductSummaryCard Name="Sample product" Price="29.00 USD" Href="/product/sample-product" />
        <ProductSummaryCard Name="Catalog item" Price="39.00 USD" Href="/product/catalog-item" />
    </div>
    <nav class="sfb-pagination" aria-label="Pagination">
        <a href="@CanonicalUrl">Previous</a>
        <a href="@CanonicalUrl" aria-current="page">1</a>
        <a href="@CanonicalUrl">Next</a>
    </nav>
</section>

@code {
    [Parameter]
    public string? Slug { get; set; }

    private string CategoryTitle => string.IsNullOrWhiteSpace(this.Slug)
        ? "Category"
        : $"Category {this.Slug}";

    private string CategoryDescription => $"Storefront category page for {NormalizeSlug(this.Slug)}.";

    private string CanonicalUrl => $"/category/{NormalizeSlug(this.Slug)}";

    private static string NormalizeSlug(string? slug)
    {
        return string.IsNullOrWhiteSpace(slug) ? "sample-category" : slug.Trim();
    }
}


@page "/search"

<PageTitle>Search</PageTitle>
<section class="sfb-catalog-header" aria-labelledby="search-title">
    <p class="sfb-eyebrow">Search</p>
    <h1 id="search-title">Search</h1>
    <p>Find products through the Starter catalog contract.</p>
</section>
<div class="sfb-catalog-toolbar" data-hydration-mode="@StarterHydrationMode.BrowserFetch">
    <input type="search" placeholder="Search products" aria-label="Search products" />
    <select aria-label="Sort results">
        <option>Relevance</option>
        <option>Newest</option>
    </select>
</div>
<PlaceholderState
    Title="Search shell"
    Message="Search can start from query SSR data and refresh after hydration when filters change."
    RenderOwner="Hybrid"
    HydrationMode="StarterHydrationMode.RefreshAfterHydration" />


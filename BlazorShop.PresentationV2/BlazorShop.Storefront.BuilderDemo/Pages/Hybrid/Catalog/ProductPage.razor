@page "/product/{Slug}"

<PageTitle>@ProductTitle</PageTitle>
<HeadContent>
    <meta name="description" content="@ProductDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <script type="application/ld+json">@((MarkupString)ProductJsonLd)</script>
</HeadContent>
<section class="sfb-product-page" aria-labelledby="product-title">
    <div>
        <p class="sfb-eyebrow">Product</p>
        <h1 id="product-title">@ProductTitle</h1>
        <p>@ProductDescription</p>
    </div>
    <PlaceholderState
        Title="Product detail shell"
        Message="SSR snapshot supplies product data; browser interactivity may refresh after hydration."
        RenderOwner="Hybrid"
        HydrationMode="StarterHydrationMode.InitialSnapshot" />
    <ProductDetailShell ProductName="@ProductTitle" />
</section>

@code {
    [Parameter]
    public string? Slug { get; set; }

    private string ProductTitle => string.IsNullOrWhiteSpace(this.Slug)
        ? "Product"
        : $"Product {this.Slug}";

    private string ProductDescription => $"Storefront product page for {NormalizeSlug(this.Slug)}.";

    private string CanonicalUrl => $"/product/{NormalizeSlug(this.Slug)}";

    private string ProductJsonLd => $$"""
        {
          "@context": "https://schema.org",
          "@type": "Product",
          "name": "{{ProductTitle}}",
          "url": "{{CanonicalUrl}}"
        }
        """;

    private static string NormalizeSlug(string? slug)
    {
        return string.IsNullOrWhiteSpace(slug) ? "sample-product" : slug.Trim();
    }
}


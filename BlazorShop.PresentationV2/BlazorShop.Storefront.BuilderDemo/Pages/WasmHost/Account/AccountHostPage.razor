@page "/account"
@page "/account/{*Path}"

<PageTitle>Account</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>
<section class="sfb-fallback-page" aria-labelledby="account-title">
<h1 id="account-title">Account</h1>
<PlaceholderState
    Title="Account host"
    Message="Profile, addresses, orders, and password management are browser-owned behind same-origin account APIs."
    RenderOwner="WASM"
    HydrationMode="StarterHydrationMode.BrowserFetch" />
<AccountShell />
</section>

@code {
    [Parameter]
    public string? Path { get; set; }
}


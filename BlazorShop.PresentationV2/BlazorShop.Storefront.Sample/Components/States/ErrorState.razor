<section class="starter-state starter-state-error" role="alert" data-error-code="@Code">
    <h2>@Title</h2>
    <p>@Message</p>
    @if (ChildContent is not null)
    {
        @ChildContent
    }
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Request failed";

    [Parameter]
    public string Message { get; set; } = "The request could not be completed.";

    [Parameter]
    public string? Code { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}


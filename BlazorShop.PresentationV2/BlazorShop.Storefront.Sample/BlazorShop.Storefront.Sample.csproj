<Project Sdk="Microsoft.NET.Sdk.Web">

  <Import Project="StorefrontPackageVersions.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>BlazorShop.Storefront.Sample</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BlazorShop.Storefront.Client" Version="$(StorefrontClientPackageVersion)" />
    <PackageReference Include="BlazorShop.Storefront.Runtime" Version="$(StorefrontRuntimePackageVersion)" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="Features\feature-manifest.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>


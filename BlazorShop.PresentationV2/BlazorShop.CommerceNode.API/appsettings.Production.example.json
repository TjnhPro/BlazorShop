{
  "ConnectionStrings": {
    "CommerceNodeConnection": "Host=<commerce-node-db-host>;Port=5432;Database=blazorshop_commerce_node;Username=<user>;Password=<secret>"
  },
  "JWT": {
    "Key": "<replace-with-strong-secret>",
    "Issuer": "https://commerce-node-api.example.com",
    "Audience": "https://commerce-node-api.example.com"
  },
  "ClientApp": {
    "BaseUrl": "https://store.example.com"
  },
  "Identity": {
    "RequireConfirmedAccount": true,
    "RequireConfirmedEmail": true
  },
  "CommerceNode": {
    "NodeKey": "<set-in-environment>",
    "NodeSecret": "<set-in-environment>",
    "AllowedControlPlaneIps": [
      "10.0.0.10"
    ],
    "Database": {
      "MigrateOnStartup": false,
      "FailStartupOnMigrationError": true,
      "LogMigrationState": true
    },
    "DataProtection": {
      "KeyRingPath": "/var/lib/blazorshop/commerce-node/data-protection-keys"
    },
    "EmailTransport": {
      "AllowGlobalEmailSettingsFallback": false,
      "CaptureModeAllowed": false
    },
    "CurrencyExchangeRateProviders": {
      "Configuration": {
        "Enabled": false,
        "Source": "<safe-provider-source-name>",
        "MaxRateAgeHours": 24,
        "Rates": []
      }
    }
  },
  "StorefrontDeployment": {
    "NetworkName": "blazorshop-commercenode",
    "EnvDirectory": "runtime/storefront-env",
    "HealthPath": "/",
    "UseDockerExecHealthProbe": true,
    "HealthProbeContainerName": "blazorshop-commercenode-nginx",
    "StorefrontApiBaseUrl": "http://host.docker.internal:5180/api/",
    "AllowedImages": [
      "blazorshop-storefront-v2:latest"
    ]
  },
  "NginxDeployment": {
    "UseDockerExec": true,
    "ContainerName": "blazorshop-commercenode-nginx",
    "ConfigDirectory": "runtime/nginx/conf.d",
    "MediaUpstreamUrl": "http://host.docker.internal:5180"
  },
  "Runtime": {
    "ForwardedHeaders": {
      "KnownProxies": [
        "10.0.0.20"
      ],
      "KnownNetworks": [],
      "ForwardLimit": 1
    },
    "RateLimiting": {
      "Enabled": true,
      "AuthStrict": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Cart": {
        "PermitLimit": 180,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Checkout": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Newsletter": {
        "PermitLimit": 20,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "Currency": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Consent": {
      "Enabled": true,
      "CurrentVersion": "2026-07",
      "BannerRequired": true,
      "VisitorCookieLifetimeDays": 180,
      "EventRetentionDays": 365,
      "OptionalCategoriesDefaultEnabled": false,
      "PolicyPagePath": "/pages/cookies"
    },
    "Captcha": {
      "Enabled": false,
      "ProviderSystemName": "none",
      "PublicSiteKey": "<public-site-key-when-enabled>",
      "SecretReference": "<secret-manager-reference-when-enabled>",
      "MinimumScore": 0.5,
      "Targets": {
        "Login": false,
        "Registration": false,
        "Newsletter": false,
        "PasswordRecovery": false,
        "Contact": false,
        "Review": false
      }
    },
    "Security": {
      "RefreshTokenCookieName": "__Host-blazorshop-refresh",
      "RefreshTokenCookieSameSite": "Strict",
      "RefreshTokenLifetimeDays": 14
    },
    "SecurityPrivacy": {
      "RefreshTokenIpRetentionDays": 30,
      "RefreshTokenUserAgentRetentionDays": 30,
      "ConsentEventRetentionDays": 365,
      "CaptchaVerificationLogRetentionDays": 30,
      "NewsletterConsentEvidenceRetentionDays": 365,
      "AnonymizeIpAfterRetentionWindow": true
    }
  },
  "AllowedHosts": "commerce-node-api.example.com"
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "CommerceNodeConnection": "Host=localhost;Port=5434;Database=blazorshop_commerce_node;Username=blazorshop_commerce_node;Password=blazorshop_commerce_node_dev"
  },
  "JWT": {
    "Key": "development-commerce-node-jwt-key-change-before-production",
    "Issuer": "https://localhost:7444",
    "Audience": "https://localhost:7444"
  },
  "ClientApp": {
    "BaseUrl": "https://localhost:7258"
  },
  "Identity": {
    "RequireConfirmedAccount": false,
    "RequireConfirmedEmail": false
  },
  "CommerceNode": {
    "NodeKey": "dev-node",
    "NodeSecret": "dev-node-secret",
    "AllowedControlPlaneIps": [
      "127.0.0.1",
      "::1"
    ],
    "Database": {
      "MigrateOnStartup": true,
      "FailStartupOnMigrationError": true,
      "LogMigrationState": true
    },
    "EmailTransport": {
      "AllowGlobalEmailSettingsFallback": false,
      "CaptureModeAllowed": true
    },
    "CurrencyExchangeRateProviders": {
      "Configuration": {
        "Enabled": false,
        "Source": "development-configuration",
        "MaxRateAgeHours": 24,
        "Rates": []
      }
    }
  },
  "StorefrontDeployment": {
    "NetworkName": "blazorshop-commercenode",
    "EnvDirectory": "runtime/storefront-env",
    "HealthPath": "/",
    "UseDockerExecHealthProbe": true,
    "HealthProbeContainerName": "blazorshop-commercenode-nginx",
    "StorefrontApiBaseUrl": "http://host.docker.internal:5180/api/",
    "AllowedImages": [
      "blazorshop-storefront-v2:latest"
    ]
  },
  "NginxDeployment": {
    "UseDockerExec": true,
    "ContainerName": "blazorshop-commercenode-nginx",
    "ConfigDirectory": "runtime/nginx/conf.d",
    "MediaUpstreamUrl": "http://host.docker.internal:5180"
  },
  "Runtime": {
    "RateLimiting": {
      "Enabled": true,
      "AuthStrict": {
        "PermitLimit": 40,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Cart": {
        "PermitLimit": 240,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Checkout": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Newsletter": {
        "PermitLimit": 40,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "Currency": {
        "PermitLimit": 180,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Consent": {
      "Enabled": true,
      "CurrentVersion": "2026-07-dev",
      "BannerRequired": true,
      "VisitorCookieLifetimeDays": 180,
      "EventRetentionDays": 365,
      "OptionalCategoriesDefaultEnabled": false,
      "PolicyPagePath": "/pages/cookies"
    },
    "Captcha": {
      "Enabled": false,
      "ProviderSystemName": "none",
      "PublicSiteKey": null,
      "SecretReference": null,
      "MinimumScore": 0.5,
      "Targets": {
        "Login": false,
        "Registration": false,
        "Newsletter": false,
        "PasswordRecovery": false,
        "Contact": false,
        "Review": false
      }
    },
    "Security": {
      "RefreshTokenCookieName": "__Host-blazorshop-refresh",
      "RefreshTokenCookieSameSite": "Strict",
      "RefreshTokenLifetimeDays": 14
    },
    "SecurityPrivacy": {
      "RefreshTokenIpRetentionDays": 30,
      "RefreshTokenUserAgentRetentionDays": 30,
      "ConsentEventRetentionDays": 365,
      "CaptchaVerificationLogRetentionDays": 30,
      "NewsletterConsentEvidenceRetentionDays": 365,
      "AnonymizeIpAfterRetentionWindow": true
    }
  }
}

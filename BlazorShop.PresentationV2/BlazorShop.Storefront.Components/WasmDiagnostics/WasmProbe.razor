<div data-wasm-probe
     style="position: fixed; right: 12px; bottom: 12px; z-index: 2147483000; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(16, 185, 129, 0.35); border-radius: 4px; background: rgba(10, 10, 10, 0.94); padding: 8px 10px; color: #fff; font-size: 12px; box-shadow: 0 12px 30px rgba(0, 0, 0, 0.28);">
    <span data-wasm-probe-runtime style="line-height: 1;">@RuntimeLabel</span>
    <button type="button"
            data-wasm-probe-button
            style="border: 0; border-radius: 4px; background: #34d399; padding: 4px 8px; color: #111827; font-weight: 700; cursor: pointer;"
            @onclick="Increment">
        Count @_count
    </button>
</div>

@code {
    private int _count;

    private static string RuntimeLabel => OperatingSystem.IsBrowser()
        ? "WASM active"
        : "SSR prerender";

    private void Increment()
    {
        _count++;
    }
}

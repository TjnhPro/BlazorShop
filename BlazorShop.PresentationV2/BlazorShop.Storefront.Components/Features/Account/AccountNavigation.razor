@namespace BlazorShop.Storefront.Components.Features.Account

<nav class="rounded border border-neutral-200 bg-white p-4 text-sm" aria-label="Account navigation" data-storefront-account-navigation>
    <a class="@LinkClass(ProfileRoute)" href="@ProfileRoute">Profile</a>
    <a class="@LinkClass(OrdersRoute)" href="@OrdersRoute">Orders</a>
    <a class="@LinkClass(AddressesRoute)" href="@AddressesRoute">Addresses</a>
    <a class="@LinkClass(ChangePasswordRoute)" href="@ChangePasswordRoute">Password</a>
</nav>

@code {
    private const string ProfileRoute = "/account/profile";
    private const string OrdersRoute = "/account/orders";
    private const string AddressesRoute = "/account/addresses";
    private const string ChangePasswordRoute = "/account/change-password";

    [Parameter]
    public string ActiveRoute { get; set; } = ProfileRoute;

    private string LinkClass(string route)
    {
        var active = string.Equals(route, ActiveRoute, StringComparison.OrdinalIgnoreCase);
        return active
            ? "mt-2 block rounded bg-neutral-900 px-3 py-2 font-semibold text-white first:mt-0"
            : "mt-2 block rounded px-3 py-2 font-semibold text-neutral-700 hover:bg-neutral-100 first:mt-0";
    }
}

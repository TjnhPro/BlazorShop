@namespace BlazorShop.Storefront.Components.Account
@using BlazorShop.Storefront.Components.Browser
@inject IServiceProvider Services

<div data-storefront-account-password>
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="mb-5 rounded border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800" role="status">@_success</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="mb-5 rounded border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800" role="alert">@_error</div>
    }

    <form method="post" action="@FormAction" class="max-w-xl space-y-5" @onsubmit="SaveAsync" @onsubmit:preventDefault="true">
        <AntiforgeryToken />
        @RenderAntiforgeryField()
        <label class="block text-sm">
            <span class="font-semibold text-neutral-800">Current password</span>
            <input name="CurrentPassword" type="password" autocomplete="current-password" required @bind="_currentPassword" class="mt-2 min-h-11 w-full rounded border border-neutral-300 px-3 text-sm" />
        </label>
        <label class="block text-sm">
            <span class="font-semibold text-neutral-800">New password</span>
            <input name="NewPassword" type="password" autocomplete="new-password" required minlength="8" @bind="_newPassword" class="mt-2 min-h-11 w-full rounded border border-neutral-300 px-3 text-sm" />
        </label>
        <label class="block text-sm">
            <span class="font-semibold text-neutral-800">Confirm new password</span>
            <input name="ConfirmPassword" type="password" autocomplete="new-password" required minlength="8" @bind="_confirmPassword" class="mt-2 min-h-11 w-full rounded border border-neutral-300 px-3 text-sm" />
        </label>
        <button type="submit" disabled="@_saving" class="inline-flex rounded bg-neutral-900 px-5 py-3 text-sm font-semibold text-white hover:bg-neutral-800 disabled:cursor-wait disabled:bg-neutral-500">@(_saving ? "Changing..." : "Change password")</button>
    </form>
</div>

@code {
    [Parameter]
    public string? InitialError { get; set; }

    [Parameter]
    public string? InitialSuccess { get; set; }

    [Parameter]
    public string FormAction { get; set; } = "/account/change-password";

    [Parameter]
    public string? AntiforgeryFieldName { get; set; }

    [Parameter]
    public string? AntiforgeryRequestToken { get; set; }

    private string? _currentPassword;
    private string? _newPassword;
    private string? _confirmPassword;
    private string? _error;
    private string? _success;
    private bool _saving;

    protected override void OnParametersSet()
    {
        _error = InitialError;
        _success = InitialSuccess;
    }

    private async Task SaveAsync()
    {
        if (!OperatingSystem.IsBrowser())
        {
            return;
        }

        var apiClient = Services.GetService(typeof(StorefrontLocalApiClient)) as StorefrontLocalApiClient;
        if (apiClient is null)
        {
            return;
        }

        _saving = true;
        _error = null;
        _success = null;
        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            _saving = false;
            _error = "Passwords do not match.";
            return;
        }

        var result = await apiClient.PostJsonAsync<object, StorefrontBrowserAccountCommandResult>(
            "/api/account/change-password",
            new
            {
                CurrentPassword = _currentPassword,
                NewPassword = _newPassword,
                ConfirmPassword = _confirmPassword,
            });
        _saving = false;
        if (result.Success && result.Data?.Success == true)
        {
            _currentPassword = null;
            _newPassword = null;
            _confirmPassword = null;
            _success = result.Data.Message;
            return;
        }

        _error = result.Message;
    }

    private RenderFragment RenderAntiforgeryField() => builder =>
    {
        if (string.IsNullOrWhiteSpace(AntiforgeryFieldName) || string.IsNullOrWhiteSpace(AntiforgeryRequestToken))
        {
            return;
        }

        builder.OpenElement(0, "input");
        builder.AddAttribute(1, "type", "hidden");
        builder.AddAttribute(2, "name", AntiforgeryFieldName);
        builder.AddAttribute(3, "value", AntiforgeryRequestToken);
        builder.CloseElement();
    };
}

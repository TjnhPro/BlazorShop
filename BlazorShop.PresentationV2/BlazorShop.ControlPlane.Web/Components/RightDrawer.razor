@if (IsOpen)
{
    <div class="fixed inset-0 z-40">
        <button type="button"
                class="absolute inset-0 h-full w-full bg-ink-900/30"
                aria-label="Close drawer"
                @onclick="CloseAsync"></button>
        <aside class="@DrawerClass" role="dialog" aria-modal="true" aria-labelledby="@TitleId">
            <header class="flex min-h-16 items-start justify-between gap-4 border-b border-ink-200 px-5 py-4">
                <div class="min-w-0">
                    @if (!string.IsNullOrWhiteSpace(Eyebrow))
                    {
                        <p class="text-xs font-semibold uppercase tracking-wide text-control-700">@Eyebrow</p>
                    }
                    <h2 id="@TitleId" class="truncate text-lg font-bold text-ink-900">@Title</h2>
                    @if (!string.IsNullOrWhiteSpace(Subtitle))
                    {
                        <p class="mt-1 text-sm text-ink-500">@Subtitle</p>
                    }
                </div>
                <button type="button" class="cp-button cp-button-secondary shrink-0" @onclick="CloseAsync" title="Close">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </button>
            </header>
            <div class="h-[calc(100vh-4rem)] overflow-y-auto px-5 py-5">
                @ChildContent
            </div>
        </aside>
    </div>
}

@code {
    private readonly string TitleId = "drawer-title-" + Guid.NewGuid().ToString("N");

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string Size { get; set; } = "large";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string DrawerClass => Size.Equals("medium", StringComparison.OrdinalIgnoreCase)
        ? "absolute inset-y-0 right-0 flex w-full max-w-[900px] flex-col overflow-hidden bg-white shadow-sm"
        : "absolute inset-y-0 right-0 flex w-full max-w-[min(1100px,90vw)] flex-col overflow-hidden bg-white shadow-sm";

    private async Task CloseAsync()
    {
        await IsOpenChanged.InvokeAsync(false);
    }
}

@using BlazorShop.ControlPlane.Web.Pages
@using BlazorShop.Domain.Constants

<section class="rounded-md border border-ink-200 p-4">
    <h2 class="text-sm font-semibold text-ink-900">Basic info</h2>
    <div class="mt-3 flex flex-wrap gap-2">
        <StatusBadge Text="@InventoryStatusLabel(Product)" Tone="@InventoryStatusTone(Product)" />
        <StatusBadge Text="@PurchaseStatusLabel(Product)" Tone="@PurchaseStatusTone(Product)" />
        @if (Product.HideWhenOutOfStock)
        {
            <StatusBadge Text="Hide when out of stock" Tone="neutral" />
        }
    </div>
    <div class="mt-3 grid gap-3 text-sm md:grid-cols-2">
        <label class="space-y-1 md:col-span-2">
            <span class="font-medium text-ink-700">Title</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="Form.Name" />
        </label>
        <label class="space-y-1 md:col-span-2">
            <span class="font-medium text-ink-700">Category</span>
            <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="BoundCategoryId">
                <option value="">No category</option>
                @foreach (var category in Categories.OrderBy(category => category.Name))
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </label>
        <label class="space-y-1 md:col-span-2">
            <span class="font-medium text-ink-700">Short description</span>
            <textarea class="min-h-20 w-full rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="Form.ShortDescription"></textarea>
        </label>
        <label class="space-y-1 md:col-span-2">
            <span class="font-medium text-ink-700">Full description</span>
            <textarea class="min-h-28 w-full rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="Form.FullDescription"></textarea>
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Price</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" @bind="Form.Price" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Compare price</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" @bind="Form.ComparePrice" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Display order</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" @bind="Form.DisplayOrder" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Available start UTC</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="datetime-local" @bind="Form.AvailableStartUtc" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Available end UTC</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="datetime-local" @bind="Form.AvailableEndUtc" />
        </label>
        <div class="md:col-span-2 pt-2 text-xs font-semibold uppercase text-ink-500">Availability & purchase</div>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Minimum order quantity</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="1" @bind="Form.MinOrderQuantity" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Maximum order quantity</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="1" @bind="Form.MaxOrderQuantity" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Quantity step</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="1" @bind="Form.QuantityStep" />
        </label>
        <div class="flex flex-wrap gap-4 rounded-md border border-ink-200 bg-ink-50 p-3 md:col-span-2">
            <label class="flex items-center gap-2 text-ink-700">
                <input type="checkbox" @bind="Form.ManageStock" />
                Manage stock
            </label>
            <label class="flex items-center gap-2 text-ink-700">
                <input type="checkbox" @bind="Form.HideWhenOutOfStock" />
                Hide when out of stock
            </label>
            <label class="flex items-center gap-2 text-ink-700">
                <input type="checkbox" @bind="Form.PurchasingDisabled" />
                Pause purchasing
            </label>
            <label class="flex items-center gap-2 text-ink-700">
                <input type="checkbox" @bind="Form.ShippingRequired" />
                Shipping required
            </label>
            <label class="flex items-center gap-2 text-ink-700">
                <input type="checkbox" @bind="Form.FreeShipping" />
                Free shipping
            </label>
        </div>
        <label class="space-y-1 md:col-span-2">
            <span class="font-medium text-ink-700">Purchasing disabled reason</span>
            <textarea class="min-h-20 w-full rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" maxlength="@ProductPurchaseConstraints.PurchasingDisabledReasonMaxLength" @bind="Form.PurchasingDisabledReason"></textarea>
        </label>
        <label class="space-y-1 md:col-span-2">
            <span class="font-medium text-ink-700">Delivery estimate</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" maxlength="@ProductPurchaseConstraints.DeliveryEstimateTextMaxLength" @bind="Form.DeliveryEstimateText" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Shipping surcharge</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="0" step="0.01" @bind="Form.ShippingSurcharge" />
        </label>
        <div class="md:col-span-2 pt-2 text-xs font-semibold uppercase text-ink-500">Identity & shipping prep</div>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">GTIN</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" maxlength="32" @bind="Form.Gtin" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Barcode</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" maxlength="64" @bind="Form.Barcode" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Manufacturer part number</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" maxlength="128" @bind="Form.ManufacturerPartNumber" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Condition</span>
            <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="Form.Condition">
                <option value="">Not set</option>
                <option value="new">New</option>
                <option value="used">Used</option>
                <option value="refurbished">Refurbished</option>
            </select>
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Weight</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="0" step="0.001" @bind="Form.Weight" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Length</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="0" step="0.001" @bind="Form.Length" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Width</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="0" step="0.001" @bind="Form.Width" />
        </label>
        <label class="space-y-1">
            <span class="font-medium text-ink-700">Height</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="0" step="0.001" @bind="Form.Height" />
        </label>
    </div>
    <div class="mt-3 rounded-md border border-ink-200 bg-ink-50 p-3 text-xs text-ink-600">
        Locked: SKU, product type, store id, and variation template are not editable here.
    </div>
    <button class="cp-button cp-button-primary mt-4 justify-center" disabled="@IsSaving" @onclick="SaveBasic">
        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
        Save basic info
    </button>
</section>

@code {
    [Parameter, EditorRequired]
    public GetProduct Product { get; set; } = default!;

    [Parameter, EditorRequired]
    public CommerceProductBasicForm Form { get; set; } = default!;

    [Parameter]
    public IReadOnlyCollection<GetCategory> Categories { get; set; } = Array.Empty<GetCategory>();

    [Parameter]
    public string CategoryId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> CategoryIdChanged { get; set; }

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter, EditorRequired]
    public Func<GetProduct, string> InventoryStatusLabel { get; set; } = _ => string.Empty;

    [Parameter, EditorRequired]
    public Func<GetProduct, string> InventoryStatusTone { get; set; } = _ => "neutral";

    [Parameter, EditorRequired]
    public Func<GetProduct, string> PurchaseStatusLabel { get; set; } = _ => string.Empty;

    [Parameter, EditorRequired]
    public Func<GetProduct, string> PurchaseStatusTone { get; set; } = _ => "neutral";

    [Parameter]
    public EventCallback SaveBasic { get; set; }

    private string BoundCategoryId
    {
        get => this.CategoryId;
        set
        {
            if (this.CategoryId == value)
            {
                return;
            }

            this.CategoryId = value;
            _ = this.CategoryIdChanged.InvokeAsync(value);
        }
    }
}

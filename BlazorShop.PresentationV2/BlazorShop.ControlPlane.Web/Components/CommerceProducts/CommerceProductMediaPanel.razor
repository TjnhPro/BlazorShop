<section class="rounded-md border border-ink-200 p-4">
    <h2 class="text-sm font-semibold text-ink-900">Media</h2>
    <textarea class="mt-3 min-h-24 w-full rounded-md border border-ink-300 px-3 py-2 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Image source URLs, one per line" @bind="BoundSourceUrls"></textarea>
    <button class="cp-button cp-button-secondary mt-3 justify-center" disabled="@IsSaving" @onclick="ImportMedia">
        <i class="fa-solid fa-cloud-arrow-down" aria-hidden="true"></i>
        Import URLs
    </button>
    <div class="mt-4 grid gap-3 md:grid-cols-2">
        @foreach (var media in MediaItems.OrderBy(media => media.SortOrder))
        {
            <div class="rounded-md border border-ink-200 p-3">
                <div class="flex gap-3">
                    <div class="h-16 w-16 shrink-0 overflow-hidden rounded-md border border-ink-200 bg-ink-50">
                        @if (PreviewUrls.TryGetValue(media.PublicId, out var previewUrl))
                        {
                            <img src="@previewUrl" alt="@media.AltText" class="h-full w-full object-cover" loading="lazy" />
                        }
                        else
                        {
                            <div class="flex h-full w-full items-center justify-center text-ink-400">
                                <i class="fa-regular fa-image" aria-hidden="true"></i>
                            </div>
                        }
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-center gap-2">
                            <StatusBadge Text="@media.Status" Tone="@MediaTone(media.Status)" />
                            @if (media.IsPrimary)
                            {
                                <StatusBadge Text="Primary" Tone="success" />
                            }
                        </div>
                        <div class="mt-1 truncate text-xs text-ink-500">@media.OriginalSourceUrl</div>
                        @if (!string.IsNullOrWhiteSpace(media.ErrorMessage))
                        {
                            <div class="mt-1 text-xs text-red-600">@media.ErrorMessage</div>
                        }
                    </div>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                    <button class="cp-button cp-button-secondary" disabled="@IsSaving" @onclick="() => SetPrimary.InvokeAsync(media.PublicId)">
                        <i class="fa-solid fa-star" aria-hidden="true"></i>
                        Primary
                    </button>
                    @if (media.Status.Equals("failed", StringComparison.OrdinalIgnoreCase))
                    {
                        <button class="cp-button cp-button-secondary" disabled="@IsSaving" @onclick="() => Retry.InvokeAsync(media.PublicId)">
                            <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                            Retry
                        </button>
                    }
                    <button class="cp-button cp-button-danger" disabled="@IsSaving" @onclick="() => Delete.InvokeAsync(media.PublicId)">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public IReadOnlyCollection<ProductMediaDto> MediaItems { get; set; } = Array.Empty<ProductMediaDto>();

    [Parameter]
    public IReadOnlyDictionary<Guid, string> PreviewUrls { get; set; } = new Dictionary<Guid, string>();

    [Parameter]
    public string? SourceUrls { get; set; }

    [Parameter]
    public EventCallback<string?> SourceUrlsChanged { get; set; }

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter, EditorRequired]
    public Func<string?, string> MediaTone { get; set; } = _ => "neutral";

    [Parameter]
    public EventCallback ImportMedia { get; set; }

    [Parameter]
    public EventCallback<Guid> SetPrimary { get; set; }

    [Parameter]
    public EventCallback<Guid> Retry { get; set; }

    [Parameter]
    public EventCallback<Guid> Delete { get; set; }

    private string? BoundSourceUrls
    {
        get => this.SourceUrls;
        set
        {
            if (this.SourceUrls == value)
            {
                return;
            }

            this.SourceUrls = value;
            _ = this.SourceUrlsChanged.InvokeAsync(value);
        }
    }
}

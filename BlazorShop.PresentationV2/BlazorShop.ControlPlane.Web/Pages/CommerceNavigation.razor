@page "/commerce-admin/navigation"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneNavigationClient NavigationClient

<PageTitle>Storefront Navigation</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Commerce Admin</p>
            <h1 class="text-2xl font-bold text-ink-900">Storefront navigation</h1>
            <p class="mt-1 text-sm text-ink-500">Configure store-scoped menus for header, footer, utility, and mobile placement.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="grid gap-5 lg:grid-cols-[320px_minmax(0,1fr)]">
        <div class="space-y-5">
            <div class="cp-card p-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-sm font-semibold text-ink-900">Menus</h2>
                    <button class="cp-button cp-button-secondary" disabled="@(!HasStore)" @onclick="NewMenu">
                        <i class="fa-solid fa-plus" aria-hidden="true"></i>
                        Menu
                    </button>
                </div>

                @if (!HasStore)
                {
                    <div class="mt-4 text-sm text-ink-500">Select a store to load navigation menus.</div>
                }
                else if (isLoading)
                {
                    <div class="mt-4 text-sm text-ink-500">Loading menus...</div>
                }
                else if (menus.Count == 0)
                {
                    <div class="mt-4 text-sm text-ink-500">No menus have been created for this store.</div>
                }
                else
                {
                    <div class="mt-4 grid gap-2">
                        @foreach (var menu in menus)
                        {
                            <button class="@MenuButtonClass(menu)" @onclick="() => SelectMenuAsync(menu.PublicId)">
                                <span class="min-w-0 text-left">
                                    <span class="block truncate font-semibold">@menu.DisplayName</span>
                                    <span class="block font-mono text-xs text-ink-500">@menu.SystemName</span>
                                </span>
                                <span class="text-xs text-ink-500">@menu.ItemCount</span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="cp-card p-4">
                <h2 class="text-sm font-semibold text-ink-900">@MenuFormTitle</h2>
                <div class="mt-3 grid gap-3 text-sm">
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">System name</span>
                        <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" disabled="@IsEditingMenu" @bind="menuForm.SystemName">
                            @foreach (var systemName in MenuSystemNames)
                            {
                                <option value="@systemName">@systemName</option>
                            }
                        </select>
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Display name</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="menuForm.DisplayName" />
                    </label>
                    <label class="flex items-center gap-2 text-ink-700">
                        <input type="checkbox" @bind="menuForm.IsEnabled" />
                        Enabled
                    </label>
                    <button class="cp-button cp-button-primary justify-center" disabled="@(!HasStore || isSavingMenu)" @onclick="SaveMenuAsync">
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        Save menu
                    </button>
                </div>
            </div>
        </div>

        <div class="cp-card overflow-hidden">
            <div class="flex flex-col gap-3 border-b border-ink-100 p-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-sm font-semibold text-ink-900">@SelectedMenuTitle</h2>
                    <p class="mt-1 text-sm text-ink-500">@SelectedMenuSubtitle</p>
                </div>
                <button class="cp-button cp-button-primary" disabled="@(selectedMenu is null)" @onclick="NewItem">
                    <i class="fa-solid fa-plus" aria-hidden="true"></i>
                    Add item
                </button>
            </div>

            @if (selectedMenu is null)
            {
                <div class="p-8 text-center text-sm text-ink-500">Select or create a menu to edit items.</div>
            }
            else if (FlattenedItems.Count == 0)
            {
                <div class="p-8 text-center text-sm text-ink-500">This menu has no items yet.</div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-ink-100 text-left text-sm">
                        <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                            <tr>
                                <th class="px-4 py-3">Item</th>
                                <th class="px-4 py-3">Target</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3">Order</th>
                                <th class="px-4 py-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-ink-100">
                            @foreach (var row in FlattenedItems)
                            {
                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="font-semibold text-ink-900" style="@IndentStyle(row.Depth)">@row.Item.Label</div>
                                        @if (!string.IsNullOrWhiteSpace(row.Item.ResolvedHref))
                                        {
                                            <div class="mt-1 font-mono text-xs text-ink-500" style="@IndentStyle(row.Depth)">@row.Item.ResolvedHref</div>
                                        }
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="font-mono text-xs text-ink-700">@row.Item.TargetType</div>
                                        <div class="mt-1 text-xs text-ink-500">@FirstNonEmpty(row.Item.TargetKey, row.Item.TargetEntityPublicId?.ToString("D"), row.Item.Url)</div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <StatusBadge Text="@row.Item.TargetStatus" Tone="@TargetTone(row.Item.TargetStatus)" />
                                        @if (!row.Item.IsEnabled)
                                        {
                                            <div class="mt-1"><StatusBadge Text="Disabled" Tone="neutral" /></div>
                                        }
                                    </td>
                                    <td class="px-4 py-3 text-ink-500">@row.Item.DisplayOrder</td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button class="cp-button cp-button-secondary" @onclick="() => EditItem(row.Item)">Edit</button>
                                            <button class="cp-button cp-button-secondary" @onclick="() => ArchiveItemAsync(row.Item.PublicId)">Archive</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

<RightDrawer IsOpen="@isItemDrawerOpen" IsOpenChanged="OnItemDrawerChanged" Title="@ItemFormTitle" Subtitle="@itemForm.TargetType" Eyebrow="Navigation Item">
    <div class="space-y-4">
        <label class="block space-y-1 text-sm">
            <span class="font-medium text-ink-700">Label</span>
            <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.Label" />
        </label>

        <div class="grid gap-3 md:grid-cols-2">
            <label class="space-y-1 text-sm">
                <span class="font-medium text-ink-700">Parent</span>
                <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.ParentItemPublicId">
                    <option value="">Root</option>
                    @foreach (var row in FlattenedItems.Where(row => row.Item.PublicId != itemForm.PublicId))
                    {
                        <option value="@row.Item.PublicId">@($"{new string('-', row.Depth * 2)} {row.Item.Label}")</option>
                    }
                </select>
            </label>
            <label class="space-y-1 text-sm">
                <span class="font-medium text-ink-700">Display order</span>
                <input type="number" class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.DisplayOrder" />
            </label>
        </div>

        <div class="grid gap-3 md:grid-cols-2">
            <label class="space-y-1 text-sm">
                <span class="font-medium text-ink-700">Target type</span>
                <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.TargetType">
                    @foreach (var targetType in TargetTypes)
                    {
                        <option value="@targetType">@targetType</option>
                    }
                </select>
            </label>
            <label class="flex items-center gap-2 pt-7 text-sm text-ink-700">
                <input type="checkbox" @bind="itemForm.IsEnabled" />
                Enabled
            </label>
        </div>

        @if (itemForm.TargetType == StoreNavigationTargetTypes.System || itemForm.TargetType == StoreNavigationTargetTypes.InternalRoute)
        {
            <label class="block space-y-1 text-sm">
                <span class="font-medium text-ink-700">Target key</span>
                <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.TargetKey">
                    @foreach (var target in systemTargets)
                    {
                        <option value="@target.Key">@target.Label (@target.Href)</option>
                    }
                </select>
            </label>
        }
        else if (itemForm.TargetType == StoreNavigationTargetTypes.ExternalUrl)
        {
            <label class="block space-y-1 text-sm">
                <span class="font-medium text-ink-700">HTTPS URL</span>
                <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.Url" />
            </label>
        }
        else if (itemForm.TargetType is StoreNavigationTargetTypes.Category or StoreNavigationTargetTypes.Page or StoreNavigationTargetTypes.Product)
        {
            <label class="block space-y-1 text-sm">
                <span class="font-medium text-ink-700">Target entity public ID</span>
                <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 font-mono text-xs outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="itemForm.TargetEntityPublicIdText" />
            </label>
        }

        <label class="flex items-center gap-2 text-sm text-ink-700">
            <input type="checkbox" @bind="itemForm.OpensInNewTab" />
            Open in new tab
        </label>

        <div class="flex flex-col gap-2 sm:flex-row">
            <button class="cp-button cp-button-primary justify-center" disabled="@isSavingItem" @onclick="SaveItemAsync">
                <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                Save item
            </button>
        </div>
    </div>
</RightDrawer>

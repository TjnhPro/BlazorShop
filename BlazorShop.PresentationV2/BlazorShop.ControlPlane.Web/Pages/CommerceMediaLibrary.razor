@page "/commerce-admin/media-library"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneCatalogClient CatalogClient

<PageTitle>Media Library</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Commerce Admin</p>
            <h1 class="text-2xl font-bold text-ink-900">Media Library</h1>
            <p class="mt-1 text-sm text-ink-500">Manage store-scoped local image links for pages, banners, logos, and icons.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
        </div>
    </div>

    <div class="cp-card p-4">
        <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_140px_auto_auto]">
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search file or display name" @bind="search" @bind:event="oninput" />
            <select class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="pageSize">
                <option value="12">12 items</option>
                <option value="24">24 items</option>
                <option value="48">48 items</option>
            </select>
            <button class="cp-button cp-button-secondary justify-center" disabled="@(!HasStore || isLoading)" @onclick="SearchAsync">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                Search
            </button>
            <label class="cp-button cp-button-primary cursor-pointer justify-center">
                <i class="fa-solid fa-upload" aria-hidden="true"></i>
                Upload
                <InputFile class="hidden" OnChange="UploadAsync" accept="image/jpeg,image/png,image/webp,image/gif,image/x-icon,.ico" />
            </label>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="cp-card overflow-hidden">
        @if (!HasStore)
        {
            <div class="p-8 text-center text-sm text-ink-500">Select a store to load media assets.</div>
        }
        else if (isLoading)
        {
            <div class="p-8 text-center text-sm text-ink-500">Loading media assets...</div>
        }
        else if (assets.Count == 0)
        {
            <div class="p-8 text-center text-sm text-ink-500">No media assets found.</div>
        }
        else
        {
            <div class="grid gap-4 p-4 sm:grid-cols-2 xl:grid-cols-4">
                @foreach (var asset in assets)
                {
                    <button class="rounded-md border border-ink-200 bg-white p-3 text-left hover:border-control-300 hover:bg-control-50" @onclick="() => OpenAsset(asset)">
                        <div class="aspect-[4/3] overflow-hidden rounded-md border border-ink-200 bg-ink-50">
                            @if (previewUrls.TryGetValue(asset.PublicId, out var previewUrl))
                            {
                                <img src="@previewUrl" alt="@asset.AltText" class="h-full w-full object-cover" loading="lazy" />
                            }
                            else
                            {
                                <div class="flex h-full w-full items-center justify-center text-ink-400">
                                    <i class="fa-regular fa-image text-xl" aria-hidden="true"></i>
                                </div>
                            }
                        </div>
                        <div class="mt-3 min-w-0">
                            <div class="truncate text-sm font-semibold text-ink-900">@asset.DisplayName</div>
                            <div class="mt-1 truncate font-mono text-xs text-ink-500">@asset.CanonicalFileName</div>
                            <div class="mt-2 flex items-center justify-between text-xs text-ink-500">
                                <span>@asset.Extension.ToUpperInvariant()</span>
                                <span>@FormatSize(asset.FileSizeBytes)</span>
                            </div>
                        </div>
                    </button>
                }
            </div>
            <div class="flex flex-col gap-3 border-t border-ink-100 px-4 py-3 text-sm text-ink-600 sm:flex-row sm:items-center sm:justify-between">
                <div>Page @pageNumber of @Math.Max(1, totalPages) · @totalCount total</div>
                <div class="flex gap-2">
                    <button class="cp-button cp-button-secondary" disabled="@(pageNumber <= 1 || isLoading)" @onclick="PreviousPageAsync">Previous</button>
                    <button class="cp-button cp-button-secondary" disabled="@(pageNumber >= totalPages || isLoading)" @onclick="NextPageAsync">Next</button>
                </div>
            </div>
        }
    </div>
</section>

<RightDrawer IsOpen="@isDrawerOpen" IsOpenChanged="OnDrawerChanged" Title="@selectedAsset?.DisplayName" Subtitle="@selectedAsset?.CanonicalFileName" Eyebrow="Media Asset">
    @if (selectedAsset is null)
    {
        <div class="text-sm text-ink-500">No media asset selected.</div>
    }
    else
    {
        <div class="space-y-5">
            <div class="overflow-hidden rounded-md border border-ink-200 bg-ink-50">
                @if (previewUrls.TryGetValue(selectedAsset.PublicId, out var previewUrl))
                {
                    <img src="@previewUrl" alt="@selectedAsset.AltText" class="max-h-80 w-full object-contain" loading="lazy" />
                }
            </div>

            <section class="rounded-md border border-ink-200 p-4">
                <h2 class="mb-3 text-sm font-semibold text-ink-900">Metadata</h2>
                <div class="grid gap-3 text-sm">
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Display name</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="metadataForm.DisplayName" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Alt text</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="metadataForm.AltText" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Title text</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="metadataForm.TitleText" />
                    </label>
                </div>
                <div class="mt-4 flex flex-wrap gap-2">
                    <button class="cp-button cp-button-primary" disabled="@isSaving" @onclick="SaveMetadataAsync">
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        Save
                    </button>
                    <label class="cp-button cp-button-secondary cursor-pointer">
                        <i class="fa-solid fa-repeat" aria-hidden="true"></i>
                        Replace
                        <InputFile class="hidden" OnChange="ReplaceAsync" accept="image/jpeg,image/png,image/webp,image/gif,image/x-icon,.ico" />
                    </label>
                    <button class="cp-button cp-button-danger" disabled="@isSaving" @onclick="DeleteAsync">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        Delete
                    </button>
                </div>
            </section>

            <section class="rounded-md border border-ink-200 p-4">
                <h2 class="mb-3 text-sm font-semibold text-ink-900">Link generator</h2>
                <div class="grid gap-3 text-sm md:grid-cols-2">
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Width</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="1" max="4096" @bind="generator.Width" @bind:event="oninput" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Height</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" min="1" max="4096" @bind="generator.Height" @bind:event="oninput" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Fit</span>
                        <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="generator.Fit">
                            <option value="inside">Inside</option>
                            <option value="cover">Cover</option>
                            <option value="contain">Contain</option>
                        </select>
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Format</span>
                        <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="generator.Format">
                            <option value="original">Original</option>
                            <option value="webp">WebP</option>
                            <option value="jpg">JPG</option>
                            <option value="png">PNG</option>
                        </select>
                    </label>
                </div>
                <div class="mt-4 rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="flex items-start gap-2">
                        <code class="min-w-0 flex-1 break-all text-xs text-ink-700">@GeneratedUrl</code>
                        <CopyButton Text="@GeneratedUrl" />
                    </div>
                </div>
                <div class="mt-3 rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="flex items-start gap-2">
                        <code class="min-w-0 flex-1 break-all text-xs text-ink-700">@GeneratedImageSnippet</code>
                        <CopyButton Text="@GeneratedImageSnippet" />
                    </div>
                </div>
            </section>
        </div>
    }
</RightDrawer>

@code {
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private readonly List<StoreSummary> stores = [];
    private readonly List<CommerceMediaAssetDto> assets = [];
    private readonly Dictionary<Guid, string> previewUrls = [];
    private Guid? selectedStorePublicId;
    private CommerceMediaAssetDto? selectedAsset;
    private MetadataForm metadataForm = new();
    private GeneratorForm generator = new();
    private string? search;
    private int pageNumber = 1;
    private int pageSize = 24;
    private int totalCount;
    private int totalPages;
    private bool isLoading;
    private bool isSaving;
    private bool isDrawerOpen;
    private string? errorMessage;
    private string? successMessage;

    private bool HasStore => selectedStorePublicId.HasValue && selectedStorePublicId.Value != Guid.Empty;

    private string GeneratedUrl => selectedAsset is null ? string.Empty : BuildGeneratedUrl(selectedAsset);

    private string GeneratedImageSnippet => selectedAsset is null ? string.Empty : BuildGeneratedSnippet(selectedAsset);

    protected override async Task OnInitializedAsync()
    {
        var response = await StoreClient.ListAsync(status: "active", pageSize: 100);
        stores.AddRange(response.Items);
        selectedStorePublicId = stores.FirstOrDefault()?.PublicId;
        await LoadAsync();
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (!HasStore)
        {
            return;
        }

        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await CatalogClient.ListMediaAssetsAsync(
                selectedStorePublicId!.Value,
                new CommerceMediaAssetListQuery(pageNumber, pageSize, search));
            if (!result.Success || result.Data is null)
            {
                errorMessage = result.Message;
                return;
            }

            assets.Clear();
            assets.AddRange(result.Data.Items);
            totalCount = result.Data.TotalCount;
            totalPages = result.Data.TotalPages;
            pageNumber = result.Data.PageNumber;
            pageSize = result.Data.PageSize;
            await LoadPreviewsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPreviewsAsync()
    {
        previewUrls.Clear();
        foreach (var asset in assets)
        {
            var query = CanTransform(asset)
                ? new MediaAssetPreviewQuery(240, 180, "cover", "webp", asset.Version)
                : new MediaAssetPreviewQuery(Version: asset.Version);
            var preview = await CatalogClient.GetMediaAssetPreviewAsync(
                selectedStorePublicId!.Value,
                asset.PublicId,
                asset.CanonicalFileName,
                query);

            if (preview.Success && preview.Content is { Length: > 0 })
            {
                previewUrls[asset.PublicId] = ToDataUrl(preview);
            }
        }
    }

    private async Task UploadAsync(InputFileChangeEventArgs args)
    {
        if (!HasStore || args.File is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            await using var stream = args.File.OpenReadStream(MaxUploadBytes);
            var result = await CatalogClient.UploadMediaAssetAsync(
                selectedStorePublicId!.Value,
                stream,
                args.File.Name,
                args.File.ContentType);
            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Media asset uploaded.";
            await LoadAsync();
            if (result.Data is not null)
            {
                OpenAsset(result.Data);
            }
        }
        catch (IOException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ReplaceAsync(InputFileChangeEventArgs args)
    {
        if (!HasStore || selectedAsset is null || args.File is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            await using var stream = args.File.OpenReadStream(MaxUploadBytes);
            var result = await CatalogClient.ReplaceMediaAssetAsync(
                selectedStorePublicId!.Value,
                selectedAsset.PublicId,
                stream,
                args.File.Name,
                args.File.ContentType);
            if (!result.Success || result.Data is null)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Media asset replaced.";
            await LoadAsync();
            OpenAsset(result.Data, resetGenerator: false);
        }
        catch (IOException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OpenAsset(CommerceMediaAssetDto asset, bool resetGenerator = true)
    {
        selectedAsset = asset;
        metadataForm = MetadataForm.From(asset);
        if (resetGenerator)
        {
            generator = new GeneratorForm();
        }

        isDrawerOpen = true;
    }

    private async Task SaveMetadataAsync()
    {
        if (!HasStore || selectedAsset is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            var result = await CatalogClient.UpdateMediaAssetMetadataAsync(
                selectedStorePublicId!.Value,
                selectedAsset.PublicId,
                new CommerceMediaAssetMetadataRequest(metadataForm.DisplayName, metadataForm.AltText, metadataForm.TitleText));
            if (!result.Success || result.Data is null)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Media asset saved.";
            await LoadAsync();
            OpenAsset(result.Data, resetGenerator: false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (!HasStore || selectedAsset is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            var result = await CatalogClient.DeleteMediaAssetAsync(selectedStorePublicId!.Value, selectedAsset.PublicId);
            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Media asset deleted.";
            selectedAsset = null;
            isDrawerOpen = false;
            await LoadAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        pageNumber = Math.Max(1, pageNumber - 1);
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        pageNumber++;
        await LoadAsync();
    }

    private Task OnDrawerChanged(bool value)
    {
        isDrawerOpen = value;
        return Task.CompletedTask;
    }

    private string BuildGeneratedUrl(CommerceMediaAssetDto asset)
    {
        var values = new List<string>();
        if (generator.Width is > 0)
        {
            values.Add("w=" + generator.Width.Value);
        }

        if (generator.Height is > 0)
        {
            values.Add("h=" + generator.Height.Value);
        }

        if (!string.IsNullOrWhiteSpace(generator.Fit))
        {
            values.Add("fit=" + Uri.EscapeDataString(generator.Fit));
        }

        if (!string.IsNullOrWhiteSpace(generator.Format))
        {
            values.Add("format=" + Uri.EscapeDataString(generator.Format));
        }

        values.Add("v=" + asset.Version);
        return asset.PublicUrl + "?" + string.Join("&", values);
    }

    private string BuildGeneratedSnippet(CommerceMediaAssetDto asset)
    {
        var url = System.Net.WebUtility.HtmlEncode(BuildGeneratedUrl(asset));
        var alt = System.Net.WebUtility.HtmlEncode(asset.AltText);
        var title = string.IsNullOrWhiteSpace(asset.TitleText)
            ? string.Empty
            : $" title=\"{System.Net.WebUtility.HtmlEncode(asset.TitleText)}\"";
        var width = generator.Width is > 0 ? $" width=\"{generator.Width.Value}\"" : string.Empty;
        var height = generator.Height is > 0 ? $" height=\"{generator.Height.Value}\"" : string.Empty;
        return $"<img src=\"{url}\" alt=\"{alt}\"{title}{width}{height} loading=\"lazy\">";
    }

    private static bool CanTransform(CommerceMediaAssetDto asset)
    {
        return !asset.Extension.Equals("gif", StringComparison.OrdinalIgnoreCase)
            && !asset.Extension.Equals("ico", StringComparison.OrdinalIgnoreCase);
    }

    private static string ToDataUrl(ControlPlaneFileResult result)
    {
        return $"data:{result.ContentType ?? "image/webp"};base64,{Convert.ToBase64String(result.Content ?? [])}";
    }

    private static string FormatSize(long bytes)
    {
        return bytes >= 1024 * 1024
            ? (bytes / 1024d / 1024d).ToString("0.0") + " MB"
            : (bytes / 1024d).ToString("0.0") + " KB";
    }

    private sealed class MetadataForm
    {
        public string? DisplayName { get; set; }

        public string? AltText { get; set; }

        public string? TitleText { get; set; }

        public static MetadataForm From(CommerceMediaAssetDto asset)
        {
            return new MetadataForm
            {
                DisplayName = asset.DisplayName,
                AltText = asset.AltText,
                TitleText = asset.TitleText,
            };
        }
    }

    private sealed class GeneratorForm
    {
        public int? Width { get; set; }

        public int? Height { get; set; }

        public string Fit { get; set; } = "inside";

        public string Format { get; set; } = "webp";
    }
}

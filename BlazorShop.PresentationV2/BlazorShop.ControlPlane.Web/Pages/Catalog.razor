@page "/catalog"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Catalog</PageTitle>

<div class="p-8 text-sm text-ink-500">Redirecting to Commerce Admin products...</div>

@code {
    protected override void OnInitialized()
    {
        Navigation.NavigateTo("commerce-admin/products", replace: true);
    }
}

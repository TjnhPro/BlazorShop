    private IReadOnlyList<ProductVariantAttributeDto> BuildVariantAttributes()
    {
        var attributes = new List<ProductVariantAttributeDto>();
        AddVariantAttribute(attributes, variantAttributeName1, variantAttributeValue1);
        AddVariantAttribute(attributes, variantAttributeName2, variantAttributeValue2);
        return attributes;
    }

    private static void AddVariantAttribute(List<ProductVariantAttributeDto> attributes, string? name, string? value)
    {
        if (!string.IsNullOrWhiteSpace(name) && !string.IsNullOrWhiteSpace(value))
        {
            attributes.Add(new ProductVariantAttributeDto { Name = name.Trim(), Value = value.Trim() });
        }
    }

    private async Task CompleteMutationAsync<TData>(ControlPlaneClientResult<TData> result)
    {
        if (result.Success)
        {
            successMessage = string.IsNullOrWhiteSpace(result.Message) ? "Catalog updated." : result.Message;
        }
        else
        {
            errorMessage = result.Message;
        }

        await Task.CompletedTask;
    }

    private void ClearMessages()
    {
        errorMessage = null;
        successMessage = null;
    }

    private void SetProductStockInput(Guid productId, string? value)
    {
        productStockInputs[productId] = int.TryParse(value, out var parsed) ? parsed : 0;
    }

    private void SetVariantStockInput(Guid variantId, string? value)
    {
        variantStockInputs[variantId] = int.TryParse(value, out var parsed) ? parsed : 0;
    }

    private int GetProductStockInput(AdminInventoryItemDto item)
    {
        return productStockInputs.TryGetValue(item.ProductId, out var value) ? value : item.Quantity;
    }

    private int GetVariantStockInput(AdminInventoryVariantDto variant)
    {
        return variantStockInputs.TryGetValue(variant.VariantId, out var value) ? value : variant.Stock;
    }

    private string GetTabClass(string tab)
    {
        return activeTab == tab
            ? "cp-button cp-button-primary"
            : "cp-button cp-button-secondary";
    }

    private static CreateProduct NewProductForm()
    {
        return new CreateProduct
        {
            Description = string.Empty,
            Image = string.Empty,
            Price = 0,
            Quantity = 0,
        };
    }

    private static string GetVariantName(GetProductVariant variant)
    {
        if (!string.IsNullOrWhiteSpace(variant.DisplayName))
        {
            return variant.DisplayName;
        }

        return string.Join(" / ", variant.Attributes.Select(attribute => attribute.Value));
    }

    private static string GetInventoryVariantName(AdminInventoryVariantDto variant)
    {
        if (!string.IsNullOrWhiteSpace(variant.DisplayName))
        {
            return variant.DisplayName;
        }

        var values = string.Join(" / ", variant.Attributes.Select(attribute => attribute.Value));
        return string.IsNullOrWhiteSpace(values) ? variant.SizeValue : values;
    }

    private RenderFragment RenderCategoryNode(GetCategoryTreeNode category, int depth) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "space-y-2");
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "class", "flex w-full items-center justify-between rounded-md border border-ink-200 bg-white px-3 py-2 text-left text-sm hover:bg-ink-50");
        builder.AddAttribute(sequence++, "style", $"margin-left:{depth * 18}px");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => SelectCategory(category)));
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "font-medium text-ink-900");
        builder.AddContent(sequence++, category.Name);
        builder.CloseElement();
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "text-xs text-ink-500");
        builder.AddContent(sequence++, $"Order {category.DisplayOrder}");
        builder.CloseElement();
        builder.CloseElement();
        foreach (var child in category.Children)
        {
            builder.AddContent(sequence++, RenderCategoryNode(child, depth + 1));
        }
        builder.CloseElement();
    };
}

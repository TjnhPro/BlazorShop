@page "/catalog"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneCatalogClient CatalogClient

<PageTitle>Catalog</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Catalog</p>
            <h1 class="text-2xl font-bold text-ink-900">Commerce catalog</h1>
            <p class="mt-1 text-sm text-ink-500">Manage store-scoped products, categories, variants, and stock through Control Plane.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadCatalogAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="flex flex-wrap gap-2">
        <button class="@GetTabClass("products")" @onclick="@(() => activeTab = "products")">
            <i class="fa-solid fa-box-open" aria-hidden="true"></i>
            Products
        </button>
        <button class="@GetTabClass("categories")" @onclick="@(() => activeTab = "categories")">
            <i class="fa-solid fa-sitemap" aria-hidden="true"></i>
            Categories
        </button>
        <button class="@GetTabClass("inventory")" @onclick="@(() => activeTab = "inventory")">
            <i class="fa-solid fa-warehouse" aria-hidden="true"></i>
            Inventory
        </button>
    </div>

    @if (CurrentStoreId is null)
    {
        <div class="cp-card p-8 text-center">
            <i class="fa-solid fa-store mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
            <p class="text-sm font-semibold text-ink-700">Select a store</p>
            <p class="mt-1 text-sm text-ink-500">Catalog calls are routed through the assigned Commerce Node and scoped by store key.</p>
        </div>
    }
    else if (activeTab == "products")
    {
        <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_420px]">
            <div class="space-y-5">
                <div class="cp-card overflow-hidden">
                    <div class="grid gap-3 border-b border-ink-200 p-4 md:grid-cols-[minmax(0,1fr)_180px_150px_150px_auto]">
                        <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search name or SKU" @bind="productSearch" />
                        <select class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="productCategoryId">
                            <option value="">All categories</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <select class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="productSortBy">
                            <option value="@ProductCatalogSortBy.Newest">Newest</option>
                            <option value="@ProductCatalogSortBy.DisplayOrder">Display order</option>
                            <option value="@ProductCatalogSortBy.Updated">Updated</option>
                            <option value="@ProductCatalogSortBy.PriceLowToHigh">Price low</option>
                            <option value="@ProductCatalogSortBy.PriceHighToLow">Price high</option>
                        </select>
                        <button class="cp-button cp-button-secondary" @onclick="LoadProductsAsync">
                            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                            Search
                        </button>
                    </div>
                    <div class="grid gap-3 border-b border-ink-200 p-4 md:grid-cols-[140px_140px_140px_auto]">
                        <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" placeholder="Min price" @bind="minPrice" />
                        <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" placeholder="Max price" @bind="maxPrice" />
                        <label class="flex min-h-10 items-center gap-2 rounded-md border border-ink-300 px-3 text-sm text-ink-700">
                            <input type="checkbox" @bind="inStockOnly" />
                            In stock
                        </label>
                        <button class="cp-button cp-button-primary justify-center" @onclick="NewProduct">
                            <i class="fa-solid fa-plus" aria-hidden="true"></i>
                            New product
                        </button>
                    </div>

                    @if (isLoadingProducts)
                    {
                        <div class="p-8 text-center text-sm text-ink-500">Loading products...</div>
                    }
                    else if (products.Count == 0)
                    {
                        <div class="p-8 text-center text-sm text-ink-500">No products found.</div>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                                <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                                    <tr>
                                        <th class="px-4 py-3">Product</th>
                                        <th class="px-4 py-3">SKU</th>
                                        <th class="px-4 py-3">Category</th>
                                        <th class="px-4 py-3 text-right">Price</th>
                                        <th class="px-4 py-3 text-right">Stock</th>
                                        <th class="px-4 py-3">Updated</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-ink-100">
                                    @foreach (var product in products)
                                    {
                                        <tr class="cursor-pointer hover:bg-ink-50" @onclick="() => SelectProductAsync(product.Id)">
                                            <td class="px-4 py-3">
                                                <div class="font-semibold text-ink-900">@product.Name</div>
                                                <div class="text-xs text-ink-500">@product.ShortDescription</div>
                                            </td>
                                            <td class="px-4 py-3 text-ink-600">@product.Sku</td>
                                            <td class="px-4 py-3 text-ink-600">@product.CategoryName</td>
                                            <td class="px-4 py-3 text-right text-ink-700">
                                                @product.Price.ToString("0.00")
                                                @if (product.ComparePrice is not null)
                                                {
                                                    <span class="ml-1 text-xs text-ink-400 line-through">@product.ComparePrice.Value.ToString("0.00")</span>
                                                }
                                            </td>
                                            <td class="px-4 py-3 text-right">
                                                <span class="@(product.InStock ? "text-emerald-700" : "text-red-700")">@(product.InStock ? "In stock" : "Out")</span>
                                            </td>
                                            <td class="px-4 py-3 text-ink-500">@product.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <aside class="space-y-5">
                <div class="cp-card">
                    <div class="border-b border-ink-200 p-4">
                        <h2 class="text-sm font-semibold text-ink-900">@(editingProductId is null ? "Create product" : "Edit product")</h2>
                    </div>
                    <div class="grid gap-3 p-4 text-sm">
                        <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Name" @bind="productForm.Name" />
                        <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="SKU" @bind="productForm.Sku" />
                        <select class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="productForm.CategoryId">
                            <option value="@Guid.Empty">Select category</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <textarea class="min-h-20 rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Short description" @bind="productForm.ShortDescription"></textarea>
                        <textarea class="min-h-28 rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Full description" @bind="productForm.FullDescription"></textarea>
                        <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Image URL" @bind="productForm.Image" />
                        <div class="grid grid-cols-2 gap-3">
                            <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" placeholder="Price" @bind="productForm.Price" />
                            <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" placeholder="Compare" @bind="productForm.ComparePrice" />
                            <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" placeholder="Quantity" @bind="productForm.Quantity" />
                            <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" placeholder="Display" @bind="productForm.DisplayOrder" />
                        </div>
                    </div>
                    <div class="flex gap-2 border-t border-ink-200 p-4">
                        <button class="cp-button cp-button-primary flex-1 justify-center" disabled="@isSaving" @onclick="SaveProductAsync">
                            <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                            Save
                        </button>
                        @if (editingProductId is not null)
                        {
                            <button class="cp-button cp-button-danger" disabled="@isSaving" @onclick="ArchiveProductAsync">
                                <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
                            </button>
                        }
                    </div>
                </div>

                @if (editingProductId is not null)
                {
                    <div class="cp-card">
                        <div class="border-b border-ink-200 p-4">
                            <h2 class="text-sm font-semibold text-ink-900">Variants</h2>
                        </div>
                        <div class="space-y-3 p-4">
                            @foreach (var variant in variants)
                            {
                                <button class="w-full rounded-md border border-ink-200 p-3 text-left hover:bg-ink-50" @onclick="() => SelectVariant(variant)">
                                    <div class="flex items-center justify-between gap-2">
                                        <span class="font-medium text-ink-900">@GetVariantName(variant)</span>
                                        <span class="text-xs text-ink-500">Stock @variant.Stock</span>
                                    </div>
                                    <div class="mt-1 text-xs text-ink-500">@variant.Sku</div>
                                </button>
                            }
                            <div class="grid gap-2 rounded-md border border-ink-200 p-3 text-sm">
                                <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Variant SKU" @bind="variantSku" />
                                <div class="grid grid-cols-2 gap-2">
                                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Attribute name" @bind="variantAttributeName1" />
                                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Value" @bind="variantAttributeValue1" />
                                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Attribute name" @bind="variantAttributeName2" />
                                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Value" @bind="variantAttributeValue2" />
                                </div>
                                <div class="grid grid-cols-2 gap-2">
                                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" step="0.01" placeholder="Price override" @bind="variantPrice" />
                                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" placeholder="Stock" @bind="variantStock" />
                                </div>
                                <label class="flex items-center gap-2 text-ink-700">
                                    <input type="checkbox" @bind="variantIsDefault" />
                                    Default variant
                                </label>
                                <div class="flex gap-2">
                                    <button class="cp-button cp-button-secondary flex-1 justify-center" disabled="@isSaving" @onclick="SaveVariantAsync">Save variant</button>
                                    <button class="cp-button cp-button-secondary" @onclick="NewVariant">New</button>
                                    @if (editingVariantId is not null)
                                    {
                                        <button class="cp-button cp-button-danger" disabled="@isSaving" @onclick="DeleteVariantAsync">
                                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </aside>
        </div>
    }
    else if (activeTab == "categories")
    {
        <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_420px]">
            <div class="cp-card p-4">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-sm font-semibold text-ink-900">Category tree</h2>
                    <button class="cp-button cp-button-secondary" @onclick="NewCategory">
                        <i class="fa-solid fa-plus" aria-hidden="true"></i>
                        New
                    </button>
                </div>
                @if (categoryTree.Count == 0)
                {
                    <div class="rounded-md border border-ink-200 p-6 text-center text-sm text-ink-500">No categories found.</div>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var category in categoryTree)
                        {
                            @RenderCategoryNode(category, 0)
                        }
                    </div>
                }
            </div>
            <aside class="cp-card">
                <div class="border-b border-ink-200 p-4">
                    <h2 class="text-sm font-semibold text-ink-900">@(editingCategoryId is null ? "Create category" : "Edit category")</h2>
                </div>
                <div class="grid gap-3 p-4 text-sm">
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Name" @bind="categoryForm.Name" />
                    <select class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="categoryParentId">
                        <option value="">No parent</option>
                        @foreach (var category in categories.Where(category => category.Id != editingCategoryId))
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Image URL" @bind="categoryForm.Image" />
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" placeholder="Display order" @bind="categoryForm.DisplayOrder" />
                </div>
                <div class="flex gap-2 border-t border-ink-200 p-4">
                    <button class="cp-button cp-button-primary flex-1 justify-center" disabled="@isSaving" @onclick="SaveCategoryAsync">
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        Save
                    </button>
                    @if (editingCategoryId is not null)
                    {
                        <button class="cp-button cp-button-danger" disabled="@isSaving" @onclick="ArchiveCategoryAsync">
                            <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
                        </button>
                    }
                </div>
            </aside>
        </div>
    }
    else
    {
        <div class="cp-card overflow-hidden">
            <div class="grid gap-3 border-b border-ink-200 p-4 md:grid-cols-[minmax(0,1fr)_150px_150px_auto]">
                <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search inventory" @bind="inventorySearch" />
                <label class="flex min-h-10 items-center gap-2 rounded-md border border-ink-300 px-3 text-sm text-ink-700">
                    <input type="checkbox" @bind="lowStockOnly" />
                    Low stock
                </label>
                <label class="flex min-h-10 items-center gap-2 rounded-md border border-ink-300 px-3 text-sm text-ink-700">
                    <input type="checkbox" @bind="outOfStockOnly" />
                    Out
                </label>
                <button class="cp-button cp-button-secondary" @onclick="LoadInventoryAsync">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    Search
                </button>
            </div>
            @if (inventory.Count == 0)
            {
                <div class="p-8 text-center text-sm text-ink-500">No inventory rows found.</div>
            }
            else
            {
                <div class="divide-y divide-ink-100">
                    @foreach (var item in inventory)
                    {
                        <div class="p-4">
                            <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_120px_auto] lg:items-center">
                                <div>
                                    <div class="font-semibold text-ink-900">@item.ProductName</div>
                                    <div class="text-xs text-ink-500">@item.CategoryName</div>
                                </div>
                                <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" value="@GetProductStockInput(item)" @onchange="eventArgs => SetProductStockInput(item.ProductId, eventArgs.Value?.ToString())" />
                                <button class="cp-button cp-button-secondary justify-center" disabled="@isSaving" @onclick="() => UpdateProductStockAsync(item.ProductId)">Update product stock</button>
                            </div>
                            @if (item.Variants.Count > 0)
                            {
                                <div class="mt-3 grid gap-2">
                                    @foreach (var variant in item.Variants)
                                    {
                                        <div class="grid gap-2 rounded-md border border-ink-200 p-3 lg:grid-cols-[minmax(0,1fr)_120px_auto] lg:items-center">
                                            <div>
                                                <div class="text-sm font-medium text-ink-800">@GetInventoryVariantName(variant)</div>
                                                <div class="text-xs text-ink-500">@variant.Sku</div>
                                            </div>
                                            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" value="@GetVariantStockInput(variant)" @onchange="eventArgs => SetVariantStockInput(variant.VariantId, eventArgs.Value?.ToString())" />
                                            <button class="cp-button cp-button-secondary justify-center" disabled="@isSaving" @onclick="() => UpdateVariantStockAsync(variant.VariantId)">Update variant stock</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</section>

@code {
    private readonly List<StoreSummary> stores = [];
    private readonly List<GetCatalogProduct> products = [];
    private readonly List<GetCategory> categories = [];
    private readonly List<GetCategoryTreeNode> categoryTree = [];
    private readonly List<GetProductVariant> variants = [];
    private readonly List<AdminInventoryItemDto> inventory = [];
    private readonly Dictionary<Guid, int> productStockInputs = [];
    private readonly Dictionary<Guid, int> variantStockInputs = [];

    private string selectedStorePublicId = string.Empty;
    private string activeTab = "products";
    private string? errorMessage;
    private string? successMessage;
    private bool isLoadingProducts;
    private bool isSaving;

    private string? productSearch;
    private string productCategoryId = string.Empty;
    private ProductCatalogSortBy productSortBy = ProductCatalogSortBy.DisplayOrder;
    private decimal? minPrice;
    private decimal? maxPrice;
    private bool inStockOnly;

    private Guid? editingProductId;
    private CreateProduct productForm = NewProductForm();

    private Guid? editingVariantId;
    private string? variantSku;
    private string? variantAttributeName1 = "Color";
    private string? variantAttributeValue1;
    private string? variantAttributeName2 = "Size";
    private string? variantAttributeValue2;
    private decimal? variantPrice;
    private int variantStock;
    private bool variantIsDefault;

    private Guid? editingCategoryId;
    private CreateCategory categoryForm = new();
    private string categoryParentId = string.Empty;

    private string? inventorySearch;
    private bool lowStockOnly;
    private bool outOfStockOnly;

    private Guid? CurrentStoreId => Guid.TryParse(selectedStorePublicId, out var value) ? value : null;

    protected override async Task OnInitializedAsync()
    {
        await LoadStoresAsync();
        if (stores.Count > 0)
        {
            selectedStorePublicId = stores[0].PublicId.ToString("D");
            await LoadCatalogAsync();
        }
    }

    private async Task LoadStoresAsync()
    {
        try
        {
            var response = await StoreClient.ListAsync();
            stores.Clear();
            stores.AddRange(response.Items.Where(store => store.Status == "active"));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task LoadCatalogAsync()
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        ClearMessages();
        await LoadCategoriesAsync();
        await LoadProductsAsync();
        await LoadInventoryAsync();
    }

    private async Task LoadProductsAsync()
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        isLoadingProducts = true;
        ClearMessages();

        var result = await CatalogClient.QueryProductsAsync(
            CurrentStoreId.Value,
            new ProductCatalogQuery
            {
                PageNumber = 1,
                PageSize = 50,
                SearchTerm = productSearch,
                CategoryId = Guid.TryParse(productCategoryId, out var categoryId) ? categoryId : null,
                MinPrice = minPrice,
                MaxPrice = maxPrice,
                InStock = inStockOnly ? true : null,
                SortBy = productSortBy,
            });

        isLoadingProducts = false;
        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        products.Clear();
        products.AddRange(result.Data?.Items ?? []);
    }

    private async Task LoadCategoriesAsync()
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        var categoryResult = await CatalogClient.ListCategoriesAsync(CurrentStoreId.Value);
        if (!categoryResult.Success)
        {
            errorMessage = categoryResult.Message;
            return;
        }

        categories.Clear();
        categories.AddRange(categoryResult.Data ?? []);

        var treeResult = await CatalogClient.GetCategoryTreeAsync(CurrentStoreId.Value);
        if (!treeResult.Success)
        {
            errorMessage = treeResult.Message;
            return;
        }

        categoryTree.Clear();
        categoryTree.AddRange(treeResult.Data ?? []);
    }

    private async Task LoadInventoryAsync()
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        var result = await CatalogClient.QueryInventoryAsync(
            CurrentStoreId.Value,
            new AdminInventoryQueryDto
            {
                SearchTerm = inventorySearch,
                LowStockOnly = lowStockOnly,
                OutOfStockOnly = outOfStockOnly,
                PageNumber = 1,
                PageSize = 50,
            });

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        inventory.Clear();
        inventory.AddRange(result.Data?.Items ?? []);
        foreach (var item in inventory)
        {
            productStockInputs[item.ProductId] = item.Quantity;
            foreach (var variant in item.Variants)
            {
                variantStockInputs[variant.VariantId] = variant.Stock;
            }
        }
    }

    private async Task SelectProductAsync(Guid productId)
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        ClearMessages();
        var result = await CatalogClient.GetProductAsync(CurrentStoreId.Value, productId);
        if (!result.Success || result.Data is null)
        {
            errorMessage = result.Message;
            return;
        }

        editingProductId = result.Data.Id;
        productForm = new CreateProduct
        {
            Name = result.Data.Name,
            Description = result.Data.Description,
            Sku = result.Data.Sku,
            ShortDescription = result.Data.ShortDescription,
            FullDescription = result.Data.FullDescription,
            Price = result.Data.Price,
            ComparePrice = result.Data.ComparePrice,
            Image = result.Data.Image,
            Quantity = result.Data.Quantity,
            DisplayOrder = result.Data.DisplayOrder,
            CategoryId = result.Data.CategoryId,
        };

        await LoadVariantsAsync(productId);
    }

    private async Task LoadVariantsAsync(Guid productId)
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        var result = await CatalogClient.ListVariantsAsync(CurrentStoreId.Value, productId);
        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        variants.Clear();
        variants.AddRange(result.Data ?? []);
        NewVariant();
    }

    private void NewProduct()
    {
        editingProductId = null;
        variants.Clear();
        productForm = NewProductForm();
    }

    private async Task SaveProductAsync()
    {
        if (CurrentStoreId is null)
        {
            return;
        }

        isSaving = true;
        ClearMessages();
        productForm.Description = string.IsNullOrWhiteSpace(productForm.Description)
            ? productForm.ShortDescription ?? productForm.FullDescription ?? productForm.Name
            : productForm.Description;

        var result = editingProductId is null
            ? await CatalogClient.CreateProductAsync(CurrentStoreId.Value, productForm)
            : await CatalogClient.UpdateProductAsync(
                CurrentStoreId.Value,
                editingProductId.Value,
                new UpdateProduct
                {
                    Id = editingProductId.Value,
                    Name = productForm.Name,
                    Description = productForm.Description,
                    Sku = productForm.Sku,
                    ShortDescription = productForm.ShortDescription,
                    FullDescription = productForm.FullDescription,
                    Price = productForm.Price,
                    ComparePrice = productForm.ComparePrice,
                    Image = productForm.Image,
                    Quantity = productForm.Quantity,
                    DisplayOrder = productForm.DisplayOrder,
                    CategoryId = productForm.CategoryId,
                });

        isSaving = false;
        await CompleteMutationAsync(result);
        await LoadProductsAsync();
        await LoadInventoryAsync();
    }

    private async Task ArchiveProductAsync()
    {
        if (CurrentStoreId is null || editingProductId is null)
        {
            return;

    }

    private void NewVariant()
    {
        editingVariantId = null;
        variantSku = null;
        variantAttributeName1 = "Color";
        variantAttributeValue1 = null;
        variantAttributeName2 = "Size";
        variantAttributeValue2 = null;
        variantPrice = null;
        variantStock = 0;
        variantIsDefault = variants.Count == 0;
    }

    private void SelectVariant(GetProductVariant variant)
    {
        editingVariantId = variant.Id;
        variantSku = variant.Sku;
        variantPrice = variant.Price;
        variantStock = variant.Stock;
        variantIsDefault = variant.IsDefault;
        variantAttributeName1 = variant.Attributes.ElementAtOrDefault(0)?.Name ?? "Color";
        variantAttributeValue1 = variant.Attributes.ElementAtOrDefault(0)?.Value;
        variantAttributeName2 = variant.Attributes.ElementAtOrDefault(1)?.Name ?? "Size";
        variantAttributeValue2 = variant.Attributes.ElementAtOrDefault(1)?.Value;
    }

    private async Task SaveVariantAsync()
    {
        if (CurrentStoreId is null || editingProductId is null)
        {
            return;
        }

        var attributes = BuildVariantAttributes();
        var firstValue = attributes.FirstOrDefault()?.Value ?? string.Empty;
        isSaving = true;
        ClearMessages();

        var result = editingVariantId is null
            ? await CatalogClient.CreateVariantAsync(
                CurrentStoreId.Value,
                editingProductId.Value,
                new CreateProductVariant
                {
                    ProductId = editingProductId.Value,
                    Sku = variantSku,
                    Attributes = attributes,
                    SizeScale = 0,
                    SizeValue = firstValue,
                    Price = variantPrice,
                    Stock = variantStock,
                    Color = attributes.FirstOrDefault(attribute => attribute.Name.Equals("Color", StringComparison.OrdinalIgnoreCase))?.Value,
                    IsDefault = variantIsDefault,
                })
            : await CatalogClient.UpdateVariantAsync(
                CurrentStoreId.Value,
                editingProductId.Value,
                editingVariantId.Value,
                new UpdateProductVariant
                {
                    Id = editingVariantId.Value,
                    ProductId = editingProductId.Value,
                    Sku = variantSku,
                    Attributes = attributes,
                    SizeScale = 0,
                    SizeValue = firstValue,
                    Price = variantPrice,
                    Stock = variantStock,
                    Color = attributes.FirstOrDefault(attribute => attribute.Name.Equals("Color", StringComparison.OrdinalIgnoreCase))?.Value,
                    IsDefault = variantIsDefault,
                });

        isSaving = false;
        await CompleteMutationAsync(result);
        await LoadVariantsAsync(editingProductId.Value);
        await LoadProductsAsync();
        await LoadInventoryAsync();
    }

    private async Task DeleteVariantAsync()
    {
        if (CurrentStoreId is null || editingProductId is null || editingVariantId is null)
        {
            return;

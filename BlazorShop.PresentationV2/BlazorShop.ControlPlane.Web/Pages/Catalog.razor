        isSaving = true;
        ClearMessages();
        var result = await CatalogClient.DeleteVariantAsync(CurrentStoreId.Value, editingProductId.Value, editingVariantId.Value);
        isSaving = false;
        await CompleteMutationAsync(result);
        await LoadVariantsAsync(editingProductId.Value);
        await LoadProductsAsync();
        await LoadInventoryAsync();
    }


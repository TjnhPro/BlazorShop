@page "/commerce-admin/orders"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneOrderClient OrderClient

<PageTitle>Orders</PageTitle>

<section class="space-y-5">
    <ControlPlanePageHeader Eyebrow="Commerce Admin"
                            Title="Orders"
                            Description="Inspect orders and maintain a simple one-shipment record per order."
                            LayoutClass="lg:flex-row lg:items-end lg:justify-between">
        <Actions>
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadOrdersAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
        </Actions>
    </ControlPlanePageHeader>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="cp-card overflow-hidden">
        <div class="grid gap-3 border-b border-ink-200 p-4 lg:grid-cols-[minmax(0,1fr)_170px_180px_auto]">
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search reference, customer, email" @bind="searchTerm" @onkeydown="OnSearchKeyDown" />
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Order status" @bind="statusFilter" />
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Shipping status" @bind="shippingStatusFilter" />
            <button class="cp-button cp-button-primary justify-center" disabled="@(!HasStore)" @onclick="SearchAsync">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                Search
            </button>
        </div>

        @if (!HasStore)
        {
            <div class="p-8 text-center text-sm text-ink-500">Select a store to load orders.</div>
        }
        else if (isLoading)
        {
            <div class="p-8 text-center text-sm text-ink-500">Loading orders...</div>
        }
        else if (orders.Count == 0)
        {
            <div class="p-8 text-center text-sm text-ink-500">No orders found.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                    <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                        <tr>
                            <th class="px-4 py-3">Reference</th>
                            <th class="px-4 py-3">Customer</th>
                            <th class="px-4 py-3 text-right">Total</th>
                            <th class="px-4 py-3">Order status</th>
                            <th class="px-4 py-3">Payment</th>
                            <th class="px-4 py-3">Shipping</th>
                            <th class="px-4 py-3">Created</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-ink-100">
                        @foreach (var order in orders)
                        {
                            <tr class="cursor-pointer hover:bg-ink-50" @onclick="() => OpenOrderAsync(order.Id)">
                                <td class="px-4 py-3">
                                    <div class="font-semibold text-ink-900">@order.Reference</div>
                                    <div class="font-mono text-xs text-ink-500">@order.Id</div>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="font-medium text-ink-800">@order.CustomerName</div>
                                    <div class="text-xs text-ink-500">@order.CustomerEmail</div>
                                </td>
                                <td class="px-4 py-3 text-right text-ink-700">@order.TotalAmount.ToString("0.00") @order.CurrencyCode</td>
                                <td class="px-4 py-3"><StatusBadge Text="@order.Status" Tone="@StatusTone(order.Status)" /></td>
                                <td class="px-4 py-3"><StatusBadge Text="@order.PaymentStatus" Tone="@PaymentTone(order.PaymentStatus)" /></td>
                                <td class="px-4 py-3"><StatusBadge Text="@order.ShippingStatus" Tone="@ShippingTone(order.ShippingStatus)" /></td>
                                <td class="px-4 py-3 text-ink-500">@order.CreatedOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex items-center justify-between border-t border-ink-200 p-4 text-sm">
                <div class="text-ink-500">Page @pageNumber Â· @orders.Count of @totalCount</div>
                <div class="flex gap-2">
                    <button class="cp-button cp-button-secondary" disabled="@(pageNumber <= 1)" @onclick="PreviousPageAsync">
                        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    </button>
                    <button class="cp-button cp-button-secondary" disabled="@(!CanNextPage)" @onclick="NextPageAsync">
                        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

<RightDrawer IsOpen="@isDrawerOpen" IsOpenChanged="OnDrawerChanged" Title="@selectedOrder?.Reference" Subtitle="@selectedOrder?.CustomerEmail" Eyebrow="Order Detail">
    @if (selectedOrder is null)
    {
        <div class="text-sm text-ink-500">No order selected.</div>
    }
    else
    {
        <div class="space-y-5">
            <section class="grid gap-3 md:grid-cols-5">
                <div class="rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="text-xs font-semibold uppercase text-ink-500">Total</div>
                    <div class="mt-1 text-xl font-bold text-ink-900">@selectedOrder.TotalAmount.ToString("0.00")</div>
                </div>
                <div class="rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="text-xs font-semibold uppercase text-ink-500">Currency</div>
                    <div class="mt-1 text-xl font-bold text-ink-900">@selectedOrder.CurrencyCode</div>
                </div>
                <div class="rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="text-xs font-semibold uppercase text-ink-500">Order</div>
                    <div class="mt-2"><StatusBadge Text="@selectedOrder.Status" Tone="@StatusTone(selectedOrder.Status)" /></div>
                </div>
                <div class="rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="text-xs font-semibold uppercase text-ink-500">Payment</div>
                    <div class="mt-2"><StatusBadge Text="@selectedOrder.PaymentStatus" Tone="@PaymentTone(selectedOrder.PaymentStatus)" /></div>
                </div>
                <div class="rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="text-xs font-semibold uppercase text-ink-500">Shipping</div>
                    <div class="mt-2"><StatusBadge Text="@selectedOrder.ShippingStatus" Tone="@ShippingTone(selectedOrder.ShippingStatus)" /></div>
                </div>
            </section>

            <section class="rounded-md border border-ink-200 p-4">
                <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                        <h2 class="text-sm font-semibold text-ink-900">Payment workflow</h2>
                        <div class="mt-3 grid gap-3 text-sm md:grid-cols-3">
                            <div>
                                <div class="text-xs font-semibold uppercase text-ink-500">Method</div>
                                <div class="mt-1 font-mono text-ink-800">@selectedOrder.PaymentMethodKey</div>
                            </div>
                            <div>
                                <div class="text-xs font-semibold uppercase text-ink-500">Payment at</div>
                                <div class="mt-1 text-ink-800">@FormatDate(selectedOrder.PaymentAt)</div>
                            </div>
                            <div>
                                <div class="text-xs font-semibold uppercase text-ink-500">Completed at</div>
                                <div class="mt-1 text-ink-800">@FormatDate(selectedOrder.CompletedAt)</div>
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button class="cp-button cp-button-primary justify-center" disabled="@(!CanCompleteSelectedOrder || isSaving)" @onclick="CompleteOrderAsync">
                            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                            Complete
                        </button>
                        <button class="cp-button cp-button-secondary justify-center" disabled="@(!CanCancelSelectedOrder || isSaving)" @onclick="CancelOrderAsync">
                            <i class="fa-solid fa-ban" aria-hidden="true"></i>
                            Cancel
                        </button>
                    </div>
                </div>
            </section>

            @if (selectedOrder.HistoryEntries.Count > 0)
            {
                <section class="rounded-md border border-ink-200 p-4">
                    <h2 class="text-sm font-semibold text-ink-900">History</h2>
                    <div class="mt-3 divide-y divide-ink-100 rounded-md border border-ink-200">
                        @foreach (var entry in selectedOrder.HistoryEntries.OrderByDescending(entry => entry.CreatedAtUtc))
                        {
                            <div class="grid gap-2 p-3 text-sm md:grid-cols-[160px_minmax(0,1fr)_120px]">
                                <div class="font-mono text-xs text-ink-500">@entry.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                <div>
                                    <div class="font-semibold text-ink-900">@entry.Message</div>
                                    <div class="mt-1 font-mono text-xs text-ink-500">@entry.EventType</div>
                                    @if (!string.IsNullOrWhiteSpace(entry.OldValue) || !string.IsNullOrWhiteSpace(entry.NewValue))
                                    {
                                        <div class="mt-1 text-xs text-ink-500">@entry.OldValue -> @entry.NewValue</div>
                                    }
                                </div>
                                <div class="text-xs text-ink-500">@entry.Source</div>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (selectedOrder.ExchangeRate.HasValue && selectedOrder.BaseTotalAmount.HasValue)
            {
                <section class="rounded-md border border-ink-200 p-4">
                    <h2 class="text-sm font-semibold text-ink-900">Currency snapshot</h2>
                    <div class="mt-3 grid gap-3 text-sm md:grid-cols-4">
                        <div>
                            <div class="text-xs font-semibold uppercase text-ink-500">Base total</div>
                            <div class="mt-1 font-medium text-ink-800">@selectedOrder.BaseTotalAmount.Value.ToString("0.00") @selectedOrder.BaseCurrencyCode</div>
                        </div>
                        <div>
                            <div class="text-xs font-semibold uppercase text-ink-500">Rate</div>
                            <div class="mt-1 font-mono text-ink-800">@selectedOrder.ExchangeRate.Value.ToString("0.########")</div>
                        </div>
                        <div>
                            <div class="text-xs font-semibold uppercase text-ink-500">Provider</div>
                            <div class="mt-1 font-mono text-ink-800">@selectedOrder.ExchangeRateProviderKey</div>
                        </div>
                        <div>
                            <div class="text-xs font-semibold uppercase text-ink-500">Effective</div>
                            <div class="mt-1 text-ink-800">@FormatDate(selectedOrder.ExchangeRateEffectiveAtUtc?.UtcDateTime)</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(selectedOrder.ExchangeRateSource))
                    {
                        <div class="mt-3 text-xs text-ink-500">Source: @selectedOrder.ExchangeRateSource</div>
                    }
                </section>
            }

            <section class="rounded-md border border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">Customer</h2>
                <div class="mt-3 grid gap-3 text-sm md:grid-cols-2">
                    <div>
                        <div class="text-xs font-semibold uppercase text-ink-500">Name</div>
                        <div class="mt-1 text-ink-800">@selectedOrder.CustomerName</div>
                    </div>
                    <div>
                        <div class="text-xs font-semibold uppercase text-ink-500">Email</div>
                        <div class="mt-1 text-ink-800">@selectedOrder.CustomerEmail</div>
                    </div>
                </div>
            </section>

            <section class="rounded-md border border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">Lines</h2>
                <div class="mt-3 divide-y divide-ink-100 rounded-md border border-ink-200">
                    @foreach (var line in selectedOrder.Lines)
                    {
                        <div class="grid gap-3 p-3 text-sm md:grid-cols-[minmax(0,1fr)_80px_120px] md:items-center">
                            <div>
                                <div class="font-semibold text-ink-900">@line.ProductName</div>
                                <div class="mt-1 font-mono text-xs text-ink-500">@line.Sku</div>
                                @if (line.VariantAttributes.Count > 0)
                                {
                                    <div class="mt-1 text-xs text-ink-500">@string.Join(" / ", line.VariantAttributes.Select(attribute => $"{attribute.Name}: {attribute.Value}"))</div>
                                }
                            </div>
                            <div class="text-ink-600">Qty @line.Quantity</div>
                            <div class="text-right font-medium text-ink-800">
                                <div>@line.LineTotal.ToString("0.00") @(line.CurrencyCode ?? selectedOrder.CurrencyCode)</div>
                                @if (line.BaseLineTotal.HasValue && !string.IsNullOrWhiteSpace(selectedOrder.BaseCurrencyCode))
                                {
                                    <div class="mt-1 text-xs font-normal text-ink-500">@line.BaseLineTotal.Value.ToString("0.00") @selectedOrder.BaseCurrencyCode base</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="rounded-md border border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">Admin note</h2>
                <textarea class="mt-3 min-h-24 w-full rounded-md border border-ink-300 px-3 py-2 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="adminNote"></textarea>
                <button class="cp-button cp-button-secondary mt-3 justify-center" disabled="@isSaving" @onclick="SaveAdminNoteAsync">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    Save note
                </button>
            </section>

            <section class="rounded-md border border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">Shipment</h2>
                <div class="mt-3 grid gap-3 text-sm md:grid-cols-2">
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Carrier name</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="shipmentForm.CarrierName" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Carrier service</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="shipmentForm.CarrierService" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Tracking number</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="shipmentForm.TrackingNumber" />
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Ship date</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="date" @bind="shipmentDate" />
                    </label>
                    <label class="space-y-1 md:col-span-2">
                        <span class="font-medium text-ink-700">Tracking URL</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="shipmentForm.TrackingUrl" />
                    </label>
                    <label class="space-y-1 md:col-span-2">
                        <span class="font-medium text-ink-700">Note</span>
                        <textarea class="min-h-20 w-full rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="shipmentForm.Note"></textarea>
                    </label>
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Shipping status</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="shippingStatus" />
                    </label>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                    <button class="cp-button cp-button-primary justify-center" disabled="@isSaving" @onclick="SaveShipmentAsync">
                        <i class="fa-solid fa-truck-fast" aria-hidden="true"></i>
                        Save shipment
                    </button>
                    <button class="cp-button cp-button-secondary justify-center" disabled="@isSaving" @onclick="SaveShippingStatusAsync">
                        <i class="fa-solid fa-flag-checkered" aria-hidden="true"></i>
                        Update shipping status
                    </button>
                </div>
            </section>
        </div>
    }
</RightDrawer>

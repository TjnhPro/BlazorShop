@page "/credentials"
@attribute [Authorize]
@inject IControlPlaneNodeClient NodeClient
@inject IControlPlaneCredentialClient CredentialClient

<PageTitle>Credentials</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Credentials</p>
            <h1 class="text-2xl font-bold text-ink-900">Node API keys</h1>
            <p class="mt-1 text-sm text-ink-500">Create, revoke, and rotate Control Plane credentials for registered nodes.</p>
        </div>
        <button class="cp-button cp-button-primary" disabled="@(selectedNodePublicId is null || isSaving)" @onclick="CreateCredentialAsync">
            <i class="fa-solid fa-key" aria-hidden="true"></i>
            Create key
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
            @successMessage
        </div>
    }

    @if (latestSecret is not null)
    {
        <div class="rounded-md border border-amber-200 bg-amber-50 p-4">
            <div class="flex items-start gap-3">
                <i class="fa-solid fa-triangle-exclamation mt-1 text-amber-700" aria-hidden="true"></i>
                <div class="min-w-0 flex-1">
                    <p class="text-sm font-semibold text-amber-900">Secret shown once</p>
                    <p class="mt-1 text-sm text-amber-800">Store this value now. It cannot be read back after this page changes.</p>
                    <div class="mt-3 rounded-md border border-amber-300 bg-white p-3 font-mono text-xs text-ink-900 break-all">
                        @latestSecret.RawSecret
                    </div>
                    <p class="mt-2 text-xs text-amber-800">Key id: <span class="font-mono">@latestSecret.Credential.KeyId</span></p>
                </div>
                <button class="cp-button cp-button-secondary" @onclick="DismissSecret">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    Dismiss
                </button>
            </div>
        </div>
    }

    <div class="grid gap-5 xl:grid-cols-[320px_minmax(0,1fr)]">
        <aside class="cp-card overflow-hidden">
            <div class="border-b border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">Nodes</h2>
            </div>

            @if (isLoadingNodes)
            {
                <div class="p-6 text-center text-sm text-ink-500">Loading nodes...</div>
            }
            else if (nodes.Count == 0)
            {
                <div class="p-6 text-center">
                    <i class="fa-solid fa-server mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
                    <p class="text-sm font-semibold text-ink-700">No nodes available</p>
                    <p class="mt-1 text-sm text-ink-500">Create a node before issuing credentials.</p>
                </div>
            }
            else
            {
                <div class="divide-y divide-ink-100">
                    @foreach (var node in nodes)
                    {
                        <button class="@GetNodeButtonClass(node.PublicId)" @onclick="() => SelectNodeAsync(node.PublicId)">
                            <span class="block truncate font-semibold">@node.Name</span>
                            <span class="mt-1 block truncate text-xs opacity-75">@node.NodeKey</span>
                        </button>
                    }
                </div>
            }
        </aside>

        <div class="cp-card overflow-hidden">
            <div class="flex flex-col gap-3 border-b border-ink-200 p-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-sm font-semibold text-ink-900">Credential inventory</h2>
                    <p class="mt-1 text-xs text-ink-500">Only hash and metadata are persisted.</p>
                </div>
                <button class="cp-button cp-button-secondary" disabled="@(selectedNodePublicId is null || isLoadingCredentials)" @onclick="ReloadCredentialsAsync">
                    <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                    Refresh
                </button>
            </div>

            @if (selectedNodePublicId is null)
            {
                <div class="p-8 text-center">
                    <i class="fa-solid fa-circle-info mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
                    <p class="text-sm font-semibold text-ink-700">Select a node</p>
                    <p class="mt-1 text-sm text-ink-500">Choose a node to view or create credentials.</p>
                </div>
            }
            else if (isLoadingCredentials)
            {
                <div class="p-8 text-center text-sm text-ink-500">Loading credentials...</div>
            }
            else if (credentials.Count == 0)
            {
                <div class="p-8 text-center">
                    <i class="fa-solid fa-key mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
                    <p class="text-sm font-semibold text-ink-700">No credentials</p>
                    <p class="mt-1 text-sm text-ink-500">Create the first API key for this node.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                        <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                            <tr>
                                <th class="px-4 py-3">Key id</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3">Created</th>
                                <th class="px-4 py-3">Revoked</th>
                                <th class="px-4 py-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-ink-100">
                            @foreach (var credential in credentials)
                            {
                                <tr class="hover:bg-ink-50">
                                    <td class="px-4 py-3 font-mono text-xs text-ink-800">@credential.KeyId</td>
                                    <td class="px-4 py-3">
                                        <span class="@GetCredentialBadgeClass(credential.Status)">@credential.Status</span>
                                    </td>
                                    <td class="px-4 py-3 text-ink-600">@credential.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="px-4 py-3 text-ink-600">@(credential.RevokedAt?.LocalDateTime.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button class="cp-button cp-button-secondary" disabled="@(credential.Status != "active" || isSaving)" @onclick="() => RotateCredentialAsync(credential.KeyId)">
                                                <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                                                Rotate
                                            </button>
                                            <button class="cp-button cp-button-danger" disabled="@(credential.Status == "revoked" || isSaving)" @onclick="() => RevokeCredentialAsync(credential.KeyId)">
                                                <i class="fa-solid fa-ban" aria-hidden="true"></i>
                                                Revoke
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private readonly List<NodeSummary> nodes = [];
    private readonly List<CredentialSummary> credentials = [];
    private Guid? selectedNodePublicId;
    private CredentialSecretResult? latestSecret;
    private string? errorMessage;
    private string? successMessage;
    private bool isLoadingNodes;
    private bool isLoadingCredentials;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadNodesAsync();
    }

    private async Task LoadNodesAsync()
    {
        isLoadingNodes = true;
        errorMessage = null;

        try
        {
            var response = await NodeClient.ListAsync(pageSize: 100);
            nodes.Clear();
            nodes.AddRange(response.Items.Where(node => node.Status != "disabled"));

            if (nodes.Count > 0)
            {
                await SelectNodeAsync(nodes[0].PublicId);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoadingNodes = false;
        }
    }

    private async Task SelectNodeAsync(Guid publicId)
    {
        selectedNodePublicId = publicId;
        latestSecret = null;
        await LoadCredentialsAsync();
    }

    private async Task ReloadCredentialsAsync()
    {
        await LoadCredentialsAsync();
    }

    private async Task LoadCredentialsAsync()
    {
        if (selectedNodePublicId is null)
        {
            return;
        }

        isLoadingCredentials = true;
        errorMessage = null;

        try
        {
            var response = await CredentialClient.ListAsync(selectedNodePublicId.Value);
            credentials.Clear();
            credentials.AddRange(response.Items);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoadingCredentials = false;
        }
    }

    private async Task CreateCredentialAsync()
    {
        if (selectedNodePublicId is null)
        {
            return;
        }

        await SaveSecretOperationAsync(async () =>
        {
            latestSecret = await CredentialClient.CreateAsync(selectedNodePublicId.Value);
            successMessage = "Credential created.";
        });
    }

    private async Task RotateCredentialAsync(string keyId)
    {
        if (selectedNodePublicId is null)
        {
            return;
        }

        await SaveSecretOperationAsync(async () =>
        {
            var result = await CredentialClient.RotateAsync(selectedNodePublicId.Value, keyId);
            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            latestSecret = result.Credential;
            successMessage = "Credential rotated.";
        });
    }

    private async Task RevokeCredentialAsync(string keyId)
    {
        if (selectedNodePublicId is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;
        latestSecret = null;

        try
        {
            var result = await CredentialClient.RevokeAsync(selectedNodePublicId.Value, keyId);
            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            successMessage = "Credential revoked.";
            await LoadCredentialsAsync();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveSecretOperationAsync(Func<Task> operation)
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;
        latestSecret = null;

        try
        {
            await operation();
            await LoadCredentialsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void DismissSecret()
    {
        latestSecret = null;
    }

    private string GetNodeButtonClass(Guid publicId)
    {
        var selected = selectedNodePublicId == publicId;
        return selected
            ? "block w-full px-4 py-3 text-left text-sm bg-control-50 text-control-800"
            : "block w-full px-4 py-3 text-left text-sm text-ink-700 hover:bg-ink-50";
    }

    private static string GetCredentialBadgeClass(string status)
    {
        return status switch
        {
            "active" => "rounded-full bg-green-50 px-2 py-1 text-xs font-semibold text-green-700",
            "rotated" => "rounded-full bg-blue-50 px-2 py-1 text-xs font-semibold text-blue-700",
            "revoked" => "rounded-full bg-ink-100 px-2 py-1 text-xs font-semibold text-ink-600",
            _ => "rounded-full bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-700"
        };
    }
}

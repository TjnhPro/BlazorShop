@page "/commerce-admin/variation-templates"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneCatalogClient CatalogClient

<PageTitle>Variation Templates</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Commerce Admin</p>
            <h1 class="text-2xl font-bold text-ink-900">Variation templates</h1>
            <p class="mt-1 text-sm text-ink-500">Maintain reusable attribute templates for CSV product imports.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
            <button class="cp-button cp-button-primary" disabled="@(!HasStore)" @onclick="NewTemplate">
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                New template
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="cp-card overflow-hidden">
        @if (!HasStore)
        {
            <div class="p-8 text-center text-sm text-ink-500">Select a store to load variation templates.</div>
        }
        else if (isLoading)
        {
            <div class="p-8 text-center text-sm text-ink-500">Loading variation templates...</div>
        }
        else if (templates.Count == 0)
        {
            <div class="p-8 text-center text-sm text-ink-500">No variation templates found.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                    <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                        <tr>
                            <th class="px-4 py-3">Template</th>
                            <th class="px-4 py-3">Slug</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Options</th>
                            <th class="px-4 py-3">Updated</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-ink-100">
                        @foreach (var template in templates)
                        {
                            <tr class="cursor-pointer hover:bg-ink-50" @onclick="() => OpenTemplateAsync(template.PublicId)">
                                <td class="px-4 py-3 font-semibold text-ink-900">@template.Name</td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-2 font-mono text-xs text-ink-600">
                                        <span>@template.Slug</span>
                                        <CopyButton Text="@template.Slug" />
                                    </div>
                                </td>
                                <td class="px-4 py-3"><StatusBadge Text="@(template.IsActive ? "Active" : "Disabled")" Tone="@(template.IsActive ? "success" : "neutral")" /></td>
                                <td class="px-4 py-3 text-ink-600">@template.OptionCount</td>
                                <td class="px-4 py-3 text-ink-500">@template.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<RightDrawer IsOpen="@isDrawerOpen" IsOpenChanged="OnDrawerChanged" Title="@DrawerTitle" Subtitle="@templateForm.Slug" Eyebrow="Variation Template">
    <div class="space-y-6">
        <div class="rounded-md border border-ink-200 p-4">
            <div class="mb-3 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-ink-900">Template fields</h2>
                @if (selectedTemplate is not null)
                {
                    <StatusBadge Text="@(templateForm.IsActive ? "Active" : "Disabled")" Tone="@(templateForm.IsActive ? "success" : "neutral")" />
                }
            </div>
            <div class="grid gap-3 text-sm">
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Name</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="templateForm.Name" />
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Slug</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 font-mono text-xs outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="templateForm.Slug" />
                </label>
                <label class="flex items-center gap-2 text-ink-700">
                    <input type="checkbox" @bind="templateForm.IsActive" />
                    Active
                </label>
                <button class="cp-button cp-button-primary justify-center" disabled="@isSaving" @onclick="SaveTemplateAsync">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    Save template
                </button>
            </div>
        </div>

        @if (selectedTemplate is not null)
        {
            <div class="rounded-md border border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">Options</h2>
                <div class="mt-3 grid gap-3 md:grid-cols-[minmax(0,1fr)_110px_120px_auto]">
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Option name, e.g. Color" @bind="optionForm.Name" />
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" @bind="optionForm.SortOrder" />
                    <label class="flex min-h-10 items-center gap-2 rounded-md border border-ink-300 px-3 text-sm text-ink-700">
                        <input type="checkbox" @bind="optionForm.IsActive" />
                        Active
                    </label>
                    <button class="cp-button cp-button-secondary justify-center" disabled="@isSaving" @onclick="SaveOptionAsync">@OptionActionText</button>
                </div>
            </div>

            <div class="space-y-3">
                @foreach (var option in selectedTemplate.Options.OrderBy(option => option.SortOrder).ThenBy(option => option.Name))
                {
                    <div class="rounded-md border border-ink-200 bg-white p-4">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <button class="text-left" @onclick="() => EditOption(option)">
                                <div class="font-semibold text-ink-900">@option.Name</div>
                                <div class="text-xs text-ink-500">Sort @option.SortOrder · @option.Values.Count values</div>
                            </button>
                            <StatusBadge Text="@(option.IsActive ? "Active" : "Disabled")" Tone="@(option.IsActive ? "success" : "neutral")" />
                        </div>
                        <div class="mt-3 flex flex-wrap gap-2">
                            @foreach (var value in option.Values.OrderByDescending(value => value.IsActive).ThenBy(value => value.SortOrder).ThenBy(value => value.Value))
                            {
                                <button class="rounded-md border border-ink-200 px-3 py-1.5 text-xs text-ink-700 hover:bg-ink-50" @onclick="() => EditValue(option, value)">
                                    @value.Value
                                    <span class="ml-1 text-ink-400">#@value.SortOrder</span>
                                    @if (!value.IsActive)
                                    {
                                        <span class="ml-1 text-red-500">disabled</span>
                                    }
                                </button>
                            }
                        </div>
                        <div class="mt-3 grid gap-3 md:grid-cols-[minmax(0,1fr)_110px_120px_auto]">
                            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Value, e.g. Red" value="@GetValueText(option.PublicId)" @onchange="args => SetValueText(option.PublicId, args.Value?.ToString())" />
                            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" value="@GetValueSortOrder(option.PublicId)" @onchange="args => SetValueSortOrder(option.PublicId, args.Value?.ToString())" />
                            <label class="flex min-h-10 items-center gap-2 rounded-md border border-ink-300 px-3 text-sm text-ink-700">
                                <input type="checkbox" checked="@GetValueIsActive(option.PublicId)" @onchange="args => SetValueIsActive(option.PublicId, args.Value)" />
                                Active
                            </label>
                            <button class="cp-button cp-button-secondary justify-center" disabled="@isSaving" @onclick="() => SaveValueAsync(option.PublicId)">
                                @GetValueActionText(option.PublicId)
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</RightDrawer>

@code {
    private readonly List<StoreSummary> stores = [];
    private readonly List<VariationTemplateSummaryDto> templates = [];
    private readonly Dictionary<Guid, ValueFormState> valueForms = [];
    private Guid? selectedStorePublicId;
    private VariationTemplateDetailDto? selectedTemplate;
    private TemplateFormState templateForm = new();
    private OptionFormState optionForm = new();
    private Guid? editingOptionPublicId;
    private bool isLoading;
    private bool isSaving;
    private bool isDrawerOpen;
    private string? errorMessage;
    private string? successMessage;

    private bool HasStore => selectedStorePublicId.HasValue && selectedStorePublicId.Value != Guid.Empty;

    private string DrawerTitle => selectedTemplate is null ? "Create template" : selectedTemplate.Name;

    private string OptionActionText => editingOptionPublicId is null ? "Add option" : "Update option";

    protected override async Task OnInitializedAsync()
    {
        await LoadStoresAsync();
    }

    private async Task LoadStoresAsync()
    {
        var response = await StoreClient.ListAsync(status: "active");
        stores.Clear();
        stores.AddRange(response.Items);
        selectedStorePublicId ??= stores.FirstOrDefault()?.PublicId;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (!HasStore)
        {
            return;
        }

        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await CatalogClient.ListVariationTemplatesAsync(selectedStorePublicId!.Value);
            if (!result.Success)
            {
                errorMessage = result.Message;
                return;
            }

            templates.Clear();
            templates.AddRange(result.Data?.Items ?? []);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NewTemplate()
    {
        selectedTemplate = null;
        templateForm = new TemplateFormState { IsActive = true };
        optionForm = new OptionFormState { IsActive = true };
        editingOptionPublicId = null;
        valueForms.Clear();
        isDrawerOpen = true;
    }

    private async Task OpenTemplateAsync(Guid templatePublicId)
    {
        if (!HasStore)
        {
            return;
        }

        var result = await CatalogClient.GetVariationTemplateAsync(selectedStorePublicId!.Value, templatePublicId);
        if (!result.Success || result.Data is null)
        {
            errorMessage = result.Message;
            return;
        }

        ApplyTemplate(result.Data);
        isDrawerOpen = true;
    }

    private async Task SaveTemplateAsync()
    {
        if (!HasStore)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            var result = selectedTemplate is null
                ? await CatalogClient.CreateVariationTemplateAsync(
                    selectedStorePublicId!.Value,
                    new CreateVariationTemplateRequest(templateForm.Name, templateForm.Slug, templateForm.IsActive))
                : await CatalogClient.UpdateVariationTemplateAsync(
                    selectedStorePublicId!.Value,
                    selectedTemplate.PublicId,
                    new UpdateVariationTemplateRequest(templateForm.Name, templateForm.Slug, templateForm.IsActive));

            await ApplyResultAsync(result, "Variation template saved.");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveOptionAsync()
    {
        if (!HasStore || selectedTemplate is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            var result = editingOptionPublicId is null
                ? await CatalogClient.CreateVariationTemplateOptionAsync(
                    selectedStorePublicId!.Value,
                    selectedTemplate.PublicId,
                    new CreateVariationTemplateOptionRequest(optionForm.Name, optionForm.SortOrder, optionForm.IsActive))
                : await CatalogClient.UpdateVariationTemplateOptionAsync(
                    selectedStorePublicId!.Value,
                    selectedTemplate.PublicId,
                    editingOptionPublicId.Value,
                    new UpdateVariationTemplateOptionRequest(optionForm.Name, optionForm.SortOrder, optionForm.IsActive));

            await ApplyResultAsync(result, "Variation option saved.");
            optionForm = new OptionFormState { IsActive = true };
            editingOptionPublicId = null;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveValueAsync(Guid optionPublicId)
    {
        if (!HasStore || selectedTemplate is null)
        {
            return;
        }

        var form = GetValueForm(optionPublicId);
        isSaving = true;
        errorMessage = null;
        try
        {
            var result = form.EditingValuePublicId is null
                ? await CatalogClient.CreateVariationTemplateValueAsync(
                    selectedStorePublicId!.Value,
                    selectedTemplate.PublicId,
                    optionPublicId,
                    new CreateVariationTemplateValueRequest(form.Value, form.SortOrder, form.IsActive))
                : await CatalogClient.UpdateVariationTemplateValueAsync(
                    selectedStorePublicId!.Value,
                    selectedTemplate.PublicId,
                    optionPublicId,
                    form.EditingValuePublicId.Value,
                    new UpdateVariationTemplateValueRequest(form.Value, form.SortOrder, form.IsActive));

            await ApplyResultAsync(result, "Variation value saved.");
            valueForms[optionPublicId] = new ValueFormState { IsActive = true };
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EditOption(VariationTemplateOptionDto option)
    {
        editingOptionPublicId = option.PublicId;
        optionForm = new OptionFormState
        {
            Name = option.Name,
            SortOrder = option.SortOrder,
            IsActive = option.IsActive,
        };
    }

    private void EditValue(VariationTemplateOptionDto option, VariationTemplateValueDto value)
    {
        valueForms[option.PublicId] = new ValueFormState
        {
            EditingValuePublicId = value.PublicId,
            Value = value.Value,
            SortOrder = value.SortOrder,
            IsActive = value.IsActive,
        };
    }

    private async Task ApplyResultAsync(ControlPlaneClientResult<VariationTemplateDetailDto> result, string message)
    {
        if (!result.Success || result.Data is null)
        {
            errorMessage = result.Message;
            return;
        }

        ApplyTemplate(result.Data);
        successMessage = message;
        await LoadAsync();
    }

    private void ApplyTemplate(VariationTemplateDetailDto detail)
    {
        selectedTemplate = detail;
        templateForm = new TemplateFormState
        {
            Name = detail.Name,
            Slug = detail.Slug,
            IsActive = detail.IsActive,
        };

        valueForms.Clear();
        foreach (var option in detail.Options)
        {
            valueForms[option.PublicId] = new ValueFormState { IsActive = true };
        }
    }

    private Task OnDrawerChanged(bool value)
    {
        isDrawerOpen = value;
        return Task.CompletedTask;
    }

    private ValueFormState GetValueForm(Guid optionPublicId)
    {
        if (!valueForms.TryGetValue(optionPublicId, out var form))
        {
            form = new ValueFormState { IsActive = true };
            valueForms[optionPublicId] = form;
        }

        return form;
    }

    private string? GetValueText(Guid optionPublicId) => GetValueForm(optionPublicId).Value;

    private string GetValueSortOrder(Guid optionPublicId) => GetValueForm(optionPublicId).SortOrder.ToString();

    private bool GetValueIsActive(Guid optionPublicId) => GetValueForm(optionPublicId).IsActive;

    private string GetValueActionText(Guid optionPublicId) => GetValueForm(optionPublicId).EditingValuePublicId is null ? "Add value" : "Update value";

    private void SetValueText(Guid optionPublicId, string? value) => GetValueForm(optionPublicId).Value = value;

    private void SetValueSortOrder(Guid optionPublicId, string? value)
    {
        if (int.TryParse(value, out var sortOrder))
        {
            GetValueForm(optionPublicId).SortOrder = sortOrder;
        }
    }

    private void SetValueIsActive(Guid optionPublicId, object? value)
    {
        GetValueForm(optionPublicId).IsActive = value is bool boolValue && boolValue;
    }

    private sealed class TemplateFormState
    {
        public string? Name { get; set; }

        public string? Slug { get; set; }

        public bool IsActive { get; set; } = true;
    }

    private sealed class OptionFormState
    {
        public string? Name { get; set; }

        public int SortOrder { get; set; }

        public bool IsActive { get; set; } = true;
    }

    private sealed class ValueFormState
    {
        public Guid? EditingValuePublicId { get; set; }

        public string? Value { get; set; }

        public int SortOrder { get; set; }

        public bool IsActive { get; set; } = true;
    }
}

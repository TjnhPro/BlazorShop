@page "/health"

<PageTitle>Health</PageTitle>

<section class="space-y-5">
    <div>
        <p class="text-sm font-semibold text-control-700">Health</p>
        <h1 class="text-2xl font-bold text-ink-900">Node health</h1>
        <p class="mt-1 text-sm text-ink-500">Inspect latest heartbeat and dependency status for each node.</p>
    </div>

    <div class="cp-card p-8 text-center">
        <i class="fa-solid fa-heart-pulse mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
        <p class="text-sm font-semibold text-ink-700">No health snapshots yet</p>
        <p class="mt-1 text-sm text-ink-500">Manual and scheduled probes are planned for Phase 6.</p>
    </div>
</section>

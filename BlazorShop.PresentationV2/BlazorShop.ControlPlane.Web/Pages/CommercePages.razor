@page "/commerce-admin/pages"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneContentClient ContentClient
@inject IControlPlaneSeoClient SeoClient

<PageTitle>Storefront Pages</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Commerce Admin</p>
            <h1 class="text-2xl font-bold text-ink-900">Storefront pages</h1>
            <p class="mt-1 text-sm text-ink-500">Manage store-scoped HTML pages rendered at /pages/slug.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
            <button class="cp-button cp-button-primary" disabled="@(!HasStore)" @onclick="NewPage">
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                New page
            </button>
        </div>
    </div>

    <div class="cp-card p-4">
        <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_180px_120px_auto]">
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search title or slug" @bind="search" @bind:event="oninput" />
            <select class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="status">
                <option value="all">All status</option>
                <option value="published">Published</option>
                <option value="draft">Draft</option>
            </select>
            <select class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="pageSize">
                <option value="10">10 rows</option>
                <option value="25">25 rows</option>
                <option value="50">50 rows</option>
            </select>
            <button class="cp-button cp-button-secondary justify-center" disabled="@(!HasStore)" @onclick="SearchAsync">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                Search
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    @if (HasStore)
    {
        <div class="cp-card p-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-sm font-semibold text-ink-900">Content readiness</h2>
                    <p class="mt-1 text-sm text-ink-500">Required store content slots are mapped by page key; custom pages remain unmapped.</p>
                </div>
                <button class="cp-button cp-button-secondary" disabled="@isTemplateLoading" @onclick="LoadTemplateStatusAsync">
                    <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                    Refresh readiness
                </button>
            </div>
            @if (isTemplateLoading)
            {
                <div class="mt-4 text-sm text-ink-500">Loading content readiness...</div>
            }
            else if (templateStatuses.Count == 0)
            {
                <div class="mt-4 text-sm text-ink-500">No content templates were returned for this store.</div>
            }
            else
            {
                <div class="mt-4 overflow-x-auto">
                    <table class="min-w-full divide-y divide-ink-100 text-left text-sm">
                        <thead class="text-xs font-semibold uppercase text-ink-500">
                            <tr>
                                <th class="py-2 pr-4">Template</th>
                                <th class="py-2 pr-4">Status</th>
                                <th class="py-2 pr-4">Mapped page</th>
                                <th class="py-2 pr-4">Default slug</th>
                                <th class="py-2 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-ink-100">
                            @foreach (var item in templateStatuses)
                            {
                                <tr>
                                    <td class="py-3 pr-4">
                                        <div class="font-semibold text-ink-900">@item.DisplayName</div>
                                        <div class="mt-1 font-mono text-xs text-ink-500">@item.PageKey</div>
                                    </td>
                                    <td class="py-3 pr-4">
                                        <StatusBadge Text="@TemplateStatusLabel(item.Status)" Tone="@TemplateStatusTone(item.Status)" />
                                        @if (item.RequiredForReadiness)
                                        {
                                            <div class="mt-1 text-xs text-ink-500">Required</div>
                                        }
                                    </td>
                                    <td class="py-3 pr-4 text-ink-700">
                                        @if (item.MappedPage is not null)
                                        {
                                            <button class="text-left font-semibold text-control-700 hover:underline" @onclick="() => OpenPageAsync(item.MappedPage.PublicId)">@item.MappedPage.Title</button>
                                            <div class="mt-1 font-mono text-xs text-ink-500">/pages/@item.MappedPage.Slug</div>
                                        }
                                        else if (item.SuggestedExistingPages.Count > 0)
                                        {
                                            <div>@item.SuggestedExistingPages[0].Title</div>
                                            <div class="mt-1 font-mono text-xs text-ink-500">Suggested: /pages/@item.SuggestedExistingPages[0].Slug</div>
                                        }
                                        else
                                        {
                                            <span class="text-ink-500">Not mapped</span>
                                        }
                                    </td>
                                    <td class="py-3 pr-4 font-mono text-xs text-ink-500">/pages/@item.DefaultSlug</td>
                                    <td class="py-3 text-right">
                                        <div class="flex justify-end gap-2">
                                            @if (item.MappedPage is not null)
                                            {
                                                <button class="cp-button cp-button-secondary" disabled="@isTemplateActionBusy" @onclick="() => OpenPageAsync(item.MappedPage.PublicId)">Edit</button>
                                                <button class="cp-button cp-button-secondary" disabled="@isTemplateActionBusy" @onclick="() => ClearTemplateAsync(item.MappedPage.PublicId)">Clear</button>
                                            }
                                            else
                                            {
                                                @if (item.SuggestedExistingPages.Count > 0)
                                                {
                                                    <button class="cp-button cp-button-secondary" disabled="@isTemplateActionBusy" @onclick="() => MapSuggestedPageAsync(item)">Map suggested</button>
                                                }
                                                <button class="cp-button cp-button-primary" disabled="@isTemplateActionBusy" @onclick="() => CreateDraftFromTemplateAsync(item.PageKey)">Create draft</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <div class="cp-card overflow-hidden">
        @if (!HasStore)
        {
            <div class="p-8 text-center text-sm text-ink-500">Select a store to load pages.</div>
        }
        else if (isLoading)
        {
            <div class="p-8 text-center text-sm text-ink-500">Loading pages...</div>
        }
        else if (pages.Count == 0)
        {
            <div class="p-8 text-center text-sm text-ink-500">No storefront pages found.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                    <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                        <tr>
                            <th class="px-4 py-3">Page</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Sitemap</th>
                            <th class="px-4 py-3">Updated</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-ink-100">
                        @foreach (var item in pages)
                        {
                            <tr class="cursor-pointer hover:bg-ink-50" @onclick="() => OpenPageAsync(item.PublicId)">
                                <td class="px-4 py-3">
                                    <div class="font-semibold text-ink-900">@item.Title</div>
                                    <div class="mt-1 flex items-center gap-2 font-mono text-xs text-ink-500">
                                        <span>/pages/@item.Slug</span>
                                        <CopyButton Text="@($"/pages/{item.Slug}")" />
                                    </div>
                                </td>
                                <td class="px-4 py-3"><StatusBadge Text="@(item.IsPublished ? "Published" : "Draft")" Tone="@(item.IsPublished ? "success" : "neutral")" /></td>
                                <td class="px-4 py-3"><StatusBadge Text="@(item.IncludeInSitemap ? "Included" : "Hidden")" Tone="@(item.IncludeInSitemap ? "info" : "neutral")" /></td>
                                <td class="px-4 py-3 text-ink-500">@item.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex flex-col gap-3 border-t border-ink-100 px-4 py-3 text-sm text-ink-600 sm:flex-row sm:items-center sm:justify-between">
                <div>Page @pageNumber of @Math.Max(1, totalPages) Â· @totalCount total</div>
                <div class="flex gap-2">
                    <button class="cp-button cp-button-secondary" disabled="@(pageNumber <= 1 || isLoading)" @onclick="PreviousPageAsync">Previous</button>
                    <button class="cp-button cp-button-secondary" disabled="@(pageNumber >= totalPages || isLoading)" @onclick="NextPageAsync">Next</button>
                </div>
            </div>
        }
    </div>
</section>

<RightDrawer IsOpen="@isDrawerOpen" IsOpenChanged="OnDrawerChanged" Title="@DrawerTitle" Subtitle="@form.Slug" Eyebrow="Storefront Page">
    <div class="space-y-5">
        <div class="rounded-md border border-ink-200 p-4">
            <div class="mb-3 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-ink-900">Page fields</h2>
                <StatusBadge Text="@(form.IsPublished ? "Published" : "Draft")" Tone="@(form.IsPublished ? "success" : "neutral")" />
            </div>
            <div class="grid gap-3 text-sm">
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Title</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="form.Title" />
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Slug</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 font-mono text-xs outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="form.Slug" />
                </label>
                <div class="space-y-2 rounded-md border border-ink-200 bg-ink-50 p-3">
                    <div class="flex flex-wrap gap-2">
                        <button type="button" class="cp-button cp-button-secondary" disabled="@isSlugActionBusy" @onclick="GeneratePageSlugAsync">
                            <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
                            Generate
                        </button>
                        <button type="button" class="cp-button cp-button-secondary" disabled="@isSlugActionBusy" @onclick="ValidatePageSlugAsync">
                            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                            Validate
                        </button>
                    </div>
                    <div class="grid gap-1 text-xs text-ink-600">
                        <div>Normalized: <span class="font-mono">@SlugPreviewText(pageSlugResult?.Slug)</span></div>
                        <div>Public path: <span class="font-mono">@BuildSeoPublicPath("page", pageSlugResult?.Slug ?? form.Slug)</span></div>
                        <div>Canonical preview: <span class="font-mono">@BuildSeoPublicPath("page", pageSlugResult?.Slug ?? form.Slug)</span></div>
                        @if (pageSlugResult is not null)
                        {
                            <div class="@(pageSlugResult.Success ? "text-green-700" : "text-red-700")">@SlugPreviewMessage(pageSlugResult)</div>
                        }
                    </div>
                    @if (pageSlugHistory.Count > 0)
                    {
                        <div class="border-t border-ink-200 pt-2">
                            <div class="text-xs font-semibold uppercase text-ink-500">Slug history</div>
                            <div class="mt-2 space-y-1">
                                @foreach (var item in pageSlugHistory)
                                {
                                    <div class="flex items-center justify-between gap-3 text-xs">
                                        <span class="font-mono text-ink-700">@item.Slug</span>
                                        <span class="text-ink-500">@(item.IsActive ? "active" : item.ReplacedAt?.ToLocalTime().ToString("yyyy-MM-dd"))</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Intro</span>
                    <textarea class="min-h-20 w-full rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="form.Intro"></textarea>
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Body HTML</span>
                    <textarea class="min-h-60 w-full rounded-md border border-ink-300 px-3 py-2 font-mono text-xs outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="form.BodyHtml"></textarea>
                </label>
                <div class="grid gap-3 md:grid-cols-2">
                    <label class="flex items-center gap-2 text-ink-700">
                        <input type="checkbox" @bind="form.IsPublished" />
                        Published
                    </label>
                    <label class="flex items-center gap-2 text-ink-700">
                        <input type="checkbox" @bind="form.IncludeInSitemap" />
                        Include in sitemap
                    </label>
                    <label class="flex items-center gap-2 text-ink-700">
                        <input type="checkbox" @bind="form.RobotsIndex" />
                        Robots index
                    </label>
                    <label class="flex items-center gap-2 text-ink-700">
                        <input type="checkbox" @bind="form.RobotsFollow" />
                        Robots follow
                    </label>
                </div>
            </div>
        </div>

        <div class="rounded-md border border-ink-200 p-4">
            <h2 class="mb-3 text-sm font-semibold text-ink-900">Content governance</h2>
            <div class="grid gap-3 text-sm md:grid-cols-2">
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Page key</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-200 bg-ink-50 px-3 font-mono text-xs text-ink-600" value="@(form.PageKey ?? "custom")" readonly />
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Display order</span>
                    <input type="number" class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="form.DisplayOrder" />
                </label>
                <label class="flex items-center gap-2 text-ink-700">
                    <input type="checkbox" @bind="form.IncludeInNavigation" />
                    Include in content navigation
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Navigation location</span>
                    <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="form.NavigationLocation">
                        <option value="">Not selected</option>
                        <option value="@StorefrontPageContentRules.Header">Header</option>
                        <option value="@StorefrontPageContentRules.FooterCompany">Footer company</option>
                        <option value="@StorefrontPageContentRules.FooterSupport">Footer support</option>
                        <option value="@StorefrontPageContentRules.FooterLegal">Footer legal</option>
                    </select>
                </label>
            </div>
        </div>

        <div class="rounded-md border border-ink-200 p-4">
            <h2 class="mb-3 text-sm font-semibold text-ink-900">SEO</h2>
            <div class="grid gap-3 text-sm">
                <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Meta title" @bind="form.MetaTitle" />
                <textarea class="min-h-20 rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Meta description" @bind="form.MetaDescription"></textarea>
                <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Canonical URL" @bind="form.CanonicalUrl" />
                <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="OG title" @bind="form.OgTitle" />
                <textarea class="min-h-20 rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="OG description" @bind="form.OgDescription"></textarea>
                <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="OG image local URL" @bind="form.OgImage" />
            </div>
        </div>

        <div class="flex flex-col gap-2 sm:flex-row">
            <button class="cp-button cp-button-primary justify-center" disabled="@isSaving" @onclick="SaveAsync">
                <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                Save page
            </button>
            @if (selectedPage is not null)
            {
                <button class="cp-button cp-button-secondary justify-center" disabled="@isSaving" @onclick="ArchiveAsync">
                    <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
                    Archive
                </button>
            }
        </div>
    </div>
</RightDrawer>

@page "/commerce-admin/payment-methods"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneCatalogClient CatalogClient

<PageTitle>Payment Methods</PageTitle>

<section class="space-y-5">
    <ControlPlanePageHeader Eyebrow="Commerce Admin"
                            Title="Payment Methods"
                            Description="Configure enabled checkout payment methods per store."
                            LayoutClass="lg:flex-row lg:items-end lg:justify-between">
        <Actions>
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadPaymentMethodsAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
        </Actions>
    </ControlPlanePageHeader>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="cp-card overflow-hidden">
        @if (!HasStore)
        {
            <div class="p-8 text-center text-sm text-ink-500">Select a store to load payment methods.</div>
        }
        else if (isLoading)
        {
            <div class="p-8 text-center text-sm text-ink-500">Loading payment methods...</div>
        }
        else if (methods.Count == 0)
        {
            <div class="p-8 text-center text-sm text-ink-500">No payment methods found.</div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                    <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                        <tr>
                            <th class="px-4 py-3">Method</th>
                            <th class="px-4 py-3">Enabled</th>
                            <th class="px-4 py-3">Display</th>
                            <th class="px-4 py-3">Order</th>
                            <th class="px-4 py-3">Settings</th>
                            <th class="px-4 py-3 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-ink-100">
                        @foreach (var method in methods)
                        {
                            <tr>
                                <td class="px-4 py-3 align-top">
                                    <div class="font-mono font-semibold text-ink-900">@method.PaymentMethodKey</div>
                                    <div class="mt-1 text-xs text-ink-500">Updated @method.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                </td>
                                <td class="px-4 py-3 align-top">
                                    <input class="size-5 rounded border-ink-300 text-control-700 focus:ring-control-500" type="checkbox" @bind="method.Enabled" />
                                </td>
                                <td class="px-4 py-3 align-top">
                                    <input class="min-h-10 w-56 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="method.DisplayName" />
                                    <textarea class="mt-2 min-h-16 w-64 rounded-md border border-ink-300 px-3 py-2 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="method.Description"></textarea>
                                </td>
                                <td class="px-4 py-3 align-top">
                                    <input class="min-h-10 w-24 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" @bind="method.DisplayOrder" />
                                </td>
                                <td class="px-4 py-3 align-top">
                                    <div class="mb-2 text-xs font-semibold @(method.SettingsConfigured ? "text-green-700" : "text-ink-500")">
                                        @(method.SettingsConfigured ? "Configured" : "Not configured")
                                    </div>
                                    <textarea class="min-h-20 w-72 rounded-md border border-ink-300 px-3 py-2 font-mono text-xs outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Replacement JSON" @bind="method.SettingsJson"></textarea>
                                    <label class="mt-2 flex items-center gap-2 text-xs text-ink-600">
                                        <input class="size-4 rounded border-ink-300 text-control-700 focus:ring-control-500" type="checkbox" @bind="method.ClearSettings" />
                                        Clear saved settings
                                    </label>
                                </td>
                                <td class="px-4 py-3 text-right align-top">
                                    <button class="cp-button cp-button-primary justify-center" disabled="@isSaving" @onclick="() => SaveMethodAsync(method)">
                                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                                        Save
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@code {
    private readonly List<StoreSummary> stores = [];
    private readonly List<PaymentMethodForm> methods = [];
    private Guid? selectedStorePublicId;
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    private bool HasStore => selectedStorePublicId.HasValue && selectedStorePublicId.Value != Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        var response = await StoreClient.ListAsync(status: "active", pageSize: 100);
        stores.AddRange(response.Items);
        selectedStorePublicId = stores.FirstOrDefault()?.PublicId;
        await LoadPaymentMethodsAsync();
    }

    private async Task LoadPaymentMethodsAsync()
    {
        if (!HasStore)
        {
            return;
        }

        isLoading = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var result = await CatalogClient.ListPaymentMethodsAsync(selectedStorePublicId!.Value);
            if (!result.Success || result.Data is null)
            {
                errorMessage = result.Message;
                return;
            }

            methods.Clear();
            methods.AddRange(result.Data.OrderBy(method => method.DisplayOrder).Select(PaymentMethodForm.FromDto));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveMethodAsync(PaymentMethodForm method)
    {
        if (!HasStore)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var result = await CatalogClient.UpdatePaymentMethodAsync(
                selectedStorePublicId!.Value,
                method.PaymentMethodKey,
                new UpdateStorePaymentMethodRequest(
                    method.Enabled,
                    method.DisplayName,
                    method.Description,
                    method.DisplayOrder,
                    method.ClearSettings ? null : method.SettingsJson,
                    method.ClearSettings));

            if (!result.Success || result.Data is null)
            {
                errorMessage = result.Message;
                return;
            }

            var index = methods.FindIndex(item => item.PaymentMethodKey == method.PaymentMethodKey);
            if (index >= 0)
            {
                methods[index] = PaymentMethodForm.FromDto(result.Data);
            }

            successMessage = result.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class PaymentMethodForm
    {
        public string PaymentMethodKey { get; init; } = string.Empty;

        public string DisplayName { get; set; } = string.Empty;

        public string? Description { get; set; }

        public bool Enabled { get; set; }

        public int DisplayOrder { get; set; }

        public string? SettingsJson { get; set; }

        public bool SettingsConfigured { get; set; }

        public bool ClearSettings { get; set; }

        public DateTime UpdatedAt { get; init; }

        public static PaymentMethodForm FromDto(StorePaymentMethodDto method)
        {
            return new PaymentMethodForm
            {
                PaymentMethodKey = method.PaymentMethodKey,
                DisplayName = method.DisplayName,
                Description = method.Description,
                Enabled = method.Enabled,
                DisplayOrder = method.DisplayOrder,
                SettingsConfigured = method.Settings.Configured,
                SettingsJson = null,
                ClearSettings = false,
                UpdatedAt = method.UpdatedAt,
            };
        }
    }
}

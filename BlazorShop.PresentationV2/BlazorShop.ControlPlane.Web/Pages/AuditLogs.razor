@page "/audit-logs"

<PageTitle>Audit Logs</PageTitle>

<section class="space-y-5">
    <div>
        <p class="text-sm font-semibold text-control-700">Audit Logs</p>
        <h1 class="text-2xl font-bold text-ink-900">Security and change history</h1>
        <p class="mt-1 text-sm text-ink-500">Search actions by actor, action, target, and time range.</p>
    </div>

    <div class="cp-card">
        <div class="grid gap-3 border-b border-ink-200 p-4 md:grid-cols-3">
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search actor" />
            <input class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search action" />
            <button class="cp-button">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                Search
            </button>
        </div>
        <div class="p-8 text-center">
            <i class="fa-solid fa-clipboard-list mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
            <p class="text-sm font-semibold text-ink-700">No audit records yet</p>
            <p class="mt-1 text-sm text-ink-500">Audit persistence is part of the database foundation and action flows.</p>
        </div>
    </div>
</section>

@page "/nodes"

<PageTitle>Nodes</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Nodes</p>
            <h1 class="text-2xl font-bold text-ink-900">Commerce nodes</h1>
            <p class="mt-1 text-sm text-ink-500">Register, inspect, disable, and rotate credentials for remote nodes.</p>
        </div>
        <button class="cp-button cp-button-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Create node
        </button>
    </div>

    <div class="cp-card">
        <div class="border-b border-ink-200 p-4">
            <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <input class="min-h-10 flex-1 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Search node name or key" />
                <select class="min-h-10 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100">
                    <option>All statuses</option>
                    <option>Healthy</option>
                    <option>Warning</option>
                    <option>Down</option>
                    <option>Disabled</option>
                </select>
            </div>
        </div>
        <div class="p-8 text-center">
            <i class="fa-solid fa-server mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
            <p class="text-sm font-semibold text-ink-700">No nodes registered</p>
            <p class="mt-1 text-sm text-ink-500">Node registry data will appear after Phase 4.</p>
        </div>
    </div>
</section>

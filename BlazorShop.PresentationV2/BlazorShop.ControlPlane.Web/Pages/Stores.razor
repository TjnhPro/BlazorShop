@page "/stores"

<PageTitle>Stores</PageTitle>

<section class="space-y-5">
    <div>
        <p class="text-sm font-semibold text-control-700">Stores</p>
        <h1 class="text-2xl font-bold text-ink-900">Store registry</h1>
        <p class="mt-1 text-sm text-ink-500">Assign platform store metadata to registered Commerce Nodes.</p>
    </div>

    <div class="cp-card p-8 text-center">
        <i class="fa-solid fa-store mb-3 text-2xl text-ink-400" aria-hidden="true"></i>
        <p class="text-sm font-semibold text-ink-700">No stores registered</p>
        <p class="mt-1 text-sm text-ink-500">Store registry metadata will be implemented after node foundation is in place.</p>
    </div>
</section>

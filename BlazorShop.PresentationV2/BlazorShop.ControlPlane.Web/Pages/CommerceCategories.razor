@page "/commerce-admin/categories"
@attribute [Authorize]
@inject IControlPlaneStoreClient StoreClient
@inject IControlPlaneCategoryClient CategoryClient
@inject IControlPlaneSeoClient SeoClient

<PageTitle>Categories</PageTitle>

<section class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold text-control-700">Commerce Admin</p>
            <h1 class="text-2xl font-bold text-ink-900">Categories</h1>
            <p class="mt-1 text-sm text-ink-500">Manage store categories and copy slugs for product import CSV files.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <select class="min-h-10 min-w-64 rounded-md border border-ink-300 px-3 text-sm outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="selectedStorePublicId">
                <option value="">Select store</option>
                @foreach (var store in stores)
                {
                    <option value="@store.PublicId">@store.Name (@store.StoreKey)</option>
                }
            </select>
            <button class="cp-button cp-button-secondary" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate" aria-hidden="true"></i>
                Refresh
            </button>
            <button class="cp-button cp-button-primary" disabled="@(!HasStore)" @onclick="NewCategory">
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                New category
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@successMessage</div>
    }

    <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_360px]">
        <div class="cp-card overflow-hidden">
            @if (!HasStore)
            {
                <div class="p-8 text-center text-sm text-ink-500">Select a store to load categories.</div>
            }
            else if (isLoading)
            {
                <div class="p-8 text-center text-sm text-ink-500">Loading categories...</div>
            }
            else if (categories.Count == 0)
            {
                <div class="p-8 text-center text-sm text-ink-500">No categories found.</div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-ink-200 text-left text-sm">
                        <thead class="bg-ink-50 text-xs font-semibold uppercase text-ink-500">
                            <tr>
                                <th class="px-4 py-3">Category</th>
                                <th class="px-4 py-3">Slug</th>
                                <th class="px-4 py-3">Parent</th>
                                <th class="px-4 py-3">Display</th>
                                <th class="px-4 py-3">Updated</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-ink-100">
                            @foreach (var category in categories.OrderBy(category => category.DisplayOrder).ThenBy(category => category.Name))
                            {
                                <tr class="cursor-pointer hover:bg-ink-50" @onclick="() => EditCategory(category)">
                                    <td class="px-4 py-3">
                                        <div class="font-semibold text-ink-900">@category.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(category.Description))
                                        {
                                            <div class="mt-1 line-clamp-2 text-xs text-ink-500">@category.Description</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(category.Image))
                                        {
                                            <div class="truncate text-xs text-ink-500">@category.Image</div>
                                        }
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2 font-mono text-xs text-ink-600">
                                            <span>@category.Slug</span>
                                            @if (!string.IsNullOrWhiteSpace(category.Slug))
                                            {
                                                <CopyButton Text="@category.Slug" />
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-ink-600">@GetParentName(category.ParentCategoryId)</td>
                                    <td class="px-4 py-3 text-ink-600">@category.DisplayOrder</td>
                                    <td class="px-4 py-3 text-ink-500">@category.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <aside class="cp-card p-4">
            <h2 class="text-sm font-semibold text-ink-900">Category tree</h2>
            @if (categoryTree.Count == 0)
            {
                <div class="mt-4 rounded-md border border-ink-200 p-4 text-center text-sm text-ink-500">No tree data.</div>
            }
            else
            {
                <div class="mt-4 space-y-2">
                    @foreach (var node in categoryTree)
                    {
                        @RenderCategoryNode(node, 0)
                    }
                </div>
            }
        </aside>
    </div>
</section>

<RightDrawer IsOpen="@isDrawerOpen" IsOpenChanged="OnDrawerChanged" Title="@DrawerTitle" Subtitle="@selectedCategory?.Slug" Eyebrow="Category">
    <div class="space-y-5">
        <div class="rounded-md border border-ink-200 p-4">
            <h2 class="text-sm font-semibold text-ink-900">Category fields</h2>
            <div class="mt-3 grid gap-3 text-sm">
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Name</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="categoryForm.Name" />
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Description</span>
                    <textarea class="min-h-24 w-full rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="categoryForm.Description"></textarea>
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Parent</span>
                    <select class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="categoryParentId">
                        <option value="">No parent</option>
                        @foreach (var category in categories.Where(category => category.Id != selectedCategory?.Id).OrderBy(category => category.Name))
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Image URL</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="categoryForm.Image" />
                </label>
                <label class="space-y-1">
                    <span class="font-medium text-ink-700">Display order</span>
                    <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" type="number" @bind="categoryForm.DisplayOrder" />
                </label>
            </div>
        </div>

        @if (selectedCategory is not null)
        {
            <div class="rounded-md border border-ink-200 p-4">
                <h2 class="text-sm font-semibold text-ink-900">SEO</h2>
                <div class="mt-3 grid gap-3 text-sm">
                    <label class="space-y-1">
                        <span class="font-medium text-ink-700">Slug</span>
                        <input class="min-h-10 w-full rounded-md border border-ink-300 px-3 font-mono text-xs outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" @bind="categorySeoForm.Slug" />
                    </label>
                    <div class="space-y-2 rounded-md border border-ink-200 bg-ink-50 p-3">
                        <div class="flex flex-wrap gap-2">
                            <button type="button" class="cp-button cp-button-secondary" disabled="@isSlugActionBusy" @onclick="GenerateCategorySlugAsync">
                                <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
                                Generate
                            </button>
                            <button type="button" class="cp-button cp-button-secondary" disabled="@isSlugActionBusy" @onclick="ValidateCategorySlugAsync">
                                <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                                Validate
                            </button>
                        </div>
                        <div class="grid gap-1 text-xs text-ink-600">
                            <div>Normalized: <span class="font-mono">@SlugPreviewText(categorySlugResult?.Slug)</span></div>
                            <div>Public path: <span class="font-mono">@BuildSeoPublicPath("category", categorySlugResult?.Slug ?? categorySeoForm.Slug)</span></div>
                            <div>Canonical preview: <span class="font-mono">@BuildSeoPublicPath("category", categorySlugResult?.Slug ?? categorySeoForm.Slug)</span></div>
                            @if (categorySlugResult is not null)
                            {
                                <div class="@(categorySlugResult.Success ? "text-green-700" : "text-red-700")">@SlugPreviewMessage(categorySlugResult)</div>
                            }
                        </div>
                        @if (categorySlugHistory.Count > 0)
                        {
                            <div class="border-t border-ink-200 pt-2">
                                <div class="text-xs font-semibold uppercase text-ink-500">Slug history</div>
                                <div class="mt-2 space-y-1">
                                    @foreach (var item in categorySlugHistory)
                                    {
                                        <div class="flex items-center justify-between gap-3 text-xs">
                                            <span class="font-mono text-ink-700">@item.Slug</span>
                                            <span class="text-ink-500">@(item.IsActive ? "active" : item.ReplacedAt?.ToLocalTime().ToString("yyyy-MM-dd"))</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Meta title" @bind="categorySeoForm.MetaTitle" />
                    <textarea class="min-h-20 rounded-md border border-ink-300 px-3 py-2 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Meta description" @bind="categorySeoForm.MetaDescription"></textarea>
                    <input class="min-h-10 rounded-md border border-ink-300 px-3 outline-none focus:border-control-500 focus:ring-2 focus:ring-control-100" placeholder="Canonical URL" @bind="categorySeoForm.CanonicalUrl" />
                    <div class="grid gap-3 md:grid-cols-2">
                        <label class="flex items-center gap-2 text-ink-700">
                            <input type="checkbox" @bind="categorySeoForm.IsPublished" />
                            Published
                        </label>
                        <label class="flex items-center gap-2 text-ink-700">
                            <input type="checkbox" @bind="categorySeoForm.RobotsIndex" />
                            Robots index
                        </label>
                        <label class="flex items-center gap-2 text-ink-700">
                            <input type="checkbox" @bind="categorySeoForm.RobotsFollow" />
                            Robots follow
                        </label>
                    </div>
                    <button class="cp-button cp-button-primary justify-center" disabled="@isSaving" @onclick="SaveCategorySeoAsync">
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        Save SEO
                    </button>
                </div>
            </div>
        }

        <div class="flex gap-2">
            <button class="cp-button cp-button-primary flex-1 justify-center" disabled="@isSaving" @onclick="SaveCategoryAsync">
                <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                Save category
            </button>
            @if (selectedCategory is not null)
            {
                <button class="cp-button cp-button-danger" disabled="@isSaving" @onclick="ArchiveCategoryAsync">
                    <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
                </button>
            }
        </div>
    </div>
</RightDrawer>

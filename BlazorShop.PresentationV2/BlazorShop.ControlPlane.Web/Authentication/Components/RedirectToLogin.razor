@inject NavigationManager NavigationManager

<div class="grid min-h-screen place-items-center bg-ink-50 text-ink-700">
    <div class="text-center">
        <div class="mx-auto mb-4 grid size-12 place-items-center rounded-md border border-ink-200 bg-white shadow-sm">
            <i class="fa-solid fa-lock" aria-hidden="true"></i>
        </div>
        <div class="text-sm font-semibold">Redirecting to sign in</div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var target = ProtectedRouteRedirectResolver.ResolveLoginRedirectPath(relativePath, isAuthenticated: false, loginPath: "/login");
        NavigationManager.NavigateTo(target ?? "/login", replace: true);
    }
}
